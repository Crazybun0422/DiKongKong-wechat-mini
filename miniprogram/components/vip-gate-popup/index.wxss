.vip-gate-overlay {
  position: fixed;
  inset: 0;
  background: rgba(2, 6, 23, 0.54);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  box-sizing: border-box;
  z-index: 2000;
}

.vip-gate-dialog {
  position: relative;
  width: 100%;
  max-width: 560rpx;
  padding: 48rpx 40rpx 40rpx;
  border-radius: 36rpx;
  background: #ffffff;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  box-shadow: 0 32rpx 80rpx rgba(2, 6, 23, 0.22);
}

.vip-gate-close {
  position: absolute;
  top: 22rpx;
  right: 22rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.vip-gate-close-icon {
  width: 28rpx;
  height: 28rpx;
}

.vip-gate-badge {
  width: 136rpx;
  height: 84rpx;
  margin-bottom: 18rpx;
}

.vip-gate-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #0f172a;
  line-height: 1.35;
}

.vip-gate-desc {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.65;
  color: rgba(15, 23, 42, 0.68);
}

.vip-gate-action {
  width: 100%;
  height: 92rpx;
  margin-top: 32rpx;
  border: none;
  border-radius: 999rpx;
  background: #000000;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.vip-gate-action::after {
  border: none;
}
