<view wx:if="{{visible}}" class="recharge-overlay {{successVisible ? 'is-success' : ''}}" catchtap="onMaskTap">
  <view wx:if="{{!successVisible}}" class="recharge-sheet" catchtap="noop">
    <text class="recharge-title">开通高级会员</text>

    <view class="recharge-mode-tabs">
      <block wx:for="{{paymentModes}}" wx:key="id">
        <view
          class="recharge-mode-tab {{paymentMode === item.id ? 'is-active' : ''}}"
          data-mode="{{item.id}}"
          bindtap="onModeTap"
        >
          {{item.label}}
        </view>
      </block>
    </view>

    <view class="recharge-plan-list">
      <block wx:for="{{plans}}" wx:key="cycle">
        <view
          class="recharge-plan {{selectedCycle === item.cycle ? 'is-active' : ''}}"
          data-cycle="{{item.cycle}}"
          bindtap="onPlanTap"
        >
          <text wx:if="{{item.badge}}" class="recharge-plan-badge">{{item.badge}}</text>
          <view class="recharge-plan-copy">
            <view class="recharge-plan-name-row">
              <text class="recharge-plan-name">{{item.name}}</text>
              <text class="recharge-plan-duration">{{item.duration}}</text>
            </view>
            <text class="recharge-plan-desc">{{item.desc}}</text>
          </view>
          <view class="recharge-plan-price">
            <text class="recharge-plan-current">{{item.price}}</text>
            <text class="recharge-plan-original">{{item.originalPrice}}</text>
          </view>
        </view>
      </block>
    </view>

    <button
      class="recharge-submit"
      loading="{{submitting}}"
      disabled="{{submitting}}"
      bindtap="onConfirmTap"
    >
      <view class="recharge-submit-content">
        <text class="recharge-submit-status">{{expireText || '暂未获得'}}</text>
        <text class="recharge-submit-text">立即支付</text>
      </view>
    </button>
  </view>

  <view wx:else class="recharge-success-sheet" catchtap="noop">
    <text class="recharge-success-title">开通成功</text>
    <text class="recharge-success-desc">恭喜成为低空星球高级会员</text>
    <text class="recharge-success-desc recharge-success-desc--tight">一起探索低空未来</text>

    <view class="recharge-success-qr-section {{memberGroupQrcodeLoading ? 'recharge-success-qr-section--loading' : ''}}">
      <view wx:if="{{!memberGroupQrcodeLoading}}" class="recharge-success-side-copy">
        <view class="recharge-success-side-copy-col">
          <text class="recharge-success-side-copy-char">长</text>
          <text class="recharge-success-side-copy-char">按</text>
          <text class="recharge-success-side-copy-char">识</text>
          <text class="recharge-success-side-copy-char">别</text>
          <text class="recharge-success-side-copy-char">二</text>
          <text class="recharge-success-side-copy-char">维</text>
          <text class="recharge-success-side-copy-char">码</text>
        </view>
        <view class="recharge-success-side-copy-col">
          <text class="recharge-success-side-copy-char">进</text>
          <text class="recharge-success-side-copy-char">会</text>
          <text class="recharge-success-side-copy-char">员</text>
          <text class="recharge-success-side-copy-char">专</text>
          <text class="recharge-success-side-copy-char">属</text>
          <text class="recharge-success-side-copy-char">群</text>
        </view>
      </view>

      <view class="recharge-success-qr-card {{memberGroupQrcodeLoading ? 'recharge-success-qr-card--loading' : ''}}" style="{{memberGroupQrcodeCardStyle}}">
        <image
          wx:if="{{memberGroupQrcodeReady && memberGroupQrcodeUrl}}"
          class="recharge-success-qr-image"
          src="{{memberGroupQrcodeUrl}}"
          style="{{memberGroupQrcodeImageStyle}}"
          mode="scaleToFill"
          bindload="onMemberGroupQrcodeLoad"
          show-menu-by-longpress="true"
        />
        <view
          wx:elif="{{memberGroupQrcodeLoading}}"
          class="recharge-success-qr-placeholder recharge-success-qr-placeholder--loading"
          style="{{memberGroupQrcodeImageStyle}}"
        >
          <view class="recharge-success-qr-skeleton">
            <view class="recharge-success-qr-skeleton-line recharge-success-qr-skeleton-line--sm"></view>
            <view class="recharge-success-qr-skeleton-line recharge-success-qr-skeleton-line--lg"></view>
            <view class="recharge-success-qr-skeleton-line recharge-success-qr-skeleton-line--md"></view>
          </view>
        </view>
        <view wx:else class="recharge-success-qr-placeholder" style="{{memberGroupQrcodeImageStyle}}">
          暂无群二维码
        </view>
      </view>
    </view>

    <button
      class="recharge-success-btn {{memberGroupQrcodeLoading ? 'is-disabled' : ''}}"
      bindtap="onSuccessConfirmTap"
      disabled="{{memberGroupQrcodeLoading}}"
    >
      立即体验
    </button>
  </view>
</view>
