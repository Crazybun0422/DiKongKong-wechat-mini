.recharge-overlay {
  position: fixed;
  inset: 0;
  z-index: 900;
  background: rgba(0, 0, 0, 0.54);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  font-family: "ZhSubset", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, "PingFang SC", "Heiti SC", "Microsoft YaHei", sans-serif;
}

.recharge-sheet,
.recharge-success-sheet {
  position: relative;
  width: 100%;
  box-sizing: border-box;
  background: #ffffff;
}

.recharge-sheet {
  min-height: 760rpx;
  padding: 34rpx 58rpx calc(env(safe-area-inset-bottom) + 44rpx);
  border-radius: 22rpx 22rpx 0 0;
}

.recharge-title {
  display: block;
  margin-bottom: 42rpx;
  font-size: 30rpx;
  line-height: 40rpx;
  font-weight: 800;
  color: #111827;
}

.recharge-mode-tabs {
  height: 54rpx;
  margin-bottom: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 30rpx;
}

.recharge-mode-tab {
  min-width: 130rpx;
  height: 48rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 500;
  color: #111827;
}

.recharge-mode-tab.is-active {
  background: #2f80ff;
  color: #ffffff;
  font-weight: 800;
}

.recharge-plan-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.recharge-plan {
  position: relative;
  height: 114rpx;
  padding: 20rpx 24rpx 16rpx 28rpx;
  border: 2rpx solid rgba(17, 24, 39, 0.32);
  border-radius: 8rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #ffffff;
}

.recharge-plan.is-active {
  border-color: #ffa726;
}

.recharge-plan-badge {
  position: absolute;
  right: 10rpx;
  top: -22rpx;
  height: 38rpx;
  min-width: 126rpx;
  padding: 0 14rpx;
  border-radius: 8rpx;
  background: #ffb423;
  color: #ffffff;
  font-size: 22rpx;
  line-height: 38rpx;
  text-align: center;
  font-weight: 800;
}

.recharge-plan-copy {
  min-width: 0;
  flex: 1;
}

.recharge-plan-name-row {
  display: flex;
  align-items: baseline;
  min-width: 0;
}

.recharge-plan-name,
.recharge-plan-duration {
  font-size: 30rpx;
  line-height: 40rpx;
  font-weight: 800;
  color: #111827;
  white-space: nowrap;
}

.recharge-plan-duration {
  margin-left: 10rpx;
  font-weight: 700;
}

.recharge-plan-desc {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  line-height: 32rpx;
  color: rgba(17, 24, 39, 0.64);
}

.recharge-plan-price {
  width: 116rpx;
  flex: 0 0 116rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.recharge-plan-current {
  font-size: 34rpx;
  line-height: 40rpx;
  font-weight: 900;
  color: #111827;
  white-space: nowrap;
}

.recharge-plan-original {
  margin-top: 4rpx;
  font-size: 24rpx;
  line-height: 28rpx;
  color: rgba(17, 24, 39, 0.44);
  text-decoration: line-through;
  white-space: nowrap;
}

button.recharge-submit,
button.recharge-success-btn {
  margin: 0;
  padding: 0;
  border: none;
  background: #000000;
  color: #ffffff;
  line-height: normal;
  box-sizing: border-box;
  font-family: inherit;
}

button.recharge-submit {
  position: absolute;
  left: 50%;
  bottom: calc(env(safe-area-inset-bottom) + 42rpx);
  transform: translateX(-50%);
  width: 500rpx;
  height: 84rpx;
  border-radius: 999rpx;
}

button.recharge-submit::after,
button.recharge-success-btn::after {
  border: none;
}

.recharge-submit-content {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  align-items: center;
  justify-content: flex-start;
  white-space: nowrap;
}

.recharge-submit-status {
  display: block;
  font-size: 26rpx;
  color: #8da0ad;
  line-height: 1;
  white-space: nowrap;
  flex-shrink: 0;
}

.recharge-submit-text {
  display: block;
  font-size: 32rpx;
  font-weight: 900;
  color: #ffffff;
  line-height: 1;
  white-space: nowrap;
  flex-shrink: 0;
  margin-left: 24rpx;
}

.recharge-success-sheet {
  min-height: 860rpx;
  padding: 48rpx 58rpx calc(env(safe-area-inset-bottom) + 46rpx);
  border-radius: 22rpx 22rpx 0 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
}

.recharge-success-title {
  font-size: 42rpx;
  line-height: 58rpx;
  font-weight: 900;
  color: #101010;
  text-align: center;
}

.recharge-success-desc {
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 700;
  color: #333333;
  text-align: center;
}

.recharge-success-desc--tight {
  margin-top: 0;
}

.recharge-success-qr-section {
  width: 100%;
  margin-top: 42rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 340rpx;
}

.recharge-success-qr-section--loading {
  min-height: 340rpx;
}

.recharge-success-side-copy {
  position: absolute;
  right: 50%;
  top: 50%;
  transform: translate(-160rpx, -50%);
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}

.recharge-success-side-copy-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.recharge-success-side-copy-char {
  font-size: 32rpx;
  line-height: 36rpx;
  font-weight: 800;
  color: #d79a27;
}

.recharge-success-qr-card {
  border: 2rpx solid rgba(223, 184, 107, 0.9);
  border-radius: 20rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  overflow: hidden;
  background: #fffdf8;
  margin: 0 auto;
}

.recharge-success-qr-card--loading {
  border-color: transparent;
  background: transparent;
}

.recharge-success-qr-image,
.recharge-success-qr-placeholder {
  display: block;
  flex: 0 0 auto;
}

.recharge-success-qr-image {
  border-radius: 12rpx;
  background: #ffffff;
}

.recharge-success-qr-placeholder {
  border-radius: 12rpx;
  background: rgba(17, 24, 39, 0.04);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  line-height: 34rpx;
  font-weight: 600;
  color: rgba(17, 24, 39, 0.48);
  text-align: center;
}

.recharge-success-qr-placeholder--loading {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.36), rgba(255, 255, 255, 0.18));
  border: 2rpx solid rgba(15, 23, 42, 0.08);
  box-shadow:
    0 10rpx 24rpx rgba(15, 23, 42, 0.06),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.4);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
}

.recharge-success-qr-skeleton {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  align-items: center;
}

.recharge-success-qr-skeleton-line {
  height: 16rpx;
  border-radius: 999rpx;
  background: linear-gradient(
    90deg,
    rgba(15, 23, 42, 0.08),
    rgba(15, 23, 42, 0.16),
    rgba(15, 23, 42, 0.08)
  );
}

.recharge-success-qr-skeleton-line--sm {
  width: 120rpx;
}

.recharge-success-qr-skeleton-line--md {
  width: 176rpx;
}

.recharge-success-qr-skeleton-line--lg {
  width: 220rpx;
}

button.recharge-success-btn {
  width: 500rpx;
  height: 88rpx;
  margin-top: auto;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
}

button.recharge-success-btn.is-disabled,
button.recharge-success-btn[disabled] {
  opacity: 0.42;
}
