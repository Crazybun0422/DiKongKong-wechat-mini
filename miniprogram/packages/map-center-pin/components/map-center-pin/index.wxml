<view
  class="center-pin-touch-area"
  style="top: calc(50% - {{topOffsetPx}}px);"
  bindtap="onTap"
  bindlongpress="onLongPress"
>
  <view wx:if="{{showWelcomeBubble}}" class="center-pin-tip">
    <text class="center-pin-tip-text">长按中心地标触发魔法~ 🔮</text>
  </view>

  <image
    class="center-pin {{satellite ? 'center-pin--satellite' : ''}} {{triggered ? 'is-triggered' : ''}}"
    src="/assets/position.png"
    mode="widthFix"
  />
  <view class="center-pin-ring {{triggered ? 'is-visible' : ''}}"></view>
</view>

<block wx:if="{{sheetVisible}}">
  <view class="center-pin-sheet-mask" bindtap="onMaskTap"></view>
  <view class="center-pin-sheet {{sheetClosing ? 'is-closing' : 'is-open'}}" catchtap="onSheetTap" catchtouchmove="noop">
    <view class="center-pin-sheet-handle"></view>
    <view class="center-pin-sheet-actions">
      <block wx:for="{{actionItems}}" wx:key="id">
        <view class="center-pin-action-item" data-action="{{item.id}}" bindtap="onActionTap">
          <image class="center-pin-action-icon" src="{{item.icon}}" mode="aspectFit" />
          <text class="center-pin-action-label">{{item.label}}</text>
        </view>
      </block>
    </view>
  </view>
</block>
