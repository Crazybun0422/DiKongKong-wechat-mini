page {
  width: 100%;
  height: 100%;
  overflow: hidden;
  background: #000000;
}

.afei-page {
  position: fixed;
  inset: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
  background: #05070a;
}

.afei-stage-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.intro-splash {
  position: absolute;
  inset: 0;
  z-index: 90;
  opacity: 1;
  transition: opacity 420ms ease;
  pointer-events: none;
}

.intro-splash.is-fading {
  opacity: 0;
}

.intro-splash-image,
.intro-splash-fallback {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.intro-splash-fallback {
  background: #000000;
}

.afei-ui-layer {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.game-back-anchor {
  position: absolute;
  left: calc(env(safe-area-inset-left) + 12rpx);
  top: calc(env(safe-area-inset-top) + 12rpx);
  z-index: 30;
  pointer-events: auto;
}

.game-tools-anchor {
  position: absolute;
  right: calc(env(safe-area-inset-right) + 148rpx);
  top: calc(env(safe-area-inset-top) + 12rpx);
  display: flex;
  align-items: center;
  gap: 8rpx;
  z-index: 30;
  pointer-events: auto;
}

.mini-btn {
  min-width: 30rpx;
  height: 30rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: radial-gradient(circle at 30% 26%, rgba(255, 255, 255, 0.94), rgba(209, 224, 255, 0.86) 44%, rgba(103, 152, 243, 0.84) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.68);
  box-shadow: 0 5rpx 10rpx rgba(0, 0, 0, 0.24), inset 0 2rpx 5rpx rgba(255, 255, 255, 0.62);
  transition: transform 90ms ease, opacity 90ms ease;
}

.mini-btn.is-active {
  transform: scale(0.93);
  box-shadow: 0 3rpx 7rpx rgba(0, 0, 0, 0.2), inset 0 1rpx 3rpx rgba(255, 255, 255, 0.45);
  opacity: 0.92;
}

.mini-btn.is-disabled {
  opacity: 0.55;
}

.mini-btn-text {
  font-size: 16rpx;
  color: #103057;
  font-weight: 700;
  line-height: 1;
}

.ctrl-left,
.ctrl-right {
  position: absolute;
  display: flex;
  pointer-events: auto;
  z-index: 20;
}

.ctrl-left {
  left: 22rpx;
  bottom: calc(env(safe-area-inset-bottom) + 22rpx);
  flex-direction: row;
  gap: 22rpx;
}

.ctrl-right {
  right: 22rpx;
  bottom: calc(env(safe-area-inset-bottom) + 22rpx);
  flex-direction: column;
  gap: 20rpx;
}

.bubble-btn {
  width: 62rpx;
  height: 62rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: radial-gradient(circle at 30% 26%, rgba(255, 255, 255, 0.60), rgba(209, 224, 255, 0.44) 44%, rgba(103, 152, 243, 0.42) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.68);
  box-shadow: 0 7rpx 14rpx rgba(0, 0, 0, 0.22), inset 0 1rpx 3rpx rgba(255, 255, 255, 0.28);
  transition: transform 90ms ease, opacity 90ms ease;
}

.bubble-btn.is-active {
  transform: scale(0.92);
  box-shadow: 0 3rpx 8rpx rgba(0, 0, 0, 0.18), inset 0 1rpx 3rpx rgba(255, 255, 255, 0.22);
  opacity: 0.92;
}

.bubble-icon {
  width: 36rpx;
  height: 36rpx;
}

.panel-mask {
  position: absolute;
  inset: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  padding: calc(env(safe-area-inset-top) + 8rpx) 10rpx calc(env(safe-area-inset-bottom) + 8rpx);
  overflow: hidden;
  background: linear-gradient(180deg, rgba(8, 12, 20, 0.68) 0%, rgba(8, 12, 20, 0.82) 100%);
  pointer-events: auto;
}

.start-panel {
  width: 64vw;
  max-width: 520rpx;
  border-radius: 14rpx;
  padding: 10rpx;
  box-sizing: border-box;
  border: 2rpx solid rgba(255, 231, 161, 0.9);
  background: linear-gradient(180deg, rgba(23, 35, 47, 0.96) 0%, rgba(14, 21, 31, 0.96) 100%);
  box-shadow: 0 16rpx 30rpx rgba(0, 0, 0, 0.35), inset 0 2rpx 8rpx rgba(255, 245, 216, 0.16);
}

.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 2rpx;
}

.panel-back-btn {
  min-width: 78rpx;
  height: 28rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13rpx;
  font-weight: 700;
  color: #1d2630;
  background: linear-gradient(180deg, #f4e6be 0%, #c6ad6e 100%);
  border: 1rpx solid rgba(255, 241, 201, 0.9);
}

.panel-title {
  font-size: 20rpx;
  font-weight: 800;
  color: #fff2c7;
  letter-spacing: 0.5rpx;
}

.metric-grid {
  margin-top: 8rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6rpx;
}

.metric-item {
  border-radius: 8rpx;
  padding: 6rpx 8rpx;
  background: rgba(7, 13, 22, 0.65);
  border: 1rpx solid rgba(151, 212, 145, 0.46);
}

.metric-name {
  display: block;
  font-size: 13rpx;
  color: rgba(220, 238, 251, 0.78);
}

.metric-value {
  display: inline-block;
  margin-top: 3rpx;
  padding: 2rpx 6rpx;
  border-radius: 999rpx;
  font-size: 16rpx;
  color: #04141e;
  font-weight: 700;
  background: linear-gradient(180deg, #d8f7ff 0%, #9cd9ea 100%);
}

.offline-chip {
  margin-top: 6rpx;
  display: inline-flex;
  padding: 3rpx 8rpx;
  border-radius: 999rpx;
  font-size: 12rpx;
  color: #1c1e25;
  background: linear-gradient(180deg, #ffe7b1 0%, #deb468 100%);
}

.panel-status {
  margin-top: 4rpx;
  font-size: 12rpx;
  color: rgba(210, 228, 241, 0.9);
}

.panel-actions {
  margin-top: 8rpx;
  display: flex;
  gap: 6rpx;
}

.panel-btn {
  flex: 1;
  height: 40rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid transparent;
}

.panel-btn--primary {
  background: linear-gradient(180deg, #8ef8b3 0%, #2ea96a 100%);
  border-color: rgba(184, 255, 207, 0.86);
}

.panel-btn--ghost {
  background: rgba(14, 21, 31, 0.62);
  border-color: rgba(169, 215, 255, 0.58);
}

.panel-btn.is-disabled {
  opacity: 0.6;
}

.panel-btn-text {
  font-size: 16rpx;
  color: #05141d;
  font-weight: 700;
}

.panel-btn--ghost .panel-btn-text {
  color: #dcefff;
}

.panel-mask--leaderboard {
  z-index: 55;
}

.rank-panel {
  width: 70vw;
  max-width: 560rpx;
  max-height: 78vh;
  border-radius: 16rpx;
  overflow: hidden;
  border: 2rpx solid rgba(255, 231, 161, 0.9);
  background: linear-gradient(180deg, rgba(16, 24, 35, 0.98) 0%, rgba(9, 16, 23, 0.98) 100%);
}

.rank-header {
  height: 56rpx;
  padding: 0 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid rgba(165, 201, 228, 0.24);
}

.rank-title {
  font-size: 20rpx;
  color: #fbe9b8;
  font-weight: 800;
}

.rank-close {
  min-width: 68rpx;
  height: 30rpx;
  border-radius: 999rpx;
  text-align: center;
  line-height: 30rpx;
  font-size: 15rpx;
  color: #1d2630;
  background: linear-gradient(180deg, #f4e6be 0%, #c6ad6e 100%);
}

.rank-list {
  max-height: calc(78vh - 56rpx);
}

.rank-item {
  height: 64rpx;
  padding: 0 10rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid rgba(165, 201, 228, 0.14);
}

.rank-index {
  width: 38rpx;
  text-align: center;
  font-size: 18rpx;
  font-weight: 800;
  color: #f5e4ac;
}

.rank-avatar {
  width: 36rpx;
  height: 36rpx;
  border-radius: 999rpx;
  background: #22313d;
  border: 1rpx solid rgba(182, 220, 255, 0.46);
}

.rank-meta {
  margin-left: 8rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  flex: 1;
  min-width: 0;
}

.rank-name {
  font-size: 16rpx;
  color: #e9f4ff;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rank-code {
  margin-top: 2rpx;
  font-size: 13rpx;
  color: rgba(174, 204, 232, 0.86);
}

.rank-score {
  margin-left: 8rpx;
  font-size: 17rpx;
  font-weight: 700;
  color: #8cf2b1;
}

.rank-empty {
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16rpx;
  color: rgba(179, 211, 236, 0.82);
}
