.preflight-rich-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f7f8fa;
}

.preflight-rich-scroll {
  flex: 1;
  box-sizing: border-box;
  padding: 16px 16px 22px;
}

.preflight-rich-loading,
.preflight-rich-error {
  margin-top: 60px;
  text-align: center;
  color: #666666;
  font-size: 14px;
}

.preflight-rich-retry {
  margin-top: 14px;
  min-width: 110px;
  height: 36px;
  line-height: 36px;
  border-radius: 999px;
  background: #1f1f1f;
  color: #ffffff;
  font-size: 14px;
}

.preflight-rich-retry::after {
  border: none;
}

.preflight-rich-content {
  color: #1f1f1f;
  font-size: 15px;
  line-height: 1.78;
}

.preflight-rich-image {
  display: block;
  width: 100%;
  margin: 14px auto;
  border-radius: 12px;
  background: #f5f6f7;
}
