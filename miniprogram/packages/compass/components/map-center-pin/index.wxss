:host {
  position: absolute;
  inset: 0;
  z-index: 130;
  pointer-events: none;
}

.center-pin-touch-area {
  position: absolute;
  left: 50%;
  width: 120rpx;
  height: 132rpx;
  transform: translate3d(-50%, -100%, 0);
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: auto;
}

.center-pin {
  width: 48rpx;
  height: 51rpx;
  display: block;
  filter: brightness(0) saturate(100%);
  opacity: 0.95;
  transition: transform 120ms ease, opacity 120ms ease;
}

.center-pin--satellite {
  filter: brightness(0) saturate(100%) invert(1);
}

.center-pin.is-triggered {
  animation: center-pin-trigger 280ms cubic-bezier(0.22, 1, 0.36, 1);
}

.center-pin-ring {
  position: absolute;
  left: 50%;
  top: calc(50% + 8rpx);
  width: 28rpx;
  height: 28rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(15, 23, 42, 0.32);
  transform: translate(-50%, -50%) scale(0.8);
  opacity: 0;
  pointer-events: none;
}

.center-pin-ring.is-visible {
  animation: center-pin-ring 320ms ease-out;
}

.center-pin-tip {
  position: absolute;
  left: 50%;
  bottom: calc(100% - 24rpx);
  transform: translateX(-50%);
  padding: 14rpx 26rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.62);
  background: linear-gradient(160deg, rgba(255, 255, 255, 0.65), rgba(243, 246, 251, 0.5));
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.1);
  -webkit-backdrop-filter: blur(10rpx);
  backdrop-filter: blur(10rpx);
  pointer-events: none;
  white-space: nowrap;
  z-index: 2;
  animation: center-pin-tip-float 2.8s ease-in-out infinite;
}

.center-pin-tip::before {
  content: none;
}

.center-pin-tip::after {
  content: none;
}

.center-pin-tip-text {
  position: relative;
  z-index: 1;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  color: #0f172a;
}

.center-pin-sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.42);
  z-index: 130;
  pointer-events: auto;
}

.center-pin-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 131;
  background: #ffffff;
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
  padding: 24rpx 40rpx calc(env(safe-area-inset-bottom) + 40rpx);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 24rpx;
  box-shadow: 0 -20rpx 60rpx rgba(15, 23, 42, 0.14);
  pointer-events: auto;
}

.center-pin-sheet.is-open {
  animation: center-pin-sheet-up 220ms cubic-bezier(0.22, 1, 0.36, 1);
}

.center-pin-sheet.is-closing {
  animation: center-pin-sheet-down 220ms cubic-bezier(0.33, 1, 0.68, 1);
}

.center-pin-sheet-handle {
  width: 96rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.2);
  margin: 0 auto;
}

.center-pin-sheet-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
  text-align: center;
}

.center-pin-sheet-desc {
  font-size: 26rpx;
  line-height: 1.6;
  color: #475569;
  text-align: center;
}

.center-pin-sheet-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 999rpx;
  border: none;
  background: #0f172a;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.center-pin-sheet-btn::after {
  display: none;
}

@keyframes center-pin-trigger {
  0% {
    transform: scale(0.9);
  }
  55% {
    transform: scale(1.2);
  }
  100% {
    transform: scale(1);
  }
}

@keyframes center-pin-ring {
  0% {
    transform: translate(-50%, -50%) scale(0.8);
    opacity: 0.45;
  }
  100% {
    transform: translate(-50%, -50%) scale(2.5);
    opacity: 0;
  }
}

@keyframes center-pin-sheet-up {
  0% {
    transform: translateY(100%);
    opacity: 0;
  }
  100% {
    transform: translateY(0);
    opacity: 1;
  }
}

@keyframes center-pin-sheet-down {
  0% {
    transform: translateY(0);
    opacity: 1;
  }
  100% {
    transform: translateY(100%);
    opacity: 0;
  }
}

@keyframes center-pin-tip-float {
  0%,
  100% {
    transform: translateX(-50%) translateY(0);
  }
  50% {
    transform: translateX(-50%) translateY(-4rpx);
  }
}
