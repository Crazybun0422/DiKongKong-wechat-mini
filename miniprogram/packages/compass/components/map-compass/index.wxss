.map-compass {
  width: 66rpx;
  height: 66rpx;
  border-radius: 50%;
  background: transparent;
  border: 0;
  box-shadow: none;
  position: relative;
  pointer-events: auto;
}

.map-compass-body {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  transform-origin: 50% 50%;
  transform-style: preserve-3d;
}

.map-compass-dial,
.map-compass-pointer,
.map-compass-north {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

.map-compass-north {
  top: -44rpx;
  width: 44rpx;
  height: 66rpx;
  left: 50%;
  transform: translateX(-50%);
}

.map-compass-pointer {
  transform-origin: 50% 50%;
}

.map-compass--satellite .map-compass-dial,
.map-compass--satellite .map-compass-north {
  filter: brightness(0) invert(1) contrast(1.15) drop-shadow(0 2rpx 6rpx rgba(0, 0, 0, 0.78));
}
