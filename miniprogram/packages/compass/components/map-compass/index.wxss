.map-compass {
  width: 75rpx;
  height: 75rpx;
  border-radius: 50%;
  background: transparent;
  border: 0;
  box-shadow: none;
  position: relative;
  pointer-events: auto;
}

.map-compass-body {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  transform-origin: 50% 50%;
  transform-style: preserve-3d;
}

.map-compass-dial,
.map-compass-pointer,
.map-compass-north {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

.map-compass-north {
  top: -50rpx;
  width: 50rpx;
  height: 75rpx;
  left: 50%;
  transform: translateX(-50%);
}

.map-compass-pointer {
  transform-origin: 50% 50%;
}
