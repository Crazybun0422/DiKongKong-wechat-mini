<block wx:if="{{visible}}">
  <view class="add-mini-mask-layer" catchtap="onMaskTap" catchtouchmove="noop">
    <view
      class="add-mini-hole"
      style="top: {{mask.top}}px; left: {{mask.left}}px; width: {{mask.width}}px; height: {{mask.height}}px; border-radius: {{mask.radius}}px;"
      catchtap="onHoleTap"
    ></view>
  </view>

  <view class="add-mini-popup" style="top: {{popupTop}}px;" catchtap="onPopupTap">
    <view class="add-mini-body">
      <image class="add-mini-hero" src="/packages/add-mini-app/assets/af-lay.png" mode="widthFix" />
      <view class="add-mini-skin-wrap">
        <image class="add-mini-skin" src="/packages/add-mini-app/assets/add-mini-app.svg" mode="widthFix" />
        <view class="add-mini-panel">
          <view class="add-mini-title">合规飞行，从添加开始</view>
          <view class="add-mini-step">
            <view class="add-mini-step-index">1</view>
            <view class="add-mini-step-text">
              <text>点击按钮“</text>
              <image class="add-mini-more-icon" src="/packages/add-mini-app/assets/wechat-more.png" mode="aspectFit" />
              <text>”选择添加</text>
            </view>
          </view>
          <view class="add-mini-step-image">
            <image class="add-mini-step-img" src="/packages/add-mini-app/assets/p1.png" mode="widthFix" />
          </view>
          <view class="add-mini-step">
            <view class="add-mini-step-index">2</view>
            <view class="add-mini-step-text">微信下拉，从“我的小程序”进入</view>
          </view>
          <view class="add-mini-step-image">
            <image class="add-mini-step-img" src="/packages/add-mini-app/assets/p2.png" mode="widthFix" />
          </view>
          <image class="add-mini-point" src="/packages/add-mini-app/assets/left-point.png" mode="widthFix" />
        </view>
      </view>
    </view>
  </view>
</block>
