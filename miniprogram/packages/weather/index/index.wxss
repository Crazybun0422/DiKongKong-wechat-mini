.weather-page {
  min-height: 100vh;
  background: #f5f5f7;
}

.weather-page--satellite {
  background: #0f172a;
}

.weather-scroll {
  padding: 28rpx 28rpx calc(env(safe-area-inset-bottom) + 36rpx);
  box-sizing: border-box;
}

.weather-hero-card {
  border-radius: 34rpx;
  padding: 32rpx 30rpx;
  background: linear-gradient(180deg, #ffffff 0%, #eef2f7 100%);
  box-shadow: 0 18rpx 42rpx rgba(15, 23, 42, 0.08);
}

.weather-hero-card--satellite {
  background: linear-gradient(180deg, rgba(30, 41, 59, 0.96) 0%, rgba(15, 23, 42, 0.98) 100%);
  box-shadow: 0 20rpx 42rpx rgba(0, 0, 0, 0.32);
}

.weather-hero-top,
.weather-hero-main,
.weather-metric-head,
.weather-forecast-top,
.weather-forecast-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.weather-brand-pill {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.06);
  color: #0f172a;
  font-size: 22rpx;
  font-weight: 700;
}

.weather-hero-card--satellite .weather-brand-pill {
  background: rgba(255, 255, 255, 0.12);
  color: #f8fafc;
}

.weather-updated-text {
  font-size: 22rpx;
  color: rgba(15, 23, 42, 0.56);
}

.weather-hero-card--satellite .weather-updated-text,
.weather-hero-card--satellite .weather-hero-subtitle,
.weather-hero-card--satellite .weather-hero-coords,
.weather-metric-card--satellite .weather-metric-label,
.weather-forecast-card--satellite .weather-forecast-time,
.weather-forecast-card--satellite .weather-forecast-metric-label,
.weather-note-card--satellite .weather-note-text,
.weather-note-card--satellite .weather-note-tip {
  color: rgba(248, 250, 252, 0.74);
}

.weather-hero-main {
  justify-content: flex-start;
  margin-top: 30rpx;
}

.weather-hero-icon {
  width: 120rpx;
  height: 120rpx;
  flex-shrink: 0;
}

.weather-hero-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.weather-hero-title {
  font-size: 54rpx;
  line-height: 1;
  color: #0f172a;
  font-weight: 700;
}

.weather-hero-card--satellite .weather-hero-title,
.weather-hero-card--satellite .weather-hero-loading-text,
.weather-metric-card--satellite .weather-metric-value,
.weather-forecast-card--satellite .weather-forecast-title,
.weather-forecast-card--satellite .weather-forecast-label,
.weather-forecast-card--satellite .weather-forecast-metric-value,
.weather-note-card--satellite .weather-note-title {
  color: #f8fafc;
}

.weather-hero-subtitle {
  font-size: 24rpx;
  color: rgba(15, 23, 42, 0.58);
}

.weather-hero-coords {
  font-size: 22rpx;
  color: rgba(15, 23, 42, 0.58);
  word-break: break-all;
}

.weather-hero-loading {
  margin-top: 26rpx;
}

.weather-hero-loading-text {
  font-size: 26rpx;
  line-height: 1.5;
  color: #0f172a;
}

.weather-state-card,
.weather-note-card {
  margin-top: 24rpx;
  border-radius: 30rpx;
  padding: 30rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 32rpx rgba(15, 23, 42, 0.08);
}

.weather-note-card--satellite {
  background: rgba(30, 41, 59, 0.92);
  box-shadow: 0 18rpx 32rpx rgba(0, 0, 0, 0.22);
}

.weather-state-title,
.weather-note-title {
  font-size: 30rpx;
  line-height: 1.4;
  color: #0f172a;
  font-weight: 700;
}

.weather-note-text,
.weather-note-tip {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #475569;
}

.weather-retry-btn {
  margin-top: 24rpx;
  width: 100%;
  height: 84rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #020202 0%, #3a3a3d 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.weather-retry-btn::after {
  border: none;
}

.weather-metric-row {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
}

.weather-metric-card,
.weather-forecast-card {
  border-radius: 28rpx;
  padding: 24rpx 22rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.08);
}

.weather-metric-card--satellite,
.weather-forecast-card--satellite {
  background: rgba(30, 41, 59, 0.92);
  box-shadow: 0 16rpx 30rpx rgba(0, 0, 0, 0.22);
}

.weather-metric-head {
  justify-content: flex-start;
}

.weather-metric-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.weather-metric-label {
  font-size: 22rpx;
  color: #64748b;
  font-weight: 600;
}

.weather-metric-value {
  display: block;
  margin-top: 18rpx;
  font-size: 32rpx;
  line-height: 1.2;
  color: #0f172a;
  font-weight: 700;
}

.weather-section {
  margin-top: 24rpx;
}

.weather-section-head {
  padding: 4rpx 4rpx 20rpx;
}

.weather-section-title {
  display: block;
  font-size: 30rpx;
  line-height: 1.3;
  color: #0f172a;
  font-weight: 700;
}

.weather-page--satellite .weather-section-title,
.weather-page--satellite .weather-section-subtitle {
  color: #f8fafc;
}

.weather-section-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.4;
  color: #64748b;
}

.weather-forecast-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.weather-forecast-title {
  font-size: 28rpx;
  line-height: 1.2;
  color: #0f172a;
  font-weight: 700;
}

.weather-forecast-time {
  font-size: 22rpx;
  line-height: 1.2;
  color: #64748b;
}

.weather-forecast-summary {
  justify-content: flex-start;
  margin-top: 20rpx;
}

.weather-forecast-icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}

.weather-forecast-label {
  font-size: 24rpx;
  line-height: 1.2;
  color: #0f172a;
  font-weight: 600;
}

.weather-forecast-metrics {
  margin-top: 22rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.weather-forecast-metric {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.weather-forecast-metric-label {
  font-size: 22rpx;
  line-height: 1.3;
  color: #64748b;
}

.weather-forecast-metric-value {
  font-size: 23rpx;
  line-height: 1.3;
  color: #0f172a;
  font-weight: 600;
  text-align: right;
}
