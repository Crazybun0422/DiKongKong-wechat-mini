.weather-strip {
  position: absolute;
  display: inline-block;
  z-index: 37;
  pointer-events: auto;
}

.weather-strip-shell {
  display: inline-flex;
  align-items: center;
  min-width: 0;
  border-radius: 9px;
  padding: 4px 6px;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.22), rgba(255, 255, 255, 0.08));
  border: 1.5px solid rgba(15, 23, 42, 0.44);
  box-shadow:
    0 8px 18px rgba(15, 23, 42, 0.08),
    inset 0 1px 0 rgba(255, 255, 255, 0.18);
  backdrop-filter: blur(4px);
}

.weather-strip-shell--loading {
  background: transparent;
}

.weather-strip--satellite .weather-strip-shell {
  background: linear-gradient(180deg, rgba(8, 12, 18, 0.36), rgba(8, 12, 18, 0.18));
  border-color: rgba(255, 255, 255, 0.34);
  box-shadow:
    0 10px 20px rgba(0, 0, 0, 0.22),
    inset 0 1px 0 rgba(255, 255, 255, 0.08);
}

.weather-strip--satellite .weather-strip-shell--loading {
  background: transparent;
}

.weather-strip-main {
  display: flex;
  align-items: center;
  gap: 5px;
  min-width: 0;
}

.weather-strip-icon-shell {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: rgba(15, 23, 42, 0.08);
  border: 1px solid rgba(15, 23, 42, 0.12);
  flex-shrink: 0;
}

.weather-strip--satellite .weather-strip-icon-shell {
  background: rgba(255, 255, 255, 0.08);
  border-color: rgba(255, 255, 255, 0.12);
}

.weather-strip-icon {
  width: 21px;
  height: 21px;
  flex-shrink: 0;
}

.weather-strip-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 1px;
}

.weather-strip-weather,
.weather-strip-speed,
.weather-strip-force,
.weather-strip-state-text {
  line-height: 1.15;
  white-space: nowrap;
}

.weather-strip-weather {
  font-size: 13px;
  font-weight: 700;
  color: rgba(15, 23, 42, 0.94);
  letter-spacing: 0.2px;
}

.weather-strip-speed-stack {
  display: inline-flex;
  align-items: baseline;
  gap: 3px;
  min-width: 0;
}

.weather-strip-speed {
  font-size: 11px;
  font-weight: 700;
  color: rgba(15, 23, 42, 0.9);
  text-decoration: underline;
  text-decoration-thickness: 1px;
  text-underline-offset: 2px;
}

.weather-strip-force {
  font-size: 10px;
  font-weight: 700;
  color: rgba(15, 23, 42, 0.72);
  padding: 1px 4px;
  border-radius: 999px;
  background: rgba(15, 23, 42, 0.08);
}

.weather-strip--satellite .weather-strip-weather,
.weather-strip--satellite .weather-strip-speed,
.weather-strip--satellite .weather-strip-force,
.weather-strip--satellite .weather-strip-state-text {
  color: #f8fafc;
}

.weather-strip-meta {
  display: flex;
  align-items: center;
  gap: 5px;
}

.weather-strip-pointer-badge {
  width: 21px;
  height: 21px;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: rgba(15, 23, 42, 0.08);
  border: 1px solid rgba(15, 23, 42, 0.12);
  flex-shrink: 0;
}

.weather-strip--satellite .weather-strip-pointer-badge {
  background: rgba(255, 255, 255, 0.08);
  border-color: rgba(255, 255, 255, 0.14);
}

.weather-strip--satellite .weather-strip-force {
  background: rgba(255, 255, 255, 0.08);
}

.weather-strip-pointer {
  position: relative;
  width: 13px;
  height: 13px;
  flex-shrink: 0;
  transform-origin: center;
}

.weather-strip-pointer-line {
  position: absolute;
  left: 50%;
  top: 2px;
  width: 1.5px;
  height: 7px;
  transform: translateX(-50%);
  border-radius: 999px;
}

.weather-strip-pointer-head {
  position: absolute;
  left: 50%;
  top: 0;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 2.5px solid transparent;
  border-right: 2.5px solid transparent;
}

.weather-strip-pointer--dark .weather-strip-pointer-line {
  background: rgba(15, 23, 42, 0.82);
}

.weather-strip-pointer--dark .weather-strip-pointer-head {
  border-bottom: 5px solid rgba(15, 23, 42, 0.92);
}

.weather-strip-pointer--light .weather-strip-pointer-line {
  background: rgba(248, 250, 252, 0.88);
}

.weather-strip-pointer--light .weather-strip-pointer-head {
  border-bottom: 5px solid rgba(248, 250, 252, 0.96);
}

.weather-strip-state {
  min-height: 22px;
  display: flex;
  align-items: center;
}

.weather-strip-state-text {
  font-size: 12px;
  font-weight: 700;
  color: rgba(15, 23, 42, 0.86);
}

.weather-strip-skeleton {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.weather-strip-skeleton-line {
  height: 14rpx;
  border-radius: 999rpx;
  background: linear-gradient(
    90deg,
    rgba(15, 23, 42, 0.08),
    rgba(15, 23, 42, 0.16),
    rgba(15, 23, 42, 0.08)
  );
}

.weather-strip--satellite .weather-strip-skeleton-line {
  background: linear-gradient(
    90deg,
    rgba(255, 255, 255, 0.14),
    rgba(255, 255, 255, 0.24),
    rgba(255, 255, 255, 0.14)
  );
}

.weather-strip-skeleton-line--sm {
  width: 90rpx;
}

.weather-strip-skeleton-line--lg {
  width: 170rpx;
}
