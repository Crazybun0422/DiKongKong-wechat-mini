.member-page {
  min-height: 100vh;
  background: #ffffff;
  color: #111827;
}

.member-shell {
  position: relative;
  min-height: 100vh;
  padding: calc(env(safe-area-inset-top) + 132rpx) 58rpx calc(env(safe-area-inset-bottom) + 178rpx);
  box-sizing: border-box;
  overflow: hidden;
  background: #ffffff;
}

.member-gradient {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  height: 360rpx;
  pointer-events: none;
  background: linear-gradient(180deg, #dceafe 0%, #eef6ff 46%, rgba(255, 255, 255, 0) 100%);
}

.member-topbar,
.member-main-tabs,
.member-content,
.member-action-wrap {
  position: relative;
  z-index: 1;
}

.member-topbar {
  position: absolute;
  left: 58rpx;
  right: 58rpx;
  top: calc(env(safe-area-inset-top) + 54rpx);
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.member-back {
  position: absolute;
  left: -130rpx;
  top: 50%;
  transform: translateY(-45%);
  width: 128rpx;
  height: 128rpx;
  margin: 0;
  padding: 0;
  border: none;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: normal;
  z-index: 3;
}

.member-back-hit {
  position: absolute;
  left: -20rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 150rpx;
  height: 128rpx;
  z-index: 4;
}

.member-back::after {
  border: none;
}

.member-back-icon {
  font-size: 98rpx;
  line-height: 98rpx;
  font-weight: 200;
  color: rgba(17, 24, 39, 0.78);
}

.member-title {
  position: absolute;
  left: 0;
  right: 0;
  top: calc(50% + 10rpx);
  transform: translateY(-50%);
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
  pointer-events: none;
  z-index: 2;
}

.member-topbar-spacer {
  display: none;
}

.member-main-tabs {
  margin-top: 50rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.member-main-tab {
  font-size: 34rpx;
  font-weight: 400;
  color: rgba(17, 24, 39, 0.58);
  line-height: 48rpx;
}

.member-main-tab.is-active {
  color: #111827;
  font-weight: 800;
}

.member-content {
  min-height: 720rpx;
  margin-top: 38rpx;
}

.feature-tabs-scroll {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 28rpx;
}

.feature-tabs-track {
  display: inline-flex;
  align-items: center;
  gap: 52rpx;
  min-width: 100%;
  padding: 0 0 6rpx;
}

.feature-tab {
  flex: 0 0 auto;
  font-size: 30rpx;
  line-height: 46rpx;
  font-weight: 400;
  color: rgba(17, 24, 39, 0.58);
}

.feature-tab.is-active {
  color: #111827;
  font-weight: 800;
}

.privilege-card {
  position: relative;
  width: 100%;
  height: 940rpx;
  margin-left: 0;
  overflow: visible;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
}

.privilege-card-media {
  position: absolute;
  inset: 0;
  overflow: hidden;
  border-radius: 34rpx;
  background: transparent;
}

.privilege-card-bg,
.privilege-card-fallback {
  position: absolute;
  inset: 0;
}

.privilege-card-bg {
  width: 100%;
  height: 100%;
  display: block;
  transform: scale(1.02);
}

.privilege-card-fallback {
  background: linear-gradient(150deg, #dbeafe 0%, #fff7ed 52%, #f8fafc 100%);
}

.dress-tabs {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin: 4rpx 0 72rpx;
}

.dress-tab {
  font-size: 30rpx;
  color: rgba(17, 24, 39, 0.72);
  line-height: 46rpx;
}

.dress-tab.is-active {
  font-weight: 800;
  color: #111827;
}

.avatar-pendant-panel {
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

.avatar-card {
  position: relative;
  height: 154rpx;
  border: 1rpx solid rgba(17, 24, 39, 0.18);
  box-sizing: border-box;
  padding: 18rpx 32rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  background: rgba(255, 255, 255, 0.72);
}

.avatar-card-label {
  position: absolute;
  left: 16rpx;
  top: 16rpx;
  font-size: 26rpx;
  color: rgba(17, 24, 39, 0.54);
}

.avatar-preview-row {
  display: flex;
  align-items: center;
  gap: 46rpx;
  margin-left: 74rpx;
}

.avatar-card--vip .avatar-preview-row {
  gap: 40rpx;
}

.avatar-preview {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: block;
  background: #e5e7eb;
}

.avatar-preview--normal {
  margin-top: 24rpx;
}

.avatar-name {
  max-width: 360rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 32rpx;
  font-weight: 800;
}

.avatar-name--normal {
  color: #000000;
  margin-top: 24rpx;
}

.avatar-name--vip {
  color: #f59e0b;
}

.avatar-vip-frame {
  width: 78rpx;
  height: 78rpx;
  border-radius: 50%;
  border: 5rpx solid #f59e0b;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 14rpx rgba(245, 158, 11, 0.2);
}

.avatar-preview--vip {
  width: 66rpx;
  height: 66rpx;
}

.vip-corner {
  height: 24rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: #f59e0b;
  color: #ffffff;
  font-size: 18rpx;
  line-height: 24rpx;
  font-weight: 800;
  font-style: italic;
}

.vip-pill-image {
  position: absolute;
  left: -20rpx;
  top: -10rpx;
  width: 116rpx;
  height: 68rpx;
  z-index: 2;
}

.location-panel {
  padding: 36rpx 0 0;
}

.location-guide-text {
  display: block;
  margin: -18rpx 0 22rpx;
  font-size: 22rpx;
  line-height: 32rpx;
  color: rgba(17, 24, 39, 0.48);
}

.location-section + .location-section {
  margin-top: 86rpx;
}

.location-title {
  display: block;
  margin-bottom: 16rpx;
  font-size: 30rpx;
  font-weight: 800;
  color: #111827;
}

.location-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 22rpx 26rpx;
}

.location-grid--top {
  flex-wrap: nowrap;
}

.icon-card {
  position: relative;
  width: 166rpx;
  height: 96rpx;
  border: 1rpx solid rgba(17, 24, 39, 0.42);
  box-sizing: border-box;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
}

.icon-card--default {
  border: none;
  background: #f0f0f0;
}

.icon-card--shadow {
  border: none;
  box-shadow: 0 16rpx 24rpx rgba(0, 0, 0, 0.24);
}

.vip-corner {
  position: absolute;
  right: 8rpx;
  top: 6rpx;
}

.vip-corner-image {
  position: absolute;
  right: 8rpx;
  top: -2rpx;
  width: 66rpx;
  height: 40rpx;
  z-index: 3;
}

.icon-card-text {
  margin-left: 6rpx;
  font-size: 27rpx;
  line-height: 34rpx;
  font-weight: 700;
  color: #111827;
  white-space: nowrap;
}

.default-position-icon {
  width: 52rpx;
  height: 52rpx;
  display: block;
}

.location-highlight-icon {
  width: 54rpx;
  height: 54rpx;
  display: block;
}

.avatar-location-pin {
  position: relative;
  width: 58rpx;
  height: 58rpx;
  flex: 0 0 auto;
}

.avatar-location-photo {
  position: absolute;
  left: 50%;
  top: 55%;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  transform: translate(-50%, -50%);
  z-index: 1;
}

.avatar-location-frame {
  position: absolute;
  left: 0;
  top: 0;
  width: 58rpx;
  height: 58rpx;
  z-index: 2;
}

.center-position-icon {
  width: 44rpx;
  height: 44rpx;
  display: block;
  filter: brightness(0) saturate(100%);
}

.center-asset {
  width: 56rpx;
  height: 66rpx;
  margin-right: -8rpx;
  display: block;
}

.center-asset--bamboo {
  width: 62rpx;
  height: 46rpx;
  margin-right: -18rpx;
}

.voice-panel {
  min-height: 500rpx;
  padding: 48rpx 0 0;
}

.voice-panel-toolbar {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  margin: -22rpx 0 28rpx;
}

.voice-clear-btn {
  height: 52rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #111827;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 52rpx;
}

.voice-clear-btn.is-disabled {
  opacity: 0.42;
}

.voice-state {
  padding: 80rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: rgba(17, 24, 39, 0.56);
}

.voice-state--error {
  color: #ef4444;
}

.voice-pack-card + .voice-pack-card {
  margin-top: 34rpx;
}

.voice-pack-head {
  display: flex;
  align-items: center;
  gap: 9rpx;
  margin: 0 0 28rpx 12rpx;
}

.voice-pack-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #111827;
}

.voice-pack-vip {
  width: 82rpx;
  height: 48rpx;
  transform: translate(-18rpx, -12rpx);
}

.voice-pack-body {
  min-height: 164rpx;
  padding: 20rpx 14rpx 0;
  border-radius: 18rpx;
  background: #f5f5f7;
  box-sizing: border-box;
}

.voice-pack-tip {
  display: block;
  margin-bottom: 10rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #111827;
}

.voice-file-row {
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid rgba(17, 24, 39, 0.06);
}

.voice-file-name {
  min-width: 0;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 24rpx;
  color: #111827;
}

.voice-play-btn {
  width: 36rpx;
  height: 36rpx;
  margin: 0;
  padding: 0;
  border-radius: 50%;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
}

.voice-play-icon {
  width: 36rpx;
  height: 36rpx;
  display: block;
}

.voice-use-btn {
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 800;
  color: #111827;
}

.voice-use-btn.is-active {
  color: #111827;
}

.benefit-panel {
  min-height: 780rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transform: translateY(-20rpx);
}

.benefit-empty-image {
  width: 230rpx;
  height: 230rpx;
  opacity: 0.92;
}

.benefit-empty-title {
  margin-top: 20rpx;
  font-size: 30rpx;
  color: #a7b8f4;
}

.benefit-empty-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(135, 151, 214, 0.72);
}

.member-action-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(env(safe-area-inset-bottom) + 42rpx);
  display: flex;
  justify-content: center;
  pointer-events: none;
}

button.member-action {
  width: 560rpx;
  min-width: 480rpx;
  max-width: 560rpx;
  height: 84rpx;
  margin: 0;
  padding: 0;
  border: none;
  border-radius: 999rpx;
  background: #000000;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  line-height: normal;
  pointer-events: auto;
  box-sizing: border-box;
}

button.member-action::after {
  border: none;
}

.member-action-status {
  width: 44%;
  flex: 0 0 44%;
  text-align: center;
  font-size: 24rpx;
  font-weight: 400;
  color: #8da0ad;
  white-space: nowrap;
}

.member-action-text {
  width: 56%;
  flex: 0 0 56%;
  text-align: center;
  font-size: 30rpx;
  font-weight: 800;
  color: #ffffff;
  white-space: nowrap;
}

.member-loading-mask {
  position: fixed;
  inset: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #86b5ff 0%, #b5d1ff 40%, #eef4ff 100%);
}

.member-loading-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.member-loading-image {
  width: 240rpx;
  height: 240rpx;
}

.member-loading-text {
  font-size: 26rpx;
  color: rgba(26, 43, 74, 0.68);
}
