.guide-page {
  min-height: 100vh;
  background: #f7f8fa;
  padding: 32rpx 36rpx 60rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
}

.guide-title {
  margin-top: 20rpx;
  margin-bottom: 36rpx;
  font-size: 52rpx;
  font-weight: 600;
  color: #222;
  text-align: center;
}

.guide-media {
  width: 100%;
  max-width: 620rpx;
  height: 680rpx;
  background: transparent;
  border-radius: 0;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  box-shadow: none;
}

.guide-loading,
.guide-error,
.guide-placeholder {
  font-size: 28rpx;
  color: #666;
  text-align: center;
}

.guide-loading-image {
  width: 200rpx;
  height: 200rpx;
}

.guide-error {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.guide-retry {
  margin-top: 16rpx;
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  border: 2rpx solid #111;
  font-size: 24rpx;
  color: #111;
}

.guide-swiper {
  width: 100%;
  height: 100%;
}

.guide-slide {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
}

.guide-image {
  width: 72%;
  height: 72%;
}

.guide-indicator {
  margin-top: 24rpx;
  margin-bottom: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.guide-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: #d3d3d3;
  margin: 0 6rpx;
}

.guide-dot.is-active {
  width: 48rpx;
  height: 14rpx;
  background: #111111;
}

.guide-start-btn {
  width: 320rpx;
  height: 73rpx;
  margin-top: 10rpx;
  border-radius: 999rpx;
  background: #111111;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 600;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 18rpx 36rpx rgba(0, 0, 0, 0.18);
}

.guide-start-btn::after {
  border: none;
}

.guide-start-btn[disabled],
.guide-start-btn.is-disabled,
.guide-start-btn.is-muted {
  opacity: 1;
  background: #5f5f5f;
  color: #eeeeee;
  box-shadow: none;
  border: none;
}


.guide-agree-row {
  margin-top: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  font-size: 24rpx;
  color: #444;
}

.guide-checkbox {
  width: 28rpx;
  height: 28rpx;
  border-radius: 6rpx;
  border: 2rpx solid #c7c7c7;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 4rpx;
  box-sizing: border-box;
  background: #fff;
}

.guide-agree-text,
.guide-link {
  margin: 0 4rpx;
}

.guide-checkbox.is-checked {
  border-color: #111111;
  background: #111111;
}

.guide-checkmark {
  color: #fff;
  font-size: 20rpx;
}

.guide-link {
  color: #111111;
  text-decoration: underline;
  font-weight: 600;
}
