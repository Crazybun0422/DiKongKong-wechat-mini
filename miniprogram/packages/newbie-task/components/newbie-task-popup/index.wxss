.newbie-task-overlay {
  position: fixed;
  inset: 0;
  z-index: 260;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
  opacity: 0;
  animation: newbie-popup-fade 240ms ease-out forwards;
}

.newbie-task-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.55);
}

.newbie-task-card {
  position: relative;
  width: 620rpx;
  max-width: 90vw;
  z-index: 1;
  transform: translateY(16rpx) scale(0.98);
  opacity: 0;
  animation: newbie-popup-rise 320ms ease-out forwards;
}

.newbie-task-header {
  position: absolute;
  left: 86rpx;
  top: 120rpx;
  pointer-events: none;
  font-family: "ZhSubset", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, "PingFang SC", "Heiti SC", "Microsoft YaHei", sans-serif;
  max-width: 360rpx;
}

.newbie-task-title {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 30rpx;
  position: relative;
  left: -5rpx;
  top: 50rpx;
}



.newbie-task-title-text {
  position: relative;
  left: -30rpx;
  top: 50rpx;
  font-size: 36rpx;
  font-weight: 600;
  color: #000000;
  line-height: 1.1;
}

.newbie-task-title-only {
  font-size: 36rpx;
  font-weight: 500;
  color: #000000;
  line-height: 1.1;
}

.newbie-task-subtitle {
  font-size: 27rpx;
  font-weight: 500;
  color: #000000;
  line-height: 1.2;
}

.newbie-task-header-badge {
  position: absolute;
  right: -30rpx;
  top: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 30rpx;
  opacity: 0;
  animation: newbie-badge-fade 360ms ease-out forwards;
  animation-delay: 80ms;
}

@keyframes newbie-popup-fade {
  0% { opacity: 0; }
  100% { opacity: 1; }
}

@keyframes newbie-popup-rise {
  0% { opacity: 0; transform: translateY(16rpx) scale(0.98); }
  100% { opacity: 1; transform: translateY(0) scale(1); }
}

@keyframes newbie-badge-fade {
  0% { opacity: 0; transform: scale(0.96); }
  100% { opacity: 1; transform: scale(1); }
}
.newbie-task-header-icon {
  display: block;
  position: relative;
  z-index: 1;
  pointer-events: none;
  width: 253rpx;
  height: 255rpx;
}
.newbie-task-qr-wrap {
  position: relative;
  z-index: 2;
  right: 76rpx;
  top: -168rpx;
  width: 120rpx;
  height: 120rpx;
}

.newbie-task-qr {
  display: block;
  position: relative;
  z-index: 1;
  width: 100%;
  height: 100%;
  padding: 0;
  box-sizing: border-box;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
}

.newbie-task-qr-scan {
  position: absolute;
  inset: 0;
  z-index: 2;
  overflow: hidden;
  pointer-events: none;
}

.newbie-task-qr-scan-line {
  position: absolute;
  left: 0;
  right: 0;
  height: 12rpx;
  pointer-events: none;
  background: linear-gradient(180deg, rgba(0, 255, 255, 0), rgba(0, 255, 255, 0.7), rgba(0, 255, 255, 0));
  box-shadow: 0 0 12rpx rgba(0, 255, 255, 0.6);
  animation: newbie-qr-scan 1.2s linear infinite;
}

@keyframes newbie-qr-scan {
  0% {
    transform: translateY(-20%);
  }
  100% {
    transform: translateY(120rpx);
  }
}

.newbie-task-bg {
  width: 100%;
  height: auto;
  display: block;
}

.newbie-task-list-wrap {
  position: absolute;
  left: 72rpx;
  right: 72rpx;
  top: 300rpx;
  bottom: 260rpx;
  transform: translateY(20rpx);
  font-family: "ZhSubset", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, "PingFang SC", "Heiti SC", "Microsoft YaHei", sans-serif;
  color: #000000;
  box-sizing: border-box;
  overflow: hidden;
}

.newbie-task-list {
  height: 100%;
  display: flex;
  flex-direction: column;
  gap: 26rpx;
}

.newbie-task-scroll-hint {
  position: absolute;
  left: 50%;
  bottom: -14rpx;
  width: 0;
  height: 0;
  transform: translateX(-50%);
  border-left: 14rpx solid transparent;
  border-right: 14rpx solid transparent;
  border-top: 18rpx solid #111111;
  opacity: 0.7;
}

.newbie-task-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 15rpx 0;
}

.newbie-task-item-text {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
  flex: 1;
  transform: translateX(10rpx);
}

.newbie-task-item-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #000000;
  line-height: 1.2;
}

.newbie-task-item-desc {
  font-size: 20rpx;
  font-weight: 500;
  color: #6b6b6b;
  line-height: 1.2;
}

.newbie-task-item-action {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  transform: translateX(-5rpx);
}

.newbie-task-item-btn,
.newbie-task-item-done {
  width: 140rpx;
  height: 56rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  border: 2rpx solid #5a5a5a;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #000000;
  background: #ffffff;
  box-sizing: border-box;
}

.newbie-task-item-done {
  padding: 0;
  background: #ffffff;
  border-color: #7a7a7a;
}

.newbie-task-item-done-box {
  width: 32rpx;
  height: 32rpx;
  border-radius: 6rpx;
  background: #000000;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.newbie-task-footer {
  position: absolute;
  left: 72rpx;
  right: 72rpx;
  bottom: 180rpx;
  transform: translateY(20rpx);
  display: flex;
  align-items: center;
  justify-content: center;
}

.newbie-task-claim-btn {
  width: calc(100% - 100rpx);
  height: 71rpx;
  border-radius: 999rpx;
  background: #000000;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  font-family: "ZhSubset", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, "PingFang SC", "Heiti SC", "Microsoft YaHei", sans-serif;
  display: flex;
  align-items: center;
  justify-content: center;
}

.newbie-task-claim-btn.is-disabled {
  background: #e6e6e6;
  color: #8a8a8a;
  pointer-events: none;
}

.newbie-task-close {
  position: absolute;
  right: 4rpx;
  top: -40rpx;
  width: 76rpx;
  height: 76rpx;
  z-index: 2;
}

.newbie-task-close-canvas {
  width: 76rpx;
  height: 76rpx;
  display: block;
}

.newbie-task-close-icon {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 44rpx;
  height: 44rpx;
  transform: translate(-50%, -50%);
}

.newbie-reward-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.newbie-reward-container {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.newbie-reward-hero {
  position: absolute;
  top: -120rpx;
  left: 50%;
  width: 220rpx;
  height: auto;
  transform: translateX(-50%);
  z-index: 3;
}

.newbie-reward-card {
  width: 320rpx;
  padding: 76rpx 48rpx 60rpx;
  border-radius: 36rpx;
  background: linear-gradient(180deg, #86b5ff 0%, #b5d1ff 30%, #eef4ff 60%, #f5f5f7 100%);
  box-shadow: 0 24rpx 60rpx rgba(0, 0, 0, 0.18);
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  text-align: center;
  font-family: "ZhSubset", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial,
    "PingFang SC", "Heiti SC", "Microsoft YaHei", sans-serif;
}

.newbie-reward-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #111111;
}

.newbie-reward-sub {
  font-size: 28rpx;
  color: #333333;
  opacity: 0.95;
}

.newbie-reward-btn {
  margin-top: 24rpx;
  width: 100%;
  height: 72rpx;
  border-radius: 999rpx;
  background: #1c1c1c;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}
