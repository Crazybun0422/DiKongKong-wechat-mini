<block wx:if="{{visible}}">
  <view class="newbie-task-overlay" catchtouchmove="noop" bindtap="onPopupHoldTap">
    <view class="newbie-task-mask"></view>
    <view class="newbie-task-card" catchtap="onPopupHoldTap">
      <image class="newbie-task-bg" src="/assets/newbie-task-svg.svg" mode="widthFix" />
      <view class="newbie-task-header">
        <view class="newbie-task-title">
          <block wx:if="{{showCountdownTitle}}">
            <text class="newbie-task-title-number">{{remainingSeconds}}</text>
            <text class="newbie-task-title-text">秒领新人大礼包</text>
          </block>
          <text class="newbie-task-title-only" wx:else>领取新人大礼包</text>
        </view>
      </view>
      <image class="newbie-task-header-icon" src="/assets/task.png" mode="aspectFit" />
      <view class="newbie-task-list-wrap" wx:if="{{tasks.length}}">
        <scroll-view scroll-y class="newbie-task-list" bindscroll="onTaskListScroll">
          <block wx:for="{{tasks}}" wx:key="index">
            <view class="newbie-task-item">
              <view class="newbie-task-item-text">
                <text class="newbie-task-item-name">{{item.name}}</text>
                <text class="newbie-task-item-desc" wx:if="{{item.description}}">{{item.description}}</text>
              </view>
              <view class="newbie-task-item-action">
                <view class="newbie-task-item-done" wx:if="{{item.completed}}">
                  <view class="newbie-task-item-done-box">✓</view>
                </view>
                <view
                  class="newbie-task-item-btn"
                  wx:else
                  data-index="{{item.index}}"
                  bindtap="onTaskActionTap"
                >
                  {{item.buttonText}}
                </view>
              </view>
            </view>
          </block>
        </scroll-view>
        <view class="newbie-task-scroll-hint" wx:if="{{showScrollHint}}"></view>
      </view>
      <view class="newbie-task-footer">
        <view class="newbie-task-claim-btn {{rewardAvailable ? '' : 'is-disabled'}}" bindtap="onRewardTap">立即领取</view>
      </view>
      <view class="newbie-task-close" bindtap="onCloseTap">
        <canvas type="2d" id="newbie-close-progress" class="newbie-task-close-canvas"></canvas>
        <image class="newbie-task-close-icon" src="/assets/newbie-git-close.png" mode="aspectFit" />
      </view>
    </view>
  </view>
</block>
<block wx:if="{{showRewardSuccess}}">
  <view class="newbie-reward-overlay" bindtap="onRewardSuccessClose">
    <view class="newbie-reward-card" catchtap="noop">
      <view class="newbie-reward-icon">✓</view>
      <text class="newbie-reward-title">领取成功</text>
      <text class="newbie-reward-sub">请在微信粘贴并打开</text>
    </view>
  </view>
</block>
