.city-report-h5-entry {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  pointer-events: auto;
}

.city-report-h5-jump {
  background: rgba(0, 0, 0, 0.86);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 999rpx;
  width: 240rpx;
  padding: 16rpx 0rpx;
  line-height: 1;
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.28);
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  box-sizing: border-box;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
}

.city-report-h5-jump--hover {
  opacity: 0.9;
}

.city-report-h5-tip {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: none;
  padding: 0;
  min-width: 0;
  min-height: 0;
  line-height: 0;
  font-size: 0;
  box-sizing: border-box;
}

.city-report-h5-tip--hover {
  opacity: 0.9;
}

.city-report-h5-tip-icon {
  width: 60rpx;
  height: 60rpx;
}