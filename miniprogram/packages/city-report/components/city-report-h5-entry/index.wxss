.city-report-h5-entry {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  pointer-events: auto;
}

.city-report-h5-jump {
  background: rgba(0, 0, 0, 0.86);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 999rpx;
  width: 240rpx;
  padding: 16rpx 0rpx;
  line-height: 1;
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.28);
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  box-sizing: border-box;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
}

.city-report-h5-jump--hover {
  opacity: 0.9;
}

.city-report-h5-tip {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: none;
  padding: 0;
  min-width: 0;
  min-height: 0;
  line-height: 0;
  font-size: 0;
  box-sizing: border-box;
}

.city-report-h5-tip--hover {
  opacity: 0.9;
}

.city-report-h5-tip-icon {
  width: 60rpx;
  height: 60rpx;
}

.city-report-dialog-overlay {
  position: fixed;
  inset: 0;
  z-index: 10000;
  background: rgba(0, 0, 0, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.city-report-dialog-container {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.city-report-dialog-card {
  width: 320rpx;
  padding: 76rpx 48rpx 60rpx;
  border-radius: 36rpx;
  background: linear-gradient(180deg, #86b5ff 0%, #b5d1ff 30%, #eef4ff 60%, #f5f5f7 100%);
  box-shadow: 0 24rpx 60rpx rgba(0, 0, 0, 0.18);
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  text-align: center;
}

.city-report-dialog-text {
  font-size: 28rpx;
  color: #333333;
  opacity: 0.95;
  line-height: 1.6;
}

.city-report-dialog-btn {
  margin-top: 24rpx;
  width: 100%;
  height: 72rpx;
  border-radius: 999rpx;
  background: #1c1c1c;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "ZhSubset", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial,
    "PingFang SC", "Heiti SC", "Microsoft YaHei", sans-serif;
  padding: 0;
  border: none;
  box-sizing: border-box;
}

.city-report-dialog-btn::after {
  border: none;
}
