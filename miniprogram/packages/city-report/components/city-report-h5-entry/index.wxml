<cover-view class="city-report-h5-entry" wx:if="{{visible}}">
  <cover-view
    class="city-report-h5-jump"
    style="width: {{jumpWidth}}rpx;"
    hover-class="city-report-h5-jump--hover"
    catchtap="onJumpTap"
  >
    {{jumpLabel}}
  </cover-view>
  <cover-view
    class="city-report-h5-tip"
    hover-class="city-report-h5-tip--hover"
    catchtap="onTipTap"
    wx:if="{{showGuide}}"
  >
    <cover-image class="city-report-h5-tip-icon" src="/assets/tips-b.png" />
  </cover-view>
</cover-view>
