<view class="page">
  <view class="panorama-stage">
    <canvas
      id="panorama-canvas"
      class="panorama-canvas"
      type="webgl"
      disable-scroll="true"
      bindtouchstart="onTouchStart"
      bindtouchmove="onTouchMove"
      bindtouchend="onTouchEnd"
      bindtouchcancel="onTouchEnd"
    ></canvas>
    <view class="panorama-hint" wx:if="{{showHint}}">
      <text class="panorama-hint-text">拖动查看</text>
    </view>
    <view class="panorama-toolbar">
      <button class="panorama-mode-btn" bindtap="onModeToggle">
        {{viewMode === 'planet' ? '360视图' : '俯瞰'}}
      </button>
    </view>
  </view>
</view>
