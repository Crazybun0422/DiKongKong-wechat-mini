.pin-picker-page {
  height: 100vh;
  background: #f5f5f7;
  display: flex;
  flex-direction: column;
}

.picker-map-wrap {
  position: relative;
  flex: 1;
  height: 100%;
  min-height: 0;
}

.picker-map {
  width: 100%;
  height: 100%;
}

.center-pin {
  position: absolute;
  width: 64rpx;
  height: 64rpx;
  left: 50%;
  top: 42%;
  transform: translate(-50%, -50%);
  z-index: 10;
  pointer-events: none;
}

.type-pill {
  margin: 16rpx 0 0;
  padding: 16rpx 20rpx;
  background: #ffffff;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 12rpx;
  box-shadow: 0 8rpx 18rpx rgba(0, 0, 0, 0.08);
  z-index: 5;
  width: 72%;
  max-width: 600rpx;
}

.type-pill-left {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
}

.type-pill-icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}

.type-pill-label {
  font-size: 30rpx;
  color: #111827;
  font-weight: 600;
}

.type-pill-arrow {
  font-size: 30rpx;
  color: #6b7280;
}

.type-pill-arrow-img {
  width: 28rpx;
  height: 28rpx;
  margin-left: auto;
  opacity: 0.8;
}

.picker-search-panel {
  position: absolute;
  top: 36rpx;
  left: 0;
  right: 0;
  padding: 0 28rpx;
  box-sizing: border-box;
  z-index: 6;
}


.search-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.search-stack {
  flex: 1;
  position: relative;
}

.search-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 999rpx;
  padding: 16rpx 20rpx;
  box-shadow: 0 10rpx 26rpx rgba(0, 0, 0, 0.12);
  border: 2rpx solid transparent;
}

.search-box.is-active {
  border-color: rgba(0, 0, 0, 0.4);
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.65;
}

.search-input {
  flex: 1;
  border: none;
  background: transparent;
  font-size: 28rpx;
}

.search-clear {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.06);
  font-size: 32rpx;
  color: #6b7280;
}

.search-suggest-card {
  position: absolute;
  top: 94rpx;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 22rpx;
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.16);
  max-height: 360rpx;
  overflow: hidden;
}

.search-suggest-loading,
.search-suggest-empty {
  padding: 26rpx 28rpx;
  font-size: 26rpx;
  color: #6b7280;
}

.search-suggest-scroll {
  max-height: 360rpx;
}

.search-suggest-item {
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.search-suggest-item:last-child {
  border-bottom: none;
}

.suggest-title {
  font-size: 28rpx;
  color: #111827;
  font-weight: 600;
}

.suggest-address {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.locate-circle {
  flex: 0 0 92rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(148, 163, 184, 0.18);
  box-shadow: 0 20rpx 40rpx rgba(15, 23, 42, 0.16);
  padding: 0;
  margin: 0;
  pointer-events: auto;
  transition: transform 0.18s ease, box-shadow 0.18s ease, background-color 0.18s ease;
}

.locate-circle::after {
  border: none;
}

.locate-icon {
  width: 46rpx;
  height: 46rpx;
  display: block;
}

.actions {
  padding: 24rpx 28rpx 40rpx;
  background: #f5f5f7;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.error-text {
  color: #ef4444;
  font-size: 26rpx;
}

.confirm-btn {
  background: linear-gradient(90deg, #000000, #2f2f2f);
  color: #fff;
  border-radius: 16rpx;
  height: 96rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.confirm-btn::after {
  border: none;
}

.type-sheet-overlay {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.35);
  display: flex;
  align-items: flex-end;
  z-index: 40;
}

.type-sheet {
  width: 100%;
  background: #f2f3f5;
  border-top-left-radius: 28rpx;
  border-top-right-radius: 28rpx;
  padding: 28rpx 32rpx 42rpx;
  box-shadow: 0 -10rpx 30rpx rgba(0, 0, 0, 0.12);
  max-height: 70vh;
  overflow-y: hidden;
  position: relative;
  top: 0;
  z-index: 200;
}

.type-sheet-body {
  display: grid;
  grid-template-columns: 190rpx 1fr;
  column-gap: 0;
  height: 100%;
  padding-top: 5rpx;
  box-sizing: border-box;
}

.type-sheet-categories {
  background: #f2f3f5;
  border-radius: 18rpx;
  padding: 10rpx 0;
  display: flex;
  margin-top: 20rpx;
  flex-direction: column;
  gap: 6rpx;
}

.type-category {
  padding: 20rpx 16rpx;
  font-size: 28rpx;
  color: #4b5563;
  border-radius: 14rpx;
}

.type-category.is-active {
  background: #ffffff;
  color: #111827;
  font-weight: 700;
  box-shadow: none;
  border-top-right-radius: 0;
  border-bottom-right-radius: 0;
}

.type-category-label {
  display: block;
}

.type-sheet-options {
  background: #fff;
  border-radius: 20rpx;
  padding: 8rpx 8rpx 12rpx;
  box-shadow: none;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.type-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 18rpx;
  padding: 18rpx 16rpx 18rpx 14rpx;
  box-shadow: none;
}

.type-option-icon {
  width: 52rpx;
  height: 52rpx;
  margin-right: 16rpx;
}

.type-option-label {
  flex: 1;
  font-size: 28rpx;
  color: #111827;
}

.type-option-check {
  font-size: 32rpx;
  color: #1d4ed8;
  padding: 0 6rpx;
}
