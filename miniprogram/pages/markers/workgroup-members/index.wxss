.member-page {
  min-height: 100vh;
  background: #f7f8fa;
  display: flex;
  flex-direction: column;
}

.member-header {
  padding: 32rpx 28rpx 12rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.member-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
}

.member-subtitle {
  font-size: 24rpx;
  color: #6b7280;
}

.member-scroll {
  flex: 1;
}

.member-list {
  padding: 8rpx 16rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.member-row {
  display: flex;
  align-items: center;
  padding: 16rpx 12rpx;
  border-radius: 16rpx;
  background: #fff;
  gap: 14rpx;
  box-shadow: 0 6rpx 18rpx rgba(15, 23, 42, 0.05);
}

.member-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #e5e7eb;
  flex-shrink: 0;
}

.member-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.member-name {
  font-size: 30rpx;
  color: #0f172a;
  font-weight: 600;
}

.member-tags {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.member-code {
  font-size: 24rpx;
  color: #6b7280;
}

.member-owner {
  padding: 4rpx 10rpx;
  background: linear-gradient(135deg, #111, #333);
  color: #fff;
  font-size: 22rpx;
  border-radius: 12rpx;
}

.member-remove {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #eef1f5;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #2563eb;
  font-size: 40rpx;
  font-weight: 500;
}
