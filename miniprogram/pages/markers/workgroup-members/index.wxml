<view class="member-page">
  <view class="member-header">
    <view class="member-title">{{groupName || '小组成员'}}</view>
    <view class="member-subtitle">{{members.length}} 人</view>
  </view>

  <scroll-view scroll-y class="member-scroll">
    <block wx:if="{{loading}}">
      <view class="state-card">加载中...</view>
    </block>
    <block wx:elif="{{!members.length}}">
      <view class="state-card">暂无成员</view>
    </block>
    <block wx:else>
      <view class="member-list">
        <block wx:for="{{members}}" wx:key="featureCode">
          <view class="member-row">
            <image class="member-avatar" src="{{item.avatarUrl}}" mode="aspectFill" />
            <view class="member-info">
              <text class="member-name">{{item.nickname || item.featureCode}}</text>
              <view class="member-tags">
                <text class="member-code">{{item.featureCode}}</text>
                <text wx:if="{{item.isOwner}}" class="member-owner">管理员</text>
              </view>
            </view>
            <view
              wx:if="{{isOwner && !item.isOwner}}"
              class="member-remove"
              data-code="{{item.featureCode}}"
              bindtap="onRemoveTap"
            >
              <text>-</text>
            </view>
          </view>
        </block>
      </view>
    </block>
  </scroll-view>
</view>
