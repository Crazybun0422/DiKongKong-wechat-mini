.modal-overlay {
  position: fixed;
  inset: 0;
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
}

.modal-card {
  position: relative;
  width: 86vw;
  max-width: 720rpx;
  background: #fff;
  border-radius: 28rpx;
  padding: 28rpx;
  box-shadow: 0 18rpx 36rpx rgba(0, 0, 0, 0.12);
  z-index: 1;
  transform: translateY(12rpx);
}
.modal-card.share{
  height: 80vh;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
  margin-left: 220rpx;
}

.modal-title-share {
  display: block;
  width: 100%;
  font-size: 40rpx;
  font-weight: 700;
  color: #0f172a;
  margin: 0;
  text-align: center;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f1f2f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #4b5563;
  
}

.modal-close.share{
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  transform: none;
}

.modal-close.modal-close-disabled {
  pointer-events: none;
  opacity: 0.4;
}

.modal-body {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  max-height: 70vh;
  overflow: auto;
}
.modal-body.share{
  margin-top: 0;
}
.modal-block {
  padding: 18rpx;
  border-radius: 18rpx;
  background: #f8f9fb;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.modal-block-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
}

.modal-input-row {
  display: flex;
  gap: 12rpx;
  align-items: center;
  margin-top: 8rpx;
}

.modal-input {
  flex: 1;
  height: 72rpx;
  padding: 0 18rpx;
  border-radius: 16rpx;
  background: #fff;
  border: 1px solid #e5e7eb;
  font-size: 26rpx;
}

.modal-btn {
  min-width: 120rpx;
  height: 64rpx;
  border-radius: 16rpx;
  border: none;
  background: #eef0f5;
  color: #111827;
  font-size: 26rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 18rpx;
}

.modal-btn.primary {
  background: linear-gradient(135deg, #111, #333);
  color: #fff;
}

.modal-footer {
  margin-top: 12rpx;
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

.modal-footer.share{
  margin-top: 30vh;
}

.publish-platform-card {
  min-height: 860rpx;
  padding: 36rpx 28rpx 180rpx;
  box-sizing: border-box;
}

.publish-platform-body {
  gap: 20rpx;
  margin-top: 24rpx;
  max-height: 540rpx;
}

.publish-platform-banner {
  width: 148rpx;
  margin: 0 auto 16rpx;
  display: block;
}

.publish-platform-state {
  font-size: 28rpx;
  line-height: 1.6;
  color: #4b5563;
  text-align: center;
}

.publish-platform-state.is-error {
  color: #b91c1c;
}

.publish-platform-richtext {
  font-size: 28rpx;
  line-height: 1.7;
  color: #111827;
}

.publish-platform-rich-image {
  width: 100%;
  border-radius: 18rpx;
  display: block;
}
.publish-platform-actions {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 0 28rpx;
  box-sizing: border-box;
}

.publish-platform-btn {
  width: 100%;
  height: 84rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.publish-platform-btn.primary {
  background: #111;
  color: #fff;
}

.publish-platform-btn.secondary {
  background: #f4f4f5;
  color: #111827;
}

.kml-tips-dialog-overlay {
  position: fixed;
  inset: 0;
  z-index: 10000;
  background: rgba(0, 0, 0, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.kml-tips-dialog-container {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.kml-tips-dialog-card {
  width: 520rpx;
  padding: 76rpx 48rpx 60rpx;
  border-radius: 36rpx;
  background: linear-gradient(180deg, #86b5ff 0%, #b5d1ff 30%, #eef4ff 60%, #f5f5f7 100%);
  box-shadow: 0 24rpx 60rpx rgba(0, 0, 0, 0.18);
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  text-align: center;
}

.kml-tips-dialog-text {
  display: block;
  width: 100%;
  text-align: left;
  font-size: 28rpx;
  color: #111111;
  opacity: 0.95;
  line-height: 1.6;
}

.kml-tips-dialog-text-highlight {
  color: #c28a00;
}

.kml-tips-dialog-btn {
  margin-top: 24rpx;
  width: 100%;
  height: 72rpx;
  border-radius: 999rpx;
  background: #1c1c1c;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "ZhSubset", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial,
    "PingFang SC", "Heiti SC", "Microsoft YaHei", sans-serif;
  padding: 0;
  border: none;
  box-sizing: border-box;
}

.kml-tips-dialog-btn::after {
  border: none;
}

.reject-reason-dialog-overlay {
  position: fixed;
  inset: 0;
  z-index: 10000;
  background: rgba(10, 10, 12, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}

.reject-reason-dialog-container {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.reject-reason-dialog-card {
  width: 560rpx;
  padding: 54rpx 42rpx 42rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #86b5ff 0%, #b5d1ff 30%, #eef4ff 60%, #f5f5f7 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.34);
  box-shadow: 0 24rpx 60rpx rgba(0, 0, 0, 0.18);
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 22rpx;
}

.reject-reason-dialog-title {
  font-size: 32rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #111111;
  text-align: left;
}

.reject-reason-dialog-text {
  font-size: 28rpx;
  line-height: 1.7;
  color: #2a2f36;
  white-space: pre-wrap;
  word-break: break-word;
  text-align: left;
}

.reject-reason-dialog-note {
  display: block;
  width: 100%;
  font-size: 22rpx;
  line-height: 1.6;
  color: #6b7280;
  font-style: italic;
  text-align: left;
}

.reject-reason-dialog-btn {
  margin-top: 10rpx;
  width: 260rpx !important;
  height: 72rpx;
  border-radius: 999rpx;
  background: #1c1c1c;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  font-family: "ZhSubset", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial,
    "PingFang SC", "Heiti SC", "Microsoft YaHei", sans-serif;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  border: none;
  box-sizing: border-box;
  align-self: center;
}

.reject-reason-dialog-btn::after {
  border: none;
}

.pin-create-sheet-overlay {
  position: fixed;
  inset: 0;
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.pin-create-sheet-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.35);
}

.pin-create-sheet {
  position: relative;
  width: 100%;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 12rpx 24rpx 18rpx;
  box-shadow: 0 -18rpx 40rpx rgba(15, 23, 42, 0.14);
  border-top: 1rpx solid rgba(148, 163, 184, 0.2);
  box-sizing: border-box;
}

.pin-create-sheet-handle {
  width: 64rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #e5e7eb;
  margin: 2rpx auto 12rpx;
  opacity: 0.9;
}

.pin-create-sheet-item {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding: 10rpx 6rpx;
  min-height: 72rpx;
}

.pin-create-sheet-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.pin-create-sheet-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.pin-create-sheet-divider {
  height: 1px;
  background: rgba(15, 23, 42, 0.08);
  margin: 4rpx 6rpx;
}

.pin-create-sheet-tip {
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f8fafc;
  border: 1rpx solid #eef2f7;
}

.pin-create-sheet-tip-icon {
  width: 26rpx;
  height: 26rpx;
}
