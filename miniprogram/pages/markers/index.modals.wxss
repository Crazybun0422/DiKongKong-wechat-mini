.modal-overlay {
  position: fixed;
  inset: 0;
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
}

.modal-card {
  position: relative;
  width: 86vw;
  max-width: 720rpx;
  background: #fff;
  border-radius: 28rpx;
  padding: 28rpx;
  box-shadow: 0 18rpx 36rpx rgba(0, 0, 0, 0.12);
  z-index: 1;
  transform: translateY(12rpx);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f1f2f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #4b5563;
}

.modal-close.modal-close-disabled {
  pointer-events: none;
  opacity: 0.4;
}

.modal-body {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  max-height: 60vh;
  overflow: auto;
}

.modal-block {
  padding: 18rpx;
  border-radius: 18rpx;
  background: #f8f9fb;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.modal-block-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
}

.modal-input-row {
  display: flex;
  gap: 12rpx;
  align-items: center;
  margin-top: 8rpx;
}

.modal-input {
  flex: 1;
  height: 72rpx;
  padding: 0 18rpx;
  border-radius: 16rpx;
  background: #fff;
  border: 1px solid #e5e7eb;
  font-size: 26rpx;
}

.modal-btn {
  min-width: 120rpx;
  height: 64rpx;
  border-radius: 16rpx;
  border: none;
  background: #eef0f5;
  color: #111827;
  font-size: 26rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 18rpx;
}

.modal-btn.primary {
  background: linear-gradient(135deg, #111, #333);
  color: #fff;
}

.modal-footer {
  margin-top: 12rpx;
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}
