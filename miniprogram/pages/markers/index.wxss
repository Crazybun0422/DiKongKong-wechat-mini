@import "./index.modals.wxss";

.markers-page {
  height: 100vh;
  overflow: hidden;
  background: #f5f5f7;
  display: flex;
  flex-direction: column;
}

.markers-shell {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
  background: #f5f5f7;
}

.center-tabs {
  display: flex;
  gap: 12rpx;
  padding: 24rpx 32rpx 12rpx;
  background: #f5f5f7;
}

.center-tab {
  flex: 1;
  text-align: center;
  padding: 22rpx 12rpx 18rpx;
  border-radius: 0;
  background: transparent;
  color: rgba(0, 0, 0, 0.45);
  font-size: 32rpx;
  font-weight: 500;
  transition: all 0.2s ease;
  position: relative;
}

.center-tab.is-active {
  color: #0f172a;
  font-weight: 700;
}

.center-tab.is-active::after {
  content: "";
  position: absolute;
  left: 18%;
  right: 18%;
  bottom: 4rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #000, #3b3b3b);
  box-shadow: 0 6rpx 14rpx rgba(0, 0, 0, 0.12);
}

.center-placeholder {
  flex: 1;
  padding: 120rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  gap: 24rpx;
  text-align: center;
  background: #f5f5f7;
}

.center-placeholder-icon {
  width: 120rpx;
  height: 120rpx;
  display: block;
}

.center-placeholder-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1d1d1f;
}

.center-placeholder-desc {
  font-size: 26rpx;
  color: #6b7280;
}

.my-marker-filters {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
  margin-bottom: 24rpx;
  padding: 0 2rpx;
}

.my-marker-filter {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.08);
  color: rgba(0, 0, 0, 0.55);
  font-size: 26rpx;
  transition: all 0.2s ease;
}

.my-marker-filter.is-active {
  background: #000;
  color: #fff;
  font-weight: 600;
  box-shadow: 0 10rpx 26rpx rgba(0, 0, 0, 0.12);
}

.my-marker-empty-card {
  margin-top: 8rpx;
  gap: 14rpx;
}

.my-marker-empty-icon-wrapper {
  box-shadow: none;
  background: rgba(0, 0, 0, 0.03);
}

.my-marker-empty-icon {
  width: 90rpx;
  height: 90rpx;
}

.my-marker-desc-box {
  width: 100%;
  margin-top: 4rpx;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  background: rgba(0, 0, 0, 0.04);
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  box-sizing: border-box;
}

.my-marker-desc-line {
  font-size: 26rpx;
  color: #4b5563;
  line-height: 1.4;
  text-align: center;
}

.pin-field .pin-selector {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(0, 0, 0, 0.04);
  border-radius: 16rpx;
  padding: 18rpx 20rpx;
}

.pin-field .pin-selector.is-locked {
  opacity: 0.75;
}

.pin-selector-main {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
  flex: 1;
}

.pin-selector-icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 14rpx;
  background: #f1f5f9;
  flex-shrink: 0;
}

.pin-selector-placeholder {
  font-size: 26rpx;
  color: #6b7280;
  flex-shrink: 0;
}

.pin-selector-side {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.pin-selector-text {
  font-size: 28rpx;
  color: #0f172a;
  font-weight: 600;
  min-width: 0;
}

.pin-selector-arrow-img {
  width: 32rpx;
  height: 32rpx;
  margin-left: 14rpx;
  flex-shrink: 0;
  display: block;
  opacity: 0.65;
}

.pin-selector-arrow {
  font-size: 32rpx;
  color: rgba(0, 0, 0, 0.45);
}

.pin-configured-hint {
  margin-left: 8rpx;
  font-size: 24rpx;
  color: #10b981;
}

.pin-location-hint {
  margin-top: 8rpx;
  padding: 6rpx 10rpx;
  border-radius: 12rpx;
  background: rgba(0, 0, 0, 0.02);
}

.pin-location-text {
  font-size: 22rpx;
  color: #4b5563;
  line-height: 1.5;
}

.pin-video-flp-hint {
  margin-left: 10rpx;
  font-size: 22rpx;
  color: #6b7280;
  font-style: italic;
  font-weight: 400;
}

.my-pin-media-grid {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.my-pin-media {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #f1f5f9;
}

.my-pin-media-img {
  width: 100%;
  height: 100%;
  display: block;
}

.my-pin-media-video-player {
  width: 100%;
  height: 100%;
  display: block;
}

.my-pin-media-uploading {
  width: 100%;
  height: 100%;
  padding: 24rpx 18rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: linear-gradient(180deg, #111827 0%, #374151 100%);
}

.my-pin-media-uploading-title {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.4;
}

.my-pin-media-uploading-progress {
  color: rgba(255, 255, 255, 0.88);
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1;
}

.my-pin-media-progress-track {
  width: 100%;
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.22);
  overflow: hidden;
}

.my-pin-media-progress-bar {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #ffffff 0%, #d1fae5 100%);
}

.video-loading-mask {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(15, 23, 42, 0.42);
  z-index: 2;
}

.video-fullscreen-hit {
  position: absolute;
  inset: 0;
  z-index: 3;
}

.video-loading-text {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #fff;
  font-size: 22rpx;
  line-height: 1;
}

.my-pin-media-video-tag {
  position: absolute;
  left: 10rpx;
  bottom: 10rpx;
  min-width: 58rpx;
  height: 34rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.7);
  color: #fff;
  font-size: 20rpx;
  line-height: 34rpx;
  text-align: center;
  z-index: 3;
}

.my-pin-media-remove {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.65);
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 4;
}

.my-pin-media-add {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  border: 2rpx dashed rgba(0, 0, 0, 0.12);
  background: #f8fafc;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.my-pin-media-plus {
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #111827;
}

.my-pin-media-add-text {
  font-size: 26rpx;
  color: #4b5563;
}

.pin-publish-row {
  align-items: center;
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
}

.pin-publish-row .field-label {
  margin-bottom: 0;
}

.publish-toggle {
  display: flex;
  align-items: center;
}

.workgroup-selector {
  display: flex;
  align-items: center;
}

.workgroup-disabled-text {
  font-size: 26rpx;
  color: #9ca3af;
}

.markers-static {
  padding: 24rpx 32rpx 12rpx;
  box-sizing: border-box;
  background: #f5f5f7;
}

.markers-scroll {
  flex: 1;
  padding: 0 32rpx 10rpx;
  box-sizing: border-box;
  min-height: 0;
  margin-bottom: 1rpx;
  background: #f5f5f7;
}

.page-header {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  margin-bottom: 24rpx;
}

.create-guide-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.create-guide-tip-icon {
  width: 38rpx;
  height: 38rpx;
  display: block;
}

.page-header-actions {
  margin-left: auto;
  display: flex;
  align-items: center;
  gap: 4rpx;
  margin-right: 24rpx;
}

.create-btn {
  margin: 0 0 0 10rpx    !important;       
  /* align-self:flex-start;        
  position: relative;
  padding: 0;  
  flex: 0 0 96rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(90deg, #000000, #333333); */
  margin-top: 40rpx;
  background: linear-gradient(90deg, #000000, #333333);
  color: #fff;
  padding: 15rpx 22rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  display: flex;
  max-width: 100px;
  align-items: center;
}

.create-btn::after {

  border: none;
}

.create-btn-icon {
  width: 40rpx;
  height: 40rpx;
  margin-top: 10rpx;
  margin: 0 0 0 0rpx    !important;  
  /* filter: grayscale(1) brightness(0); */
}
.create-btn-text{
  font-weight: 600;
  margin-left: 10rpx;

}

.kml-import-link {
  color: #111111;
  font-size: 26rpx;
  text-decoration: underline;
  line-height: 1.2;
  margin-top: 25rpx;
}

.kml-import-link.is-loading {
  opacity: 0.6;
}

.kml-tips-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 25rpx;
}

.kml-tips-btn--link {
  margin-top: 22rpx;
}

.kml-tips-icon {
  width: 36rpx;
  height: 36rpx;
}
.status-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.status-tab {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.08);
  color: rgba(0, 0, 0, 0.6);
  font-size: 26rpx;
  transition: background 0.2s ease, color 0.2s ease;
}

.status-tab.is-active {
  background: #000000;
  color: #ffffff;
  font-weight: 600;
}

.state-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 80rpx 32rpx;
  text-align: center;
  color: #6b7280;
  font-size: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.state-card.state-error {
  color: #ef4444;
}

.retry-btn {
  margin-top: 24rpx;
  background: linear-gradient(135deg, #000000 0%, #333333 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
  padding: 0 48rpx;
  height: 72rpx;
  line-height: 1;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 24rpx rgba(15, 23, 42, 0.12);
}

.retry-btn::after {
  border: none;
}

.merchant-empty-state {
  min-height: calc(100vh - 520rpx);
  padding: 6rpx 0 150rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 28rpx;
}

.merchant-overview-card {
  background: linear-gradient(180deg, #ffffff 0%, #f4f4f6 100%);
  border-radius: 30rpx;
  padding: 34rpx 28rpx 30rpx;
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.merchant-overview-update {
  width: 100%;
  font-size: 25rpx;
  color: #7b8190;
  line-height: 1.4;
}

.merchant-overview-stats {
  width: 100%;
  margin-top: 28rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.merchant-overview-stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.merchant-overview-number {
  font-size: 58rpx;
  line-height: 1;
  font-weight: 500;
  color: #203dff;
  font-family: "ZhSubset", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, "PingFang SC", "Heiti SC", "Microsoft YaHei", sans-serif;
}

.merchant-overview-label {
  font-size: 25rpx;
  line-height: 1.4;
  color: #707784;
  text-align: center;
}

.merchant-overview-tip {
  margin-top: 34rpx;
  font-size: 27rpx;
  line-height: 1.6;
  color: #6b7280;
  text-align: center;
}

.merchant-overview-action {
  margin-top: 28rpx;
  min-width: 260rpx;
  height: 76rpx;
  line-height: 76rpx;
  padding: 0 54rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #020202 0%, #3a3a3d 100%);
  color: #fff;
  font-size: 29rpx;
  font-weight: 600;
  box-shadow: 0 14rpx 24rpx rgba(0, 0, 0, 0.12);
}

.merchant-overview-action::after {
  border: none;
}

.merchant-guide-entry {
  margin-top: auto;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0 0;
}

.merchant-guide-entry-text {
  font-size: 28rpx;
  line-height: 1.5;
  color: #111827;
  text-decoration: underline;
  font-weight: 600;
}

.my-marker-guide-floating {
  position: fixed;
  left: 50%;
  bottom: calc(env(safe-area-inset-bottom) + 150rpx);
  transform: translateX(-50%);
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 20rpx;
}

.empty-card {
  background: linear-gradient(180deg, #ffffff 0%, #f3f4f6 100%);
  border-radius: 28rpx;
  padding: 80rpx 40rpx;
  text-align: center;
  display: flex;
  flex-direction: column;        /* 涓€鍒楁帓鍒?= 姣忎釜鈥滃崰涓€琛屸€?*/
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.08);
  
}

.empty-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  margin: 0 auto;
  border-radius: 50%;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 0 12rpx rgba(15, 23, 42, 0.12);
}

.empty-icon {
  width: 82rpx;
  height: 82rpx;
  display: block;
}

.empty-title {
  margin-top: 20rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: #1d1d1f;
}

.empty-desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #6b7280;
}

.empty-action {
  margin-top: 40rpx;
  background: linear-gradient(90deg, #000000, #333333);
  color: #fff;
  padding: 18rpx 42rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
}

.marker-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.marker-card {
  position: relative;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0rpx 10rpx 30rpx rgba(15, 23, 42, 0.1);
  overflow: hidden;
}

.reject-reason-icon-hit {
  position: absolute;
  top: 6rpx;
  right: 0rpx;
  z-index: 5;
  width: 30rpx;
  height: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.reject-reason-icon {
  width: 22rpx;
  height: 22rpx;
  display: block;
  transform-origin: center;
  animation: reject-bubble-breath 2.2s ease-in-out infinite;
}

@keyframes reject-bubble-breath {
  0%,
  100% {
    opacity: 0.62;
    transform: rotate(0deg) translateY(0) scale(0.9);
  }
  50% {
    opacity: 1;
    transform: rotate(0deg) translateY(-6rpx) scale(1.22);
  }
}

.workgroup-list {
  padding: 0 12rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.workgroup-card {
  padding: 36rpx 32rpx;
}

.workgroup-card .card-top {
  align-items: flex-start;
  gap: 24rpx;
}

.workgroup-card .marker-cover {
  width: 200rpx;
  height: 140rpx;
  margin-top: 0;
}

.card-body {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.card-top {
  display: flex;
  gap: 32rpx;
  align-items: flex-start;
}

.card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  min-width: 0;
}

.marker-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.marker-name {
  font-size: 38rpx;
  font-weight: 700;
  color: #111827;
  line-height: 1.3;
  min-width: 0;
}

.marker-certified-icon {
  width: 34rpx;
  height: 34rpx;
  display: block;
  flex-shrink: 0;
}

.marker-location,
.marker-created,
.marker-expire {
  font-size: 22rpx;
  color: #6b7280;
  line-height: 1.4;
}

.marker-expire {
  color: #8a6a12;
}

.marker-auth-action {
  display: inline-block;
  margin-top: 2rpx;
  font-size: 24rpx;
  line-height: 1.3;
  font-weight: 600;
  color: #111111;
  text-decoration: underline;
  text-decoration-thickness: 2rpx;
  text-underline-offset: 4rpx;
  align-self: flex-start;
}

.marker-cover {
  width: 188rpx;
  height: 140rpx;
  margin-top: 8rpx;
  border-radius: 20rpx;
  background: #f3f4f6;
  align-self: flex-start;
  position: relative;
  overflow: hidden;
}

.marker-cover-video-player {
  width: 100%;
  height: 100%;
  display: block;
}

.card-stats {
  display: flex;
  gap: 4rpx;
  margin-top: 12rpx;
  flex-wrap: nowrap;
}

.stat-item {
  flex: 0 0 138rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  justify-content: flex-start;
  max-width: 150rpx;
  overflow: hidden;
}

.stat-icon {
  width: 44rpx;
  height: 44rpx;
  display: block;
  transform: translateZ(0);
}

.stat-value {
  font-size: 24rpx;
  font-weight: 400;
  letter-spacing: 0.5rpx;
  color: #1f2937;
  max-width: 100rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  
}
.stat-value.exp{
  transform: translateY(-15rpx);
}

.stat-phone-pill {
  min-width: 200rpx;
  height: 64rpx;
  padding: 0 22rpx;
  border-radius: 32rpx;
  background: #f4f5f7;
  border: 1rpx solid #e5e7eb;
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  justify-content: center;
  box-sizing: border-box;
  transition: transform 120ms ease, background-color 120ms ease, box-shadow 120ms ease;
  flex-shrink: 0;
  max-width: 200rpx;
}

.stat-phone-pill.is-private {
  justify-content: center;
}

.stat-phone-pill.is-workgroup {
  min-width: 200rpx;
  padding-right: 18rpx;
  padding-left: 18rpx;
}

.pill-icon {
  width: 40rpx;
  height: 40rpx;
  display: block;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  display:flex;
  align-items:center;
  justify-content:center;
}

/* .pill-icon.pill-img{
  width:100%;
  height:100%;
  display:block;
} */



.stat-phone-pill.is-private .pill-icon {
  filter: brightness(0);
}

.stat-phone-pill.is-workgroup .pill-icon {
  filter: none;
}

.pill-name {
  font-size: 22rpx;
  color: #111827;
  max-width: 120rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  
}
.pill-name.is_card{
