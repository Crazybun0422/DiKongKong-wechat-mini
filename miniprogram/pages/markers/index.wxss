.required-indicator {
  color: #ef4444;
  font-size: 28rpx;
  line-height: 1;
}

.section-title.required .required-indicator {
  font-size: 32rpx;
}

.form-input {
  border-radius: 16rpx;
  border: 1px solid #e5e7eb;
  padding: 18rpx 24rpx;
  font-size: 28rpx;
  color: #111827;
  background: #f9fafb;
}

.form-textarea {
  border-radius: 16rpx;
  border: 1px solid #e5e7eb;
  padding: 18rpx 24rpx;
  font-size: 28rpx;
  color: #111827;
  background: #f9fafb;
  min-height: 180rpx;
}

.form-input[disabled],
.form-textarea[disabled] {
  opacity: 0.7;
  color: #94a3b8;
  background: #f3f4f6;
}

.location-box {
  border-radius: 16rpx;
  border: 1px dashed #94a3b8;
  padding: 18rpx 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #f8fafc;
}

.location-text {
  font-size: 28rpx;
  color: #1f2937;
}

.location-action {
  font-size: 26rpx;
  color: #000000;
}

.tag-editor {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-editor.is-disabled {
  opacity: 0.7;
}

.tag-editor.is-disabled .tag-chip {
  background: rgba(0, 0, 0, 0.08);
  color: #6b7280;
}

.tag-editor.is-disabled .tag-input {
  color: #9ca3af;
}

.image-uploader {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: 20rpx;
  overflow: hidden;
  position: relative;
  background: #f1f5f9;
}

.image-thumb-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.image-thumb-action {
  position: absolute;
  right: 12rpx;
  bottom: 12rpx;
  padding: 8rpx 14rpx;
  background: rgba(0, 0, 0, 0.45);
  color: #fff;
  font-size: 22rpx;
  border-radius: 999rpx;
}

.image-remove {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 18rpx;
  background: rgba(15, 23, 42, 0.6);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.image-add {
  width: 160rpx;
  height: 160rpx;
  border: 1px dashed #cbd5f5;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: #f8fbff;
  color: #475569;
}

.image-add-icon {
  width: 54px;
  height: 54rpx;
  filter: brightness(0.6) saturate(100%);
}

.image-add-text {
  font-size: 26rpx;
}

.tag-remove {
  width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  background: rgba(0, 0, 0, 0.06);
  color: #374151;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
}

.tag-input {
  min-width: 220rpx;
  padding: 16rpx 20rpx;
  border-radius: 14rpx;
  border: 1px dashed #cbd5f5;
  font-size: 26rpx;
  color: #111827;
  background: #f8fbff;
}

.tag-add {
  padding: 16rpx 24rpx;
  border-radius: 14rpx;
  background: rgba(0, 0, 0, 0.12);
  color: #000000;
  font-size: 26rpx;
}

.admin-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.media-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-top: 24rpx;
}

.media-item {
  position: relative;
  width: 100%;
  padding-top: 100%;
  border-radius: 20rpx;
  /* overflow: hidden; */
  background: #f1f5f9;
}

.media-image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.media-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1px dashed #94a3b8;
  border-radius: 20rpx;
  background: #f9fafb;
  padding: 32rpx 0;
}

.media-add.is-disabled,
.attachment-add.is-disabled {
  opacity: 0.55;
}

.media-add-icon {
  font-size: 40rpx;
  color: #000000;
}

.media-add-text {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #475569;
}

.media-remove {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  background: rgba(17, 24, 39, 0.6);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.video-form {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-top: 24rpx;
}

.video-field {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.video-field-label {
  font-size: 26rpx;
  color: #1f2937;
}

.decoration-card {
  background: #ffffff;
  border: 1rpx solid rgba(148, 163, 184, 0.18);
}

.decoration-card.is-locked {
  background: #ffffff;
}

.decoration-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.decoration-card-title-group {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.decoration-card-status {
  min-width: 108rpx;
  height: 42rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.decoration-card-status-text {
  display: inline-block;
  line-height: 1;
  transform: translateY(-2rpx);
}

.decoration-card-status.is-certified {
  background: rgba(17, 24, 39, 0.08);
  color: #111827;
}

.decoration-card-status.is-locked {
  background: rgba(217, 119, 6, 0.12);
  color: #b45309;
}

.decoration-card-arrow {
  width: 34rpx;
  height: 34rpx;
  display: block;
  opacity: 0.72;
}

.decoration-card-body {
  margin-top: 28rpx;
  padding-top: 28rpx;
  border-top: 1rpx solid rgba(148, 163, 184, 0.18);
}

.decoration-card-lock-tip {
  margin-bottom: 24rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(245, 158, 11, 0.08);
  color: #92400e;
  font-size: 24rpx;
  line-height: 1.6;
}

.helper-text {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.payment-options {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.merchant-entry-card {
  padding: 0;
  background: transparent;
  border: 0;
  box-shadow: 0 14rpx 36rpx rgba(15, 23, 42, 0.08);
}

.merchant-entry-card-shell {
  position: relative;
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
  border-radius: 0;
  background-color: #f3df8a;
  border: 0;
}

.merchant-entry-card-skin-stack {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  pointer-events: none;
  z-index: 1;
}

.merchant-entry-card-skin {
  width: 100%;
  display: block;
  flex-shrink: 0;
}

.merchant-entry-card-skin-top,
.merchant-entry-card-skin-bottom {
  height: auto;
}

.merchant-entry-card-skin-middle-fill {
  flex: 1;
  min-height: 0;
  background: #ffffff;
}

.merchant-entry-card-content {
  position: relative;
  z-index: 2;
  padding: 26rpx 28rpx 28rpx;
  box-sizing: border-box;
}

.merchant-entry-tabs {
  position: relative;
  display: flex;
  align-items: stretch;
  gap: 0;
  border-radius: 24rpx;
  background: transparent;
  padding: 0;
  overflow: hidden;
}

.merchant-entry-tab {
  position: relative;
  z-index: 1;
  flex: 1;
  min-height: 108rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.merchant-entry-tab-inner {
  position: relative;
  z-index: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 0 16rpx;
}

.merchant-entry-tab.is-left .merchant-entry-tab-inner {
  transform: translate(-25rpx, -30rpx);
}

.merchant-entry-tab.is-right .merchant-entry-tab-inner {
  transform: translate(25rpx, -30rpx);
}

.merchant-entry-tab-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
}

.merchant-entry-tab.is-active .merchant-entry-tab-label {
  color: #46351b;
}

.merchant-entry-tab-icon {
  width: 34rpx;
  height: 34rpx;
  display: block;
}

.merchant-entry-panel {
  position: relative;
  margin-top: 28rpx;
}

.merchant-entry-panel.free-mode {
  margin-top: 24rpx;
}

.merchant-entry-placeholder {
  min-height: 320rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.72);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6b7280;
  font-size: 26rpx;
  text-align: center;
  padding: 32rpx;
  box-sizing: border-box;
}

.merchant-entry-placeholder.is-error {
  color: #b91c1c;
}

.merchant-intro-long-image {
  width: 100%;
  display: block;
  border-radius: 24rpx;
  background: #ffffff;
}

.payment-option {
  border: 1px solid #e2e8f0;
  border-radius: 20rpx;
  padding: 24rpx;
  background: #f8fafc;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.payment-option.is-disabled {
  opacity: 0.6;
}

.payment-option.is-disabled .payment-option-title,
.payment-option.is-disabled .payment-option-note,
.payment-option.is-disabled .price-tag,
.payment-option.is-disabled .price-original {
  color: rgba(31, 41, 55, 0.4);
}

.payment-option.is-active {
  border-color: #111827;
  background: #111827;
  color: #ffffff;
}

.payment-option.is-active .payment-option-title,
.payment-option.is-active .payment-option-note,
.payment-option.is-active .price-tag,
.payment-option.is-active .price-original {
  color: #ffffff;
}

.payment-option-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.payment-option-title {
  font-size: 28rpx;
  font-weight: 600;
  color: inherit;
}

.payment-option-note {
  font-size: 24rpx;
  color: inherit;
}

.payment-price {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.price-tag {
  font-size: 36rpx;
  font-weight: 700;
  color: #0f172a;
}

.price-original {
  font-size: 26rpx;
  color: rgba(15, 23, 42, 0.6);
  text-decoration: line-through;
}

.payment-summary {
  margin-top: 24rpx;
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.payment-summary-item {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #0f172a;
  font-size: 24rpx;
}

.plan-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 24rpx;
}

.plan-card {
  border-radius: 24rpx;
  padding: 28rpx;
  border: 1px solid #e2e8f0;
  background: #f8fafc;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.plan-card.is-selected {
  border-color: #000000;
  background: rgba(0, 0, 0, 0.1);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.plan-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.plan-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
}

.plan-price {
  font-size: 34rpx;
  font-weight: 600;
  color: #000000;
}

.plan-desc {
  font-size: 26rpx;
  color: #4b5563;
  line-height: 1.4;
}

.plan-status {
  font-size: 24rpx;
  color: #000000;
}

.summary-card {
  margin-top: 24rpx;
  border-radius: 20rpx;
  background: #f8fafc;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  font-size: 26rpx;
  color: #1f2937;
}

.error-box {
  margin-top: 24rpx;
  background: rgba(248, 113, 113, 0.15);
  color: #b91c1c;
  padding: 20rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
}

.result-card {
  margin: 48rpx auto;
  text-align: center;
  background: #ffffff;
  border-radius: 28rpx;
  padding: 80rpx 32rpx;
  box-shadow: 0 14rpx 36rpx rgba(15, 23, 42, 0.1);
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.result-card.error {
  background: #fff7f7;
}

.result-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
}

.result-icon.success {
  background: rgba(16, 185, 129, 0.12);
  color: #047857;
}

.result-icon.error {
  background: rgba(248, 113, 113, 0.18);
  color: #b91c1c;
}

.result-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #111827;
}

.result-desc {
  font-size: 26rpx;
  color: #4b5563;
}

.result-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  font-size: 26rpx;
  color: #1f2937;
}

.result-btn {
  margin-top: 24rpx;
  background: linear-gradient(90deg, #000000, #333333);
  color: #fff;
  border-radius: 999rpx;
  padding: 20rpx 0;
  font-size: 30rpx;
}

.detail-list {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  font-size: 26rpx;
  color: #000000;
  word-break: break-all;
}

.detail-link {
  text-decoration: underline;
}
.workgroup-meta-row {
  display: flex;
  align-items: center;
  gap: 34rpx;
  margin-top: 16rpx;
}

.workgroup-members-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #0f172a;
}

.location-pill {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(52, 152, 255, 0.12), rgba(52, 152, 255, 0.08));
  margin-left: 14rpx;
}

.location-number {
  font-size: 34rpx;
  font-weight: 700;
  font-style: italic;
  color: #1d6cff;
  transform: translateY(-2rpx);
}

.location-label {
  font-size: 26rpx;
  font-weight: 700;
  color: #1d6cff;
}

/* 工作组邀请弹窗 */
.invite-overlay {
  position: fixed;
  inset: 0;
  z-index: 300;
  display: flex;
  align-items: center;
  justify-content: center;
}

.invite-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.55);
}

.invite-card {
  position: relative;
  width: 82vw;
  max-width: 700rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 28rpx 22rpx;
  box-shadow: 0 18rpx 40rpx rgba(0, 0, 0, 0.22);
  z-index: 1;
}

.invite-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
  text-align: center;
  margin-bottom: 16rpx;
}

.invite-body {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 12rpx 6rpx 6rpx;
  color: #111827;
  font-size: 28rpx;
  text-align: center;
}

.invite-text {
  word-break: break-all;
}

.invite-tip {
  font-size: 24rpx;
  color: #6b7280;
}

.invite-footer {
  margin-top: 18rpx;
  display: flex;
  justify-content: center;
  gap: 16rpx;
}

.invite-btn {
  min-width: 240rpx;
  height: 72rpx;
  border-radius: 20rpx;
  border: none;
  font-size: 28rpx;
}

.invite-btn::after {
  border: none;
}

.invite-btn.primary {
  background: #0f172a;
  color: #fff;
}

.invite-btn.secondary {
  background: #f3f4f6;
  color: #111827;
}

.invite-btn.primary:disabled {
  opacity: 0.6;
}
