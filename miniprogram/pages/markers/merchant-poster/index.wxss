.merchant-poster-page {
  position: relative;
  width: 100%;
  min-height: 100vh;
  overflow: hidden;
  background: #0b1731;
  display: flex;
  flex-direction: column;
}

.merchant-poster-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  filter: blur(48rpx);
  transform: scale(1.12);
}

.merchant-poster-bg-mask {
  position: absolute;
  inset: 0;
  background: rgba(6, 12, 24, 0.62);
}

.merchant-poster-close {
  position: absolute;
  top: -90rpx;
  left: -130rpx;
  width: 66rpx;
  height: 66rpx;
  background: transparent;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 3;
}

.merchant-poster-close::after {
  display: none;
}

.merchant-poster-close-icon {
  width: 60rpx;
  height: 60rpx;
}

.merchant-poster-body {
  flex: 1;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: calc(env(safe-area-inset-top) + 120rpx) 40rpx 40rpx;
  box-sizing: border-box;
  position: relative;
  z-index: 2;
}

.merchant-poster-card-wrap {
  width: 100%;
  max-width: 720rpx;
  position: relative;
  transform: translateY(-170rpx);
}

.merchant-poster-card {
  width: 100%;
  max-width: 720rpx;
  background: transparent;
  border-radius: 36rpx;
  padding: 12rpx;
  box-sizing: border-box;
  border: none;
  transform: scale(1.12);
  transform-origin: center center;
}

.merchant-poster-swiper-wrap {
  width: 100%;
  position: relative;
  padding-top: 134.4%;
}

.merchant-poster-swiper {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  overflow: visible;
}

.merchant-poster-peek-fog {
  position: absolute;
  top: 0;
  bottom: 0;
  width: 3rpx;
  pointer-events: none;
  z-index: 2;
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  opacity: 0.55;
}

.merchant-poster-peek-fog--left {
  left: -2rpx;
  background: linear-gradient(
    90deg,
    rgba(11, 23, 49, 0.01) 0%,
    rgba(11, 23, 49, 0.05) 20%,
    rgba(11, 23, 49, 0.12) 46%,
    rgba(11, 23, 49, 0.12) 54%,
    rgba(11, 23, 49, 0.05) 80%,
    rgba(11, 23, 49, 0.01) 100%
  );
}

.merchant-poster-peek-fog--right {
  right: 0rpx;
  width: 3rpx;
  background: linear-gradient(
    270deg,
    rgba(11, 23, 49, 0.01) 0%,
    rgba(11, 23, 49, 0.05) 20%,
    rgba(11, 23, 49, 0.12) 46%,
    rgba(11, 23, 49, 0.12) 54%,
    rgba(11, 23, 49, 0.05) 80%,
    rgba(11, 23, 49, 0.01) 100%
  );
}

.merchant-poster-swiper-item {
  padding: 0 32rpx 0 0;
  box-sizing: border-box;
}

.merchant-poster-image-frame {
  width: 100%;
  height: 100%;
  border-radius: 28rpx;
  overflow: hidden;
  background: transparent;
  box-sizing: border-box;
}

.merchant-poster-image {
  width: 100%;
  height: 100%;
  display: block;
}

.merchant-poster-dots {
  margin-top: 14rpx;
  display: flex;
  justify-content: center;
  gap: 10rpx;
  position: relative;
  z-index: 3;
}

.merchant-poster-dot {
  width: 16rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.35);
}

.merchant-poster-dot.is-active {
  width: 32rpx;
  background: #ffffff;
}

.merchant-poster-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 16rpx 40rpx calc(env(safe-area-inset-bottom) + 16rpx + 90rpx);
  min-height: 200rpx;
  z-index: 4;
  box-shadow: 0 -12rpx 36rpx rgba(10, 15, 30, 0.1);
}

.merchant-poster-action-hover {
  opacity: 0.8;
}

.merchant-poster-action-save,
.merchant-poster-action-wechat,
.merchant-poster-action-timeline {
  position: absolute;
  top: 56rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  
}

.merchant-poster-action-save {
  left: 23rpx;
}

.merchant-poster-action-wechat {
  left: 183rpx;
}

.merchant-poster-action-timeline {
  left: 343rpx;
}

.merchant-poster-save-btn,
.merchant-poster-wechat-btn,
.merchant-poster-timeline-btn {
  position: relative;
  width: 86rpx;
  height: 86rpx;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
  min-height: 0;
  line-height: 0;
  font-size: 0;
  box-sizing: border-box;

}

.merchant-poster-save-btn::after,
.merchant-poster-wechat-btn::after,
.merchant-poster-timeline-btn::after {
  display: none;
}

.merchant-poster-save-icon,
.merchant-poster-wechat-icon,
.merchant-poster-timeline-icon {
  width: 86rpx;
  height: 86rpx;
  display: block;
  margin: 0;
  transform: translateX(-80%);
}


.merchant-poster-save-text,
.merchant-poster-wechat-text,
.merchant-poster-timeline-text {
  margin-top: 12rpx;
  text-align: center;
  font-size: 24rpx;
  color: #1c1c1e;
  white-space: nowrap;
  transform: translateX(-75%);
}
.merchant-poster-timeline-text {
  transform: translateX(-100%);
}



.merchant-poster-loading {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 12;
}

.merchant-poster-loading-mask {
  position: absolute;
  inset: 0;
  background: rgba(7, 12, 22, 0.58);
}

.merchant-poster-loading-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  color: #ffffff;
}

.merchant-poster-loading-image {
  width: 180rpx;
  height: 180rpx;
  animation: merchant-poster-breathe 1.6s ease-in-out infinite;
}

.merchant-poster-loading-text {
  font-size: 24rpx;
  color: #ffffff;
}

.merchant-poster-error {
  position: fixed;
  left: 40rpx;
  right: 40rpx;
  top: 40%;
  transform: translateY(-50%);
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.94);
  text-align: center;
  z-index: 13;
}

.merchant-poster-error-text {
  font-size: 26rpx;
  color: #d64545;
}

.merchant-poster-error-btn {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #fff;
  background: #d64545;
  border-radius: 999rpx;
}

.merchant-poster-error-btn::after {
  display: none;
}

@keyframes merchant-poster-breathe {
  0% {
    transform: scale(0.9);
    opacity: 0.6;
  }
  50% {
    transform: scale(1.05);
    opacity: 1;
  }
  100% {
    transform: scale(0.9);
    opacity: 0.6;
  }
}
