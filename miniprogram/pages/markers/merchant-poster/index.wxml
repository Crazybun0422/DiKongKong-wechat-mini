<view class="merchant-poster-page">
  <image class="merchant-poster-bg" src="{{activeBackground}}" mode="aspectFill" />
  <view class="merchant-poster-bg-mask"></view>

  <view class="merchant-poster-body">
    <view class="merchant-poster-card-wrap">
      <button class="merchant-poster-close" bindtap="onCloseTap" hover-class="none">
        <image class="merchant-poster-close-icon" src="/pages/markers/assets/poster-close.png" mode="aspectFit" />
      </button>
      <view class="merchant-poster-card">
        <view class="merchant-poster-swiper-wrap">
          <swiper
            class="merchant-poster-swiper"
            circular="{{posters.length > 1}}"
            current="{{currentIndex}}"
            previous-margin="50rpx"
            next-margin="50rpx"
            bindchange="onPosterChange"
          >
            <block wx:for="{{posters}}" wx:key="backgroundUrl">
              <swiper-item class="merchant-poster-swiper-item">
                <view class="merchant-poster-image-frame">
                  <image
                    class="merchant-poster-image"
                    src="{{item.path || item.backgroundUrl}}"
                    mode="aspectFit"
                    data-index="{{index}}"
                    bindload="onPosterImageLoad"
                    binderror="onPosterImageError"
                  />
                </view>
              </swiper-item>
            </block>
          </swiper>
          <view class="merchant-poster-peek-fog merchant-poster-peek-fog--left"></view>
          <view class="merchant-poster-peek-fog merchant-poster-peek-fog--right"></view>
        </view>
        <view class="merchant-poster-dots" wx:if="{{posters.length > 1}}">
          <block wx:for="{{posters}}" wx:key="backgroundUrl">
            <view class="merchant-poster-dot {{index === currentIndex ? 'is-active' : ''}}"></view>
          </block>
        </view>
      </view>
    </view>
  </view>

  <view class="merchant-poster-actions">
    <view class="merchant-poster-action-save">
      <button class="merchant-poster-save-btn" bindtap="onSavePosterTap" hover-class="merchant-poster-action-hover">
        <image class="merchant-poster-save-icon" src="/pages/markers/assets/download-poster.png" mode="aspectFit" />
      </button>
      <text class="merchant-poster-save-text">保存海报</text>
    </view>
    <view class="merchant-poster-action-wechat">
      <button class="merchant-poster-wechat-btn" open-type="share" hover-class="merchant-poster-action-hover">
        <image class="merchant-poster-wechat-icon" src="/pages/markers/assets/t-wechat.png" mode="aspectFit" />
      </button>
      <text class="merchant-poster-wechat-text">微信好友</text>
    </view>
    <view class="merchant-poster-action-timeline">
      <button class="merchant-poster-timeline-btn" bindtap="onShareTimelineTap" hover-class="merchant-poster-action-hover">
        <image class="merchant-poster-timeline-icon" src="/pages/markers/assets/t-moments.png" mode="aspectFit" />
      </button>
      <text class="merchant-poster-timeline-text">朋友圈</text>
    </view>
  </view>

  <view class="merchant-poster-loading" wx:if="{{loading}}">
    <view class="merchant-poster-loading-mask"></view>
    <view class="merchant-poster-loading-content">
      <image class="merchant-poster-loading-image" src="/assets/af-loading.png" mode="aspectFit" />
      <text class="merchant-poster-loading-text" wx:if="{{loadingText}}">{{loadingText}}</text>
    </view>
  </view>

  <view class="merchant-poster-error" wx:if="{{error}}">
    <text class="merchant-poster-error-text">{{error}}</text>
    <button class="merchant-poster-error-btn" bindtap="onRetryTap">重试</button>
  </view>
</view>
