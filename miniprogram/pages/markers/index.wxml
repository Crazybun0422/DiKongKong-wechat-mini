<view class="markers-page">
  <view wx:if="{{!showDetail && !showCreate && !showMyPinCreate && !showWorkGroupCreate &&!showWorkGroupDetail}}" class="markers-shell">
    <view class="center-tabs">
      <block wx:for="{{centerTabs}}" wx:key="id">
        <view class="center-tab {{activeCenterTab === item.id ? 'is-active' : ''}}" data-tab="{{item.id}}" bindtap="onCenterTabTap">
          <text>{{item.label}}</text>
        </view>
      </block>
    </view>

    <block wx:if="{{activeCenterTab === 'MERCHANT'}}">
      <view class="markers-static">
        <view class="page-header">
          <button class="create-btn" bindtap="onCreateTap">
            <image class="create-btn-icon" src="{{assetPaths.add}}" mode="aspectFit" />
            <text class="create-btn-text">新增</text>
          </button>
          <view class="create-guide-tip" catchtap="onMerchantGuideTap">
            <image class="create-guide-tip-icon" src="{{assetPaths.tips}}" mode="aspectFit" />
          </view>
        </view>

        <view class="status-tabs">
          <block wx:for="{{statusTabs}}" wx:key="id">
            <view class="status-tab {{filterStatus === item.id ? 'is-active' : ''}}" data-status="{{item.id}}" bindtap="onStatusTabTap">
              <text>{{item.label}}</text>
            </view>
          </block>
        </view>
      </view>

      <scroll-view scroll-y class="markers-scroll" refresher-enabled="{{true}}" refresher-triggered="{{listRefreshing}}" bindrefresherrefresh="onPullDownRefresh">
        <block wx:if="{{loading && !hasLoaded}}">
          <view class="state-card">加载中...</view>
        </block>
        <block wx:elif="{{error}}">
          <view class="state-card state-error">
            <text class="state-text">{{error}}</text>
            <button class="retry-btn" bindtap="onRetryTap">重新加载</button>
          </view>
        </block>
        <block wx:elif="{{!visibleMarkers.length}}">
          <view class="merchant-empty-state">
            <view class="merchant-overview-card">
              <text class="merchant-overview-update">更新时间{{merchantOverview.updateTimeDisplay}}</text>
              <view class="merchant-overview-stats">
                <view class="merchant-overview-stat">
                  <text class="merchant-overview-number">{{merchantOverview.registeredUserDisplay}}</text>
                  <text class="merchant-overview-label">注册飞友数</text>
                </view>
                <view class="merchant-overview-stat">
                  <text class="merchant-overview-number">{{merchantOverview.averageMonthlyExposureDisplay}}</text>
                  <text class="merchant-overview-label">商户平均月曝光量</text>
                </view>
              </view>
              <text class="merchant-overview-tip">*入驻低空门店（服务），获取精准客户。</text>
              <button class="merchant-overview-action" bindtap="onCreateTap">免费入驻</button>
            </view>
            <view class="merchant-guide-entry" bindtap="onMerchantGuideTap">
              <text class="merchant-guide-entry-text">星球商户进阶攻略 ></text>
            </view>
          </view>
        </block>
        <block wx:else>
          <view class="marker-list">
            <block wx:for="{{visibleMarkers}}" wx:key="id">
              <view class="marker-card" bindtap="onMarkerCardTap" data-id="{{item.id}}">
                <view class="status-corner {{item.reviewTone}}">
                  <text class="status-corner-text">{{item.reviewStatusLabel}}</text>
                </view>
                <view
                  wx:if="{{item.reviewStatus === 'REJECTED' && item.reviewRejectDetail}}"
                  class="reject-reason-icon-hit"
                  data-type="marker"
                  data-reason="{{item.reviewRejectDetail}}"
                  catchtap="onOpenRejectReason"
                >
                  <image
                    class="reject-reason-icon"
                    src="{{assetPaths.exclPoint}}"
                    mode="aspectFit"
                  />
                </view>
                <view class="card-body">
                  <view class="card-top">
                    <view class="card-info">
                      <view class="marker-title-row">
                        <block wx:if="{{item.isCertified}}">
                          <text class="marker-name">{{item.titlePrefixText}}</text>
                          <view class="marker-title-badge-group">
                            <text class="marker-name">{{item.titleTailText}}</text>
                            <image
                              class="marker-certified-icon"
                              src="{{assetPaths.svip}}"
                              mode="aspectFit"
                            />
                          </view>
                        </block>
                        <text wx:else class="marker-name">{{item.titleDisplayText}}</text>
                      </view>
                      <text class="marker-location">{{item.locationText || '未填写位置'}}</text>
                      <view
                        class="marker-auth-row"
                        data-id="{{item.id}}"
                        catchtap="onMarkerAuthTap"
                      >
                        <text wx:if="{{item.isCertified && item.expireAtDisplay}}" class="marker-expire">
                          {{item.expireAtDisplay}}认证到期
                        </text>
                        <text class="marker-auth-action">
                          {{item.authActionText}}
                        </text>
                      </view>
                      <view class="card-stats">
                        <view class="stat-item">
                          <image class="stat-icon" src="{{assetPaths.exposure}}" mode="aspectFit" />
                          <text class="stat-value exp" data-value="{{item.exposureFull || item.exposureCount}}" catchtap="onExposureTap">
                            {{item.exposureDisplay || item.exposureCount}}
                          </text>
                        </view>
                        <view class="stat-item">
                          <image class="stat-icon" src="{{assetPaths.telephone}}" mode="aspectFit" />
                          <text class="stat-value">{{item.phoneCallCount}}</text>
                        </view>
                      </view>
                    </view>
                    <view wx:if="{{item.video}}" class="marker-cover marker-cover-video" catchtap="onInlineVideoTap" data-url="{{item.video.url}}" data-poster="{{item.video.poster}}" data-video-id="pin-card-video-{{index}}">
                      <video
                        id="pin-card-video-{{index}}"
                        class="marker-cover-video-player"
                        src="{{item.video.url}}"
                        poster="{{item.video.poster}}"
                        object-fit="cover"
                        autoplay="{{true}}"
                        muted="{{true}}"
                        loop="{{true}}"
                        show-center-play-btn="{{false}}"
                        show-play-btn="{{false}}"
                        controls="{{false}}"
                        enable-progress-gesture="{{false}}"
                        data-pin-id="{{item.id}}"
                        data-video-id="pin-card-video-{{index}}"
                        bindwaiting="onPinCardVideoWaiting"
                        bindplay="onPinCardVideoReady"
                        bindloadeddata="onPinCardVideoReady"
                      />
                      <view wx:if="{{pinCardVideoLoadingMap[item.id]}}" class="video-loading-mask">
                        <text class="video-loading-text">加载中...</text>
                      </view>
                      <view class="video-fullscreen-hit"></view>
                    </view>
                    <image wx:else class="marker-cover" src="{{item.coverImage || defaultCoverImage}}" mode="aspectFill" />
                  </view>
                </view>
              </view>
            </block>
          </view>
        </block>
      </scroll-view>
    </block>

    <block wx:elif="{{activeCenterTab === 'MY_MARKERS'}}">
      <view class="markers-static">
        <view class="page-header">
          <button class="create-btn" bindtap="onCreateTap">
            <image class="create-btn-icon" src="{{assetPaths.add}}" mode="aspectFit" />
            <text class="create-btn-text">新增</text>
          </button>
          <view class="create-guide-tip" catchtap="onPinCreationGuideTap">
            <image class="create-guide-tip-icon" src="{{assetPaths.tips}}" mode="aspectFit" />
          </view>
        </view>

        <view class="my-marker-filters">
          <block wx:for="{{pinFilters}}" wx:key="id">
            <view class="my-marker-filter {{activePinFilter === item.id ? 'is-active' : ''}}" data-filter="{{item.id}}" bindtap="onPinFilterTap">
              <text>{{item.label}}</text>
            </view>
          </block>
        </view>
      </view>

      <scroll-view
        scroll-y
        class="markers-scroll"
        refresher-enabled="{{true}}"
        refresher-triggered="{{pinsRefreshing}}"
        bindrefresherrefresh="onPullDownRefresh"
        bindscrolltolower="onPinListScrollLower"
        lower-threshold="80"
      >

        <block wx:if="{{pinsLoading && !pinsLoaded}}">
          <view class="state-card">加载中...</view>
        </block>
        <block wx:elif="{{pinsError}}">
          <view class="state-card state-error">
            <text class="state-text">{{pinsError}}</text>
            <button class="retry-btn" bindtap="onRetryPinRefreshTap">重新加载</button>
          </view>
        </block>
        <block wx:elif="{{!visiblePins.length}}">
          <view class="empty-card my-marker-empty-card">
            <view class="empty-icon-wrapper my-marker-empty-icon-wrapper">
              <image class="empty-icon my-marker-empty-icon" src="{{assetPaths.emptyPin}}" mode="aspectFit" />
            </view>
            <text class="empty-title">暂未创建标记</text>
            <view class="my-marker-desc-box">
              <text class="my-marker-desc-line">支持标记点、线和面3种类型</text>
              <text class="my-marker-desc-line">也支持uom、奥维地图KML文件导入/导出</text>
              <text class="my-marker-desc-line">权限可设为私有、工作组和发布到平台</text>
            </view>
            <button class="empty-action" bindtap="onCreateTap">立即创建</button>
          </view>
        </block>
        <block wx:else>
          <view class="marker-list">
            <block wx:for="{{visiblePins}}" wx:key="id">
              <view class="marker-card" bindtap="onPinCardTap" data-pin-id="{{item.id}}">
                <view class="status-corner {{item.reviewTone}}">
                  <text class="status-corner-text">{{item.reviewStatusLabel}}</text>
                </view>
                <view
                  wx:if="{{item.scope === 'PUBLIC' && item.reviewStatus === 'REJECTED' && item.reviewRejectDetail}}"
                  class="reject-reason-icon-hit"
                  data-type="pin"
                  data-reason="{{item.reviewRejectDetail}}"
                  catchtap="onOpenRejectReason"
                >
                  <image
                    class="reject-reason-icon"
                    src="{{assetPaths.exclPoint}}"
                    mode="aspectFit"
                  />
                </view>
                <view class="card-body">
                  <view class="card-top">
                    <view class="card-info">
                      <text class="marker-name">{{item.name || '未命名标记'}}</text>
                      <text class="marker-location">{{item.locationText || '未填写位置'}}</text>
                      <text class="marker-created">{{item.timelineLabel}}: {{item.timelineDisplay}}</text>
                      <view class="card-stats">
                        <view class="stat-item">
                          <image class="stat-icon" src="{{assetPaths.exposure}}" mode="aspectFit" />
                          <text class="stat-value exp" data-value="{{item.exposureFull || item.exposureCount}}" catchtap="onExposureTap">
                            {{item.exposureDisplay || item.exposureCount}}
                          </text>
                        </view>
                        <view class="stat-phone-pill {{item.hasWorkGroup ? 'is-workgroup' : 'is-private'}}" wx:if="{{activeCenterTab === 'MY_MARKERS' && item.scope !== 'PUBLIC'}}" catchtap="onOpenWorkGroupPicker" data-id="{{item.id}}">
                          <block wx:if="{{item.hasWorkGroup}}">
                            <image class="pill-icon" src="{{item.workGroupCoverImage || assetPaths.workGroup}}" mode="aspectFill" lazy-load="true" />
                            <text class="pill-name is_card">
                              {{item.workGroupDisplayName}}
                            </text>
                            <text class="pill-count">({{item.workGroupMemberCount || 0}})</text>
                            <image class="pill-arrow" src="{{assetPaths.arrowRight}}" mode="aspectFit" />
                          </block>
                          <block wx:else>
                            <image class="pill-icon" src="{{assetPaths.workGroup}}" mode="aspectFit" />
                          </block>
                        </view>
                      </view>
                    </view>
                    <view wx:if="{{item.video}}" class="marker-cover marker-cover-video" catchtap="onInlineVideoTap" data-url="{{item.video.url}}" data-poster="{{item.video.poster}}" data-video-id="pin-list-video-{{index}}">
                      <video
                        id="pin-list-video-{{index}}"
                        class="marker-cover-video-player"
                        src="{{item.video.url}}"
                        poster="{{item.video.poster}}"
                        object-fit="cover"
                        autoplay="{{true}}"
                        muted="{{true}}"
                        loop="{{true}}"
                        show-center-play-btn="{{false}}"
                        show-play-btn="{{false}}"
                        controls="{{false}}"
                        enable-progress-gesture="{{false}}"
                        data-pin-id="{{item.id}}"
                        data-video-id="pin-list-video-{{index}}"
                        bindwaiting="onPinCardVideoWaiting"
                        bindplay="onPinCardVideoReady"
                        bindloadeddata="onPinCardVideoReady"
                      />
                      <view wx:if="{{pinCardVideoLoadingMap[item.id]}}" class="video-loading-mask">
                        <text class="video-loading-text">加载中...</text>
                      </view>
                      <view class="video-fullscreen-hit"></view>
                    </view>
                    <image wx:else class="marker-cover" src="{{item.coverImage || defaultCoverImage}}" mode="aspectFill" />
                  </view>
                </view>
              </view>
            </block>
          </view>
          <view class="pin-list-more-state" wx:if="{{visiblePins.length}}">
            <text class="pin-list-more-text" wx:if="{{pinLoadingMore}}">加载更多中...</text>
            <text class="pin-list-more-text" wx:elif="{{!pinHasMore}}">没有更多了</text>
          </view>
        </block>
      </scroll-view>
      <view
        wx:if="{{!pinsLoading && !pinsError && !visiblePins.length}}"
        class="my-marker-guide-floating"
        bindtap="onPinCreationGuideTap"
      >
        <text class="merchant-guide-entry-text">星球创作进阶攻略 ></text>
      </view>
    </block>

    <block wx:elif="{{activeCenterTab === 'WORKGROUP'}}">
      <view class="markers-static">
        <view class="page-header">
          <button class="create-btn" bindtap="onWorkGroupCreateTap">
            <image class="create-btn-icon" src="{{assetPaths.add}}" mode="aspectFit" />
            <text class="create-btn-text">新增</text>
          </button>
        </view>
      </view>
      <scroll-view scroll-y class="markers-scroll" refresher-enabled="{{true}}" refresher-triggered="{{workGroupsRefreshing}}" bindrefresherrefresh="onPullDownRefresh">
        <block wx:if="{{workGroupsLoading && !workGroupsLoaded}}">
          <view class="state-card">加载中...</view>
        </block>
        <block wx:elif="{{workGroupsError}}">
          <view class="state-card state-error">
            <text class="state-text">{{workGroupsError}}</text>
            <button class="retry-btn" bindtap="refreshWorkGroups">重新加载</button>
          </view>
        </block>
        <block wx:elif="{{!workGroups.length}}">
          <view class="empty-card workgroup-empty-card">
            <view class="empty-icon-wrapper">
              <image class="empty-icon" src="{{assetPaths.workGroup}}" mode="aspectFit" />
            </view>
            <text class="empty-title">暂未创建工作组</text>
            <text class="empty-desc">与团队协作共享组内标记，效率翻倍。</text>
            <button class="empty-action" bindtap="onWorkGroupCreateTap">立即创建</button>
          </view>
        </block>
        <block wx:else>
          <view class="workgroup-list">
            <block wx:for="{{workGroups}}" wx:key="id">
              <view class="marker-card workgroup-card" data-id="{{item.id}}" bindtap="onWorkGroupCardTap">
                <view wx:if="{{item.isOwner}}" class="status-corner online">
                  <text class="status-corner-text">管理员</text>
                </view>
                <view class="card-body">
                  <view class="card-top">
                    <view class="card-info">
                      <text class="marker-name">{{item.name || '未命名工作组'}}</text>
                      <text class="marker-created">更新时间：{{item.updatedAtDisplay || '--'}}</text>
                      <view class="workgroup-meta-row">
                        <text class="workgroup-members-text">{{item.memberCount || 0}}人</text>
                        <view class="location-pill">
                          <text class="location-number">{{item.pinCount || 0}}</text>
                          <text class="location-label">个地点</text>
                        </view>
                      </view>
                    </view>
                    <image class="marker-cover workgroup-cover" src="{{item.coverImage || assetPaths.workGroup}}" mode="aspectFill" />
                  </view>
                </view>
              </view>
            </block>
          </view>
        </block>
      </scroll-view>
    </block>
  </view>

  <view wx:if="{{activeCenterTab === 'MERCHANT' && showDetail}}" class="drawer-overlay">
    <view class="drawer">
      <view class="drawer-header">
        <text class="drawer-title">入驻详情</text>
        <view class="drawer-close" bindtap="onCloseDetail">✕</view>
      </view>
      <scroll-view scroll-y class="drawer-body">
        <view class="detail-section">
          <text class="detail-title">基础信息</text>
          <view class="detail-item">
            <text class="detail-label">商户（门店）名称</text>
            <text class="detail-value">{{activeMarker.name}}</text>
          </view>
          <view class="detail-item">
            <text class="detail-label">审核状态</text>
            <text class="detail-value status-text {{activeMarker.reviewTone}}">{{activeMarker.reviewStatusLabel}}</text>
          </view>
          <view class="detail-item">
            <text class="detail-label">认证状态</text>
            <text class="detail-value">{{activeMarker.paid ? '已认证' : '未认证'}}</text>
          </view>
          <view class="detail-item">
            <text class="detail-label">门店（服务）位置</text>
            <text class="detail-value">{{activeMarker.locationText || '未填写'}}</text>
          </view>
          <view class="detail-item">
            <text class="detail-label">商家电话</text>
            <text class="detail-value">{{activeMarker.phone || '未填写'}}</text>
          </view>
          <view class="detail-item">
            <text class="detail-label">业务简介</text>
            <text class="detail-value">{{activeMarker.description || '未填写'}}</text>
          </view>
          <view class="detail-item">
            <text class="detail-label">创建时间</text>
            <text class="detail-value">{{activeMarker.createdAtDisplay}}</text>
          </view>
          <view class="detail-item">
            <text class="detail-label">更新时间</text>
            <text class="detail-value">{{activeMarker.updatedAtDisplay}}</text>
          </view>
        </view>

        <view class="detail-section" wx:if="{{activeMarker.industryHonorTags && activeMarker.industryHonorTags.length}}">
          <text class="detail-title">行业荣誉</text>
          <view class="tag-display">
            <block wx:for="{{activeMarker.industryHonorTags}}" wx:key="*this">
              <view class="tag-chip">{{item}}</view>
            </block>
          </view>
        </view>

        <view class="detail-section" wx:if="{{activeMarker.images && activeMarker.images.length}}">
          <text class="detail-title">门店（服务）图片</text>
          <view class="media-preview-grid">
            <block wx:for="{{activeMarker.images}}" wx:key="id">
              <image class="media-preview" src="{{item.url}}" mode="aspectFill" />
            </block>
          </view>
        </view>

        <view class="detail-section" wx:if="{{activeMarker.businessLicense}}">
          <text class="detail-title">营业执照</text>
          <image class="license-preview" src="{{activeMarker.businessLicense.url}}" mode="aspectFill" />
        </view>

        <view class="detail-section" wx:if="{{activeMarker.attachments && activeMarker.attachments.length}}">
          <text class="detail-title">产品业务资料</text>
          <view class="attachment-list">
            <block wx:for="{{activeMarker.attachments}}" wx:key="id">
              <view class="attachment-item">
                <text class="attachment-icon">📎</text>
                <text class="attachment-name">{{item.label || '产品业务资料'}}</text>
              </view>
            </block>
          </view>
        </view>

        <view class="detail-section" wx:if="{{activeMarker.qrCodes && activeMarker.qrCodes.length}}">
          <text class="detail-title">产品体验二维码</text>
          <view class="qr-code-list">
            <block wx:for="{{activeMarker.qrCodes}}" wx:key="id">
              <image class="qr-code-preview" src="{{item.url}}" mode="widthFix" show-menu-by-longpress />
            </block>
          </view>
        </view>

        <view class="detail-section" wx:if="{{activeMarker.videoChannelUrls && activeMarker.videoChannelUrls.length}}">
          <text class="detail-title">挂载视频号视频</text>
          <view class="detail-list">
            <block wx:for="{{activeMarker.videoChannelUrls}}" wx:key="*this">
              <text class="detail-link">{{item}}</text>
            </block>
          </view>
        </view>

        <view class="detail-section" wx:if="{{activeMarker.adminInfo &&(activeMarker.adminInfo.name || activeMarker.adminInfo.phone)}}">
          <text class="detail-title">管理员联系</text>
          <view class="detail-item">
            <text class="detail-label">姓名</text>
            <text class="detail-value">{{activeMarker.adminInfo.name || '未填写'}}</text>
          </view>
          <view class="detail-item">
            <text class="detail-label">电话</text>
            <text class="detail-value">{{activeMarker.adminInfo.phone || '未填写'}}</text>
          </view>
        </view>

        <!-- <button
          class="danger-btn"
          data-id="{{activeMarker.id}}"
          bindtap="onDeleteMarkerTap"
          loading="{{deletingId === activeMarker.id}}"
          disabled="{{deletingId === activeMarker.id}}"
        >
          删除标记
        </button> -->
      </scroll-view>
    </view>
  </view>

  <view wx:if="{{showWorkGroupCreate}}" class="drawer-overlay">
    <view class="drawer">
      <view class="drawer-header">
        <text class="drawer-title">创建工作组</text>
        <view class="drawer-close" bindtap="onCloseWorkGroupCreate">×</view>
      </view>
      <scroll-view scroll-y class="drawer-body">
        <view class="field-row">
          <view class="field-label required">
            <text class="required-star">*</text>
            <text>图片</text>
          </view>
          <view class="image-uploader">
            <block wx:if="{{workGroupForm.images && workGroupForm.images.length}}">
              <view class="image-thumb" bindtap="onWorkGroupChooseImage">
                <image class="image-thumb-img" src="{{workGroupForm.images[0].url}}" mode="aspectFill" />
                <text class="image-thumb-action">更换</text>
              </view>
            </block>
            <view class="image-add" wx:if="{{!workGroupForm.images || !workGroupForm.images.length}}" bindtap="onWorkGroupChooseImage">
              <text class="image-add-plus">+</text>
              <text class="image-add-text">上传</text>
            </view>
          </view>
        </view>
        <view class="field-row">
          <view class="field-label required">
            <text class="required-star">*</text>
            <text>名称</text>
          </view>
          <input class="field-input form-input" placeholder="请输入" value="{{workGroupForm.name}}" bindinput="onWorkGroupNameInput" />
        </view>
        <view class="field-row">
          <view class="field-label">
            <text>简介</text>
          </view>
          <textarea class="field-textarea form-textarea" placeholder="请填写简介" value="{{workGroupForm.description}}" bindinput="onWorkGroupDescInput" maxlength="500" auto-height />
        </view>
      </scroll-view>
      <view class="drawer-footer">
        <button class="footer-btn primary" loading="{{workGroupSubmitting}}" disabled="{{workGroupSubmitting}}" bindtap="onSubmitWorkGroupCreate">
          立即创建
        </button>
      </view>
    </view>
  </view>

  <view wx:if="{{showWorkGroupPicker}}" class="modal-overlay" catchtouchmove="noop">
    <view class="modal-mask" bindtap="onCloseWorkGroupPicker"></view>
    <view class="sheet">
      <view class="sheet-header">
        <text class="sheet-title">选择工作组</text>
        <view class="sheet-close" bindtap="onCloseWorkGroupPicker">×</view>
      </view>
      <scroll-view scroll-y class="sheet-list" bindscrolltolower="onWorkGroupPickerScrollLower" lower-threshold="40">
        <block wx:if="{{workGroupPickerLoading && !workGroupPickerList.length}}">
          <view class="sheet-state">加载中...</view>
        </block>
        <block wx:elif="{{!workGroupPickerLoading && !workGroupPickerList.length}}">
          <view class="sheet-state">暂无工作组</view>
        </block>
        <block wx:else>
          <block wx:for="{{workGroupPickerList}}" wx:key="id">
            <view class="sheet-item" data-id="{{item.id}}" bindtap="onWorkGroupPickerSelect">
              <view class="sheet-item-left">
                <image class="sheet-avatar small-round" src="{{item.coverImage || assetPaths.workGroup}}" mode="aspectFill" />
                <view class="sheet-info">
                  <text class="sheet-name">
                    {{item.name || '未命名工作组'}} ({{item.memberCount || 0}})
                  </text>
                </view>
              </view>
              <view class="sheet-check {{workGroupPickerSelectedMap[item.id] ? 'is-checked' : ''}}" data-id="{{item.id}}" catchtap="onWorkGroupPickerSelect"></view>
            </view>
          </block>
          <view class="sheet-state" wx:if="{{workGroupPickerLoading}}">加载更多...</view>
          <view class="sheet-state" wx:elif="{{!workGroupPickerHasMore}}">没有更多了</view>
        </block>
      </scroll-view>
      <view class="sheet-footer">
        <button class="sheet-save-btn" loading="{{workGroupPickerSaving}}" disabled="{{workGroupPickerSaving}}" bindtap="onWorkGroupPickerSave">
          保存
        </button>
      </view>
    </view>
  </view>

  <view wx:if="{{showWorkGroupDetail && activeWorkGroup}}" class="drawer-overlay">
    <view class="drawer">
      <view class="drawer-header">
        <text class="drawer-title">工作组设置</text>
        <view class="drawer-close" bindtap="onCloseWorkGroupDetail">×</view>
      </view>
      <scroll-view scroll-y class="drawer-body wg-settings">
        <view class="wg-card">
          <view class="wg-card-title">{{activeWorkGroup.name || '工作组'}}</view>
          <view class="wg-card-code">
            <text class="wg-code-label">工作组码</text>
            <text class="wg-code-value">{{activeWorkGroup.id || '--'}}</text>
            <text class="copy-link" bindtap="onCopyWorkGroupCode">复制</text>
          </view>
        </view>

        <view class="wg-block">
          <view class="wg-block-header">
            <text class="wg-block-title">工作组成员</text>
            <view class="wg-block-count" bindtap="onWorkGroupMemberListTap">
              <text>{{activeWorkGroup.memberCount || 0}}人</text>
              <image class="workgroup-arrow" src="{{assetPaths.arrowRight}}" mode="aspectFit" />
            </view>
          </view>
          <view class="wg-avatar-row">
            <block wx:for="{{activeWorkGroup.memberAvatars}}" wx:key="featureCode">
              <image class="wg-avatar" src="{{item.avatarUrl}}" mode="aspectFill" />
            </block>
            <view wx:if="{{activeWorkGroup.isOwner}}" class="wg-avatar add" bindtap="onWorkGroupInviteTap">+</view>
          </view>
        </view>

        <view class="wg-block">
          <view class="wg-field">
            <text class="wg-field-label">图片</text>
            <view class="image-uploader">
              <block wx:if="{{workGroupDetailForm.images && workGroupDetailForm.images.length}}">
                <view class="image-thumb" bindtap="onWorkGroupDetailChooseImage">
                  <image class="image-thumb-img" src="{{workGroupDetailForm.images[0].url}}" mode="aspectFill" />
                  <text wx:if="{{activeWorkGroup.isOwner}}" class="image-thumb-action">更换</text>
                </view>
              </block>
              <view class="image-add" wx:if="{{activeWorkGroup.isOwner && (!workGroupDetailForm.images || !workGroupDetailForm.images.length)}}" bindtap="onWorkGroupDetailChooseImage">
                <text class="image-add-plus">+</text>
                <text class="image-add-text">上传</text>
              </view>
            </view>
          </view>
          <view class="wg-field">
            <text class="wg-field-label">工作组名称</text>
            <input class="wg-field-input" placeholder="请输入名称" value="{{workGroupDetailForm.name}}" bindinput="onWorkGroupDetailNameInput" disabled="{{!activeWorkGroup.isOwner}}" />
          </view>
          <view class="wg-field">
            <text class="wg-field-label">简介</text>
            <textarea class="wg-field-textarea" placeholder="请填写简介" value="{{workGroupDetailForm.description}}" bindinput="onWorkGroupDetailDescInput" maxlength="500" auto-height disabled="{{!activeWorkGroup.isOwner}}" />
          </view>
        </view>

      </scroll-view>
      <view class="wg-actions">
        <button class="footer-btn" bindtap="onExitWorkGroupTap" wx:if="{{!activeWorkGroup.isOwner}}">
          退出工作组
        </button>
        <view wx:if="{{activeWorkGroup.isOwner}}">
          <button class="footer-btn primary" loading="{{workGroupDetailSaving}}" disabled="{{workGroupDetailSaving}}" bindtap="onSaveWorkGroupDetail">
            保存
          </button>
          <button class="footer-btn danger" loading="{{workGroupDissolving}}" disabled="{{workGroupDissolving}}" bindtap="onDissolveWorkGroupTap">
            解散工作组
          </button>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{showWorkGroupInviteDialog}}" class="modal-overlay" catchtouchmove="noop">
    <view class="modal-mask" bindtap="onCloseWorkGroupInviteDialog"></view>
    <view class="modal-card">
      <view class="modal-header">
        <text class="modal-title">邀请成员</text>
        <view class="modal-close" bindtap="onCloseWorkGroupInviteDialog">×</view>
      </view>
      <view class="modal-body">
        <view class="modal-block">
          <text class="modal-block-title">输入用户低空码</text>
          <view class="modal-input-row">
            <input class="modal-input" placeholder="输入用户低空码" value="{{workGroupInviteInput}}" bindinput="onWorkGroupInviteInput" />
            <button class="modal-btn primary" loading="{{workGroupInviteSubmitting}}" disabled="{{workGroupInviteSubmitting}}" bindtap="onSubmitWorkGroupInvite">
              立即添加
            </button>
          </view>
        </view>
        <view class="modal-block">
          <text class="modal-block-title">发送微信邀请</text>
          <button class="modal-btn" open-type="share">发送邀请</button>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{showDissolveDialog}}" class="modal-overlay" catchtouchmove="noop">
    <view class="modal-mask" bindtap="onCloseDissolveDialog"></view>
    <view class="modal-card">
      <view class="modal-header">
        <text class="modal-title">解散工作组</text>
        <view class="modal-close" bindtap="onCloseDissolveDialog">×</view>
      </view>
      <view class="modal-body">
        <view class="field-row">
          <view class="field-label">
            <text>输入名称确认解散</text>
          </view>
          <input class="field-input form-input" placeholder="请输入工作组名称确认解散" value="{{workGroupDissolveInput}}" bindinput="onWorkGroupDissolveInput" />
        </view>
      </view>
      <view class="modal-footer">
        <button class="modal-btn" bindtap="onCloseDissolveDialog">取消</button>
        <button class="modal-btn primary" loading="{{workGroupDissolving}}" disabled="{{workGroupDissolving}}" bindtap="onConfirmDissolveWorkGroup">
          确认解散
        </button>
      </view>
    </view>
  </view>

  <view wx:if="{{activeCenterTab === 'MERCHANT' && showCreate}}" class="drawer-overlay">
    <view class="drawer">
      <view class="drawer-header">
        <text class="drawer-title">创建入驻信息</text>
        <view class="drawer-close" bindtap="onCloseCreate">✕</view>
      </view>
      <view class="drawer-step-indicator">
        <view class="step-indicator">
          <block wx:for="{{createSteps}}" wx:key="label">
            <view class="step-item-wrapper">
              <view class="step-item {{createStep === index ? 'is-current' : (createStep > index ? 'is-finished' : '')}} {{resultStepsLocked && index < 3 ? 'is-disabled' : ''}}" data-step="{{index}}" bindtap="onStepIndicatorTap">
                <view class="step-circle {{createStep === index ? 'is-active' : (createStep > index ? 'is-finished' : '')}}">
                  <text>{{index + 1}}</text>
                </view>
                <text class="step-label">{{item.label}}</text>
              </view>
              <view wx:if="{{index < createSteps.length - 1}}" class="step-connector {{createStep > index ? 'is-active' : ''}}"></view>
            </view>
          </block>
        </view>
      </view>

      <scroll-view scroll-y class="drawer-body">
        <block wx:if="{{createStep === 0}}">
          <view class="form-card">
            <view class="field-row">
              <view class="field-label required">
                <text class="required-star">*</text>
                <text>门店（服务）图片</text>
              </view>
              <view class="image-uploader">
                <block wx:for="{{form.images}}" wx:key="fileName">
                  <view class="image-thumb">
                    <image class="image-thumb-img" src="{{item.url}}" mode="aspectFill" />
                    <view class="image-remove" data-type="images" data-index="{{index}}" bindtap="onRemoveMediaTap">✕</view>
                  </view>
                </block>
                <view class="image-add" data-type="images" bindtap="onAddMediaTap">
                  <image class="image-add-icon" src="{{assetPaths.add}}" mode="aspectFit" />
                  <text class="image-add-text">上传</text>
                </view>
              </view>
            </view>

            <view class="field-row">
              <view class="field-label required">
                <text class="required-star">*</text>
                <text>商户（门店）名称</text>
              </view>
              <input class="field-input form-input" placeholder="请输入" value="{{form.name}}" data-field="name" bindinput="onFormInput" />
              <view class="field-tip">最多输入20个汉字或字符</view>
            </view>

            <view class="field-row">
              <view class="field-label required">
                <text class="required-star">*</text>
                <text>业务简介</text>
              </view>
              <textarea class="field-textarea form-textarea" placeholder="请输入" value="{{form.description}}" data-field="description" bindinput="onFormInput" maxlength="500" auto-height />
            </view>

            <view class="field-row">
              <view class="field-label required">
                <text class="required-star">*</text>
                <text>门店（服务）位置</text>
              </view>
              <view class="location-box location-selector" bindtap="onChooseLocation">
                <text class="location-text">{{form.locationText || '点击选择'}}</text>
              </view>
            </view>

            <view class="field-row">
              <view class="field-label required">
                <text class="required-star">*</text>
                <text>商家电话</text>
              </view>
              <input class="field-input form-input" placeholder="请输入联系电话" value="{{form.phone}}" data-field="phone" bindinput="onFormInput" />
            </view>
          </view>
        </block>

        <block wx:elif="{{createStep === 1}}">
          <view class="form-card">
            <view class="field-label required">
              <text class="required-star">*</text>
              <text>营业执照</text>
            </view>
            <view class="field-tip">个人可提供执照、技能证书等</view>
            <view class="media-grid">
              <block wx:if="{{form.businessLicense}}">
                <view class="media-item">
                  <image class="media-image" src="{{form.businessLicense.url}}" mode="aspectFill" />
                  <view class="media-remove" data-type="businessLicense" bindtap="onRemoveMediaTap">✕</view>
                </view>
              </block>
              <view class="media-add" data-type="businessLicense" bindtap="onAddMediaTap" wx:if="{{!form.businessLicense}}">
                <text class="media-add-icon">＋</text>
                <text class="media-add-text">上传执照</text>
              </view>
            </view>
          </view>

          <view class="form-card decoration-card {{!merchantCertified ? 'is-locked' : ''}}">
            <view class="decoration-card-header" bindtap="onToggleMerchantDecoration">
              <view class="decoration-card-title-group">
                <text class="field-label">店铺主页装修</text>
                <text class="decoration-card-status {{merchantCertified ? 'is-certified' : 'is-locked'}}">
                  <text class="decoration-card-status-text">{{merchantCertified ? '已认证' : '未认证'}}</text>
                </text>
              </view>
              <image
                class="decoration-card-arrow"
                src="{{merchantDecorationExpanded ? assetPaths.collapse : assetPaths.expand}}"
                mode="aspectFit"
              />
            </view>
            <view wx:if="{{merchantDecorationExpanded}}" class="decoration-card-body">
              <view wx:if="{{!merchantCertified}}" class="decoration-card-lock-tip">
                认证入驻后可继续完善行业标签、产品业务资料、体验二维码和视频号内容
              </view>

              <view class="field-block">
                <view class="field-label">行业荣誉标签</view>
                <view class="field-tip">如高新技术企业、培训资质、行业关键词</view>
                <view class="tag-editor {{!merchantCertified ? 'is-disabled' : ''}}">
                  <block wx:for="{{form.industryHonorTags}}" wx:key="*this">
                    <view class="tag-chip">
                      <text>{{item}}</text>
                      <view wx:if="{{merchantCertified}}" class="tag-remove" data-index="{{index}}" bindtap="onRemoveTag">✕</view>
                    </view>
                  </block>
                  <input
                    class="tag-input"
                    placeholder="输入后回车添加"
                    value="{{tagInput}}"
                    confirm-type="done"
                    bindinput="onTagInput"
                    bindconfirm="onTagConfirm"
                    disabled="{{!merchantCertified}}"
                  />
                </view>
              </view>

              <view class="field-block">
                <view class="field-label">产品业务资料</view>
                <view class="field-tip">请先将文件发送到微信文件传输助手对话框，再点击“上传（PPT/PDF）”。</view>
                <view class="attachment-list">
                  <block wx:for="{{form.attachmentFiles}}" wx:key="fileName">
                    <view class="attachment-item">
                      <text class="attachment-icon">📎</text>
                      <text class="attachment-name">{{item.label || '产品业务资料'}}</text>
                      <view wx:if="{{merchantCertified}}" class="attachment-remove" data-type="attachments" data-index="{{index}}" bindtap="onRemoveMediaTap">删除</view>
                    </view>
                  </block>
                  <view wx:if="{{form.attachmentFiles.length < 1}}" class="attachment-add {{!merchantCertified ? 'is-disabled' : ''}}" data-type="attachments" bindtap="onAddMediaTap">上传（PPT/PDF）</view>
                </view>
              </view>

              <view class="field-block">
                <view class="field-label">产品体验二维码</view>
                <view class="media-grid">
                  <block wx:for="{{form.qrCodeImages}}" wx:key="fileName">
                    <view class="media-item">
                      <image class="media-image" src="{{item.url}}" mode="aspectFill" />
                      <view wx:if="{{merchantCertified}}" class="media-remove" data-type="qrCodeImages" data-index="{{index}}" bindtap="onRemoveMediaTap">✕</view>
                    </view>
                  </block>
                  <view wx:if="{{form.qrCodeImages.length < qrCodeMaxCount}}" class="media-add {{!merchantCertified ? 'is-disabled' : ''}}" data-type="qrCodeImages" bindtap="onAddMediaTap">
                    <text class="media-add-icon">＋</text>
                    <text class="media-add-text">上传二维码</text>
                  </view>
                </view>
              </view>

              <view class="field-block">
                <view class="field-label">挂载视频号视频</view>
                <view class="video-form">
                  <view class="video-field">
                    <text class="video-field-label">视频号ID</text>
                    <input class="field-input form-input" placeholder="请输入" value="{{form.videoChannelId}}" data-field="videoChannelId" bindinput="onFormInput" disabled="{{!merchantCertified}}" />
                  </view>
                  <view class="video-field">
                    <text class="video-field-label">视频ID</text>
                    <input class="field-input form-input" placeholder="请输入" value="{{form.videoId}}" data-field="videoId" bindinput="onFormInput" disabled="{{!merchantCertified}}" />
                  </view>
                </view>
              </view>
            </view>
          </view>
        </block>

        <block wx:elif="{{createStep === 2}}">
          <view class="form-card">
            <view class="field-label required">
              <text class="required-star">*</text>
              <text>管理员信息</text>
            </view>
            <text class="field-tip">不对外展示，仅用于审核等重要通知</text>
            <view class="admin-grid">
              <input class="field-input form-input" placeholder="姓名" value="{{form.adminInfo.name}}" data-group="adminInfo" data-field="name" bindinput="onFormInput" />
              <input class="field-input form-input" placeholder="联系电话" value="{{form.adminInfo.phone}}" data-group="adminInfo" data-field="phone" bindinput="onFormInput" />
            </view>
          </view>

          <view class="form-card merchant-entry-card">
            <view class="merchant-entry-card-shell {{activeMerchantEntryTab === 'FREE' ? 'is-free' : 'is-certified'}}">
              <view class="merchant-entry-card-skin-stack">
                <image
                  class="merchant-entry-card-skin merchant-entry-card-skin-top"
                  src="{{activeMerchantEntryTab === 'FREE' ? assetPaths.tabSkinCheckLeftTop : assetPaths.tabSkinCheckRightTop}}"
                  mode="widthFix"
                />
                <view class="merchant-entry-card-skin-middle-fill"></view>
                <image
                  class="merchant-entry-card-skin merchant-entry-card-skin-bottom"
                  src="{{activeMerchantEntryTab === 'FREE' ? assetPaths.tabSkinCheckLeftBottom : assetPaths.tabSkinCheckRightBottom}}"
                  mode="widthFix"
                />
              </view>
              <view class="merchant-entry-card-content">
                <view class="merchant-entry-tabs {{merchantCertified ? 'is-locked' : ''}}">
                  <block wx:for="{{merchantEntryTabs}}" wx:key="id">
                    <view
                    class="merchant-entry-tab {{activeMerchantEntryTab === item.id ? 'is-active' : ''}} {{item.id === 'FREE' ? 'is-left' : 'is-right'}} {{merchantCertified && item.id !== 'CERTIFIED' ? 'is-disabled' : ''}}"
                    data-tab="{{item.id}}"
                    bindtap="onMerchantEntryTabTap"
                  >
                    <view class="merchant-entry-tab-inner {{item.id === 'CERTIFIED' ? 'merchant-entry-tab-inner--certified' : ''}}">
                      <image wx:if="{{item.id === 'CERTIFIED'}}" class="merchant-entry-tab-icon merchant-entry-tab-icon--certified" src="{{assetPaths.svip}}" mode="aspectFit" />
                      <text wx:if="{{item.label}}" class="merchant-entry-tab-label">{{item.label}}</text>
                    </view>
                  </view>
                </block>
              </view>

              <view wx:if="{{activeMerchantEntryTab === 'FREE'}}" class="merchant-entry-panel free-mode">
                <view wx:if="{{merchantIntroLongImageLoading}}" class="merchant-entry-placeholder">加载中...</view>
                <view wx:elif="{{merchantIntroLongImageError && !merchantIntroLongImageUrl}}" class="merchant-entry-placeholder is-error">{{merchantIntroLongImageError}}</view>
                <image
                  wx:elif="{{merchantIntroLongImageUrl}}"
                  class="merchant-intro-long-image"
                  src="{{merchantIntroLongImageUrl}}"
                  mode="widthFix"
                  bindtap="onPreviewMerchantIntroLongImage"
                />
              </view>

              <view wx:elif="{{showPaymentSection}}" class="merchant-entry-panel">
                <view class="field-label required">
                  <text class="required-star">*</text>
                  <text>支付认证费</text>
                </view>
                <text wx:if="{{paymentPromptMessage}}" class="field-tip">{{paymentPromptMessage}}</text>
                <view class="payment-options">
                  <block wx:for="{{paymentMethods}}" wx:key="id">
                    <view class="payment-option {{selectedPaymentMethod === item.id ? 'is-active' : ''}} {{item.id === 'FLP' && flpPaymentDisabled ? 'is-disabled' : ''}}" data-method="{{item.id}}" bindtap="onSelectPaymentMethod">
                      <view class="payment-option-header">
                        <text class="payment-option-title">{{item.label}}</text>
                        <text class="payment-option-note" wx:if="{{item.id === 'FLP'}}">{{flpPaymentNote}}</text>
                        <text class="payment-option-note" wx:elif="{{item.note}}">{{item.note}}</text>
                      </view>
                      <view class="payment-price" wx:if="{{item.id === 'WECHAT'}}">
                        <text class="price-tag">{{wechatPriceDisplay || '¥--'}}</text>
                        <text class="price-original" wx:if="{{wechatListPriceDisplay}}">{{wechatListPriceDisplay}}</text>
                      </view>
                      <view class="payment-price" wx:elif="{{item.id === 'FLP'}}">
                        <text class="price-tag">{{flpPriceDisplay || 'FLP--'}}</text>
                        <text class="price-original" wx:if="{{flpListPriceDisplay}}">{{flpListPriceDisplay}}</text>
                      </view>
                    </view>
                  </block>
                </view>
              </view>

                <view wx:else class="merchant-entry-panel">
                  <view class="field-label">
                    <text>认证状态</text>
                  </view>
                  <view class="field-tip field-tip-inline">
                    <text>{{paymentStatusMessage}}</text>
                    <text class="field-tip-link" bindtap="onPaymentDecorationLinkTap">修改店铺装修信息</text>
                  </view>
                </view>
              </view>
            </view>
          </view>

          <block wx:if="{{creationError}}">
            <view class="error-box">{{creationError}}</view>
          </block>
        </block>

        <block wx:elif="{{createStep === 3}}">
          <view class="result-card" wx:if="{{creationResult && creationResult.status === 'success'}}">
            <view class="result-icon success">✓</view>
            <text class="result-title">{{creationResult.title || '提交成功'}}</text>
            <text class="result-desc">{{creationResult.message}}</text>
          <view class="result-info">
              <text>商户名称：{{creationResult.marker.name}}</text>
          </view>
            <button class="result-btn" bindtap="onCloseCreate">完成</button>
          </view>
          <view class="result-card error" wx:elif="{{creationError}}">
            <view class="result-icon error">!</view>
            <text class="result-title">提交失败</text>
            <text class="result-desc">{{creationError}}</text>
            <button class="result-btn" bindtap="goToPrevStep">返回修改</button>
          </view>
        </block>
      </scroll-view>

      <view class="drawer-footer" wx:if="{{createStep < 3}}">
        <button
          class="support-btn"
          open-type="contact"
          bindcontact="onCustomerServiceContact"
          session-from="{{customerServiceSessionFrom}}"
        >
          <image class="support-btn-icon" src="/pages/markers/assets/support.png" mode="aspectFit" />
        </button>
        <view class="footer-actions">
          <button class="footer-btn secondary" wx:if="{{createStep > 0}}" bindtap="goToPrevStep">上一步</button>
          <block wx:if="{{createStep === 2}}">
            <button class="footer-btn primary" bindtap="submitMarker" loading="{{creationSubmitting}}" disabled="{{creationSubmitting}}">
              {{submitButtonText}}
            </button>
          </block>
          <block wx:else>
            <button class="footer-btn primary" bindtap="goToNextStep">下一步</button>
          </block>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{activeCenterTab === 'MY_MARKERS' && showMyPinCreate}}" class="drawer-overlay">
    <view class="drawer">
      <view class="drawer-header">
        <text class="drawer-title">创建地图标记</text>
        <view class="drawer-close" bindtap="onCloseMyPinCreate">✕</view>
      </view>
      <scroll-view scroll-y class="drawer-body">
        <view class="form-card">
          <view class="field-row pin-field">
            <view class="field-label required">
              <text class="required-star">*</text>
              <text>开始标记</text>
              <text wx:if="{{myPinFormConfigured}}" class="pin-configured-hint">(已配置)</text>
            </view>
            <view class="pin-selector {{myPinForm.kmlLocked ? 'is-locked' : ''}}" bindtap="onPinPickerTap">
              <view class="pin-selector-main">
                <image class="pin-selector-icon" src="{{myPinForm.geometryIcon || '/assets/default.png'}}" mode="aspectFit" />
                <text class="pin-selector-text">{{myPinForm.geometryName || '通用'}}</text>
              </view>
              <view class="pin-selector-side" wx:if="{{!myPinForm.kmlLocked}}">
                <text class="pin-selector-placeholder">请选择类型</text>
                <image class="pin-selector-arrow-img" src="/assets/arrow-right.png" mode="aspectFit" />
              </view>
            </view>
            <view wx:if="{{myPinFormConfigured && pinLocationDisplay}}" class="pin-location-hint">
              <text class="pin-location-text">{{pinLocationDisplay}}</text>
            </view>
          </view>
          <view class="field-row">
            <view class="field-label">
              <text>图片/视频</text>
              <text wx:if="{{pinVideoUploadFlpLimitDisplay}}" class="pin-video-flp-hint">（FLP>{{pinVideoUploadFlpLimitDisplay}}可上传高清视频）</text>
            </view>
            <view class="my-pin-media-grid">
              <block wx:for="{{myPinForm.images}}" wx:key="fileName">
                <view class="my-pin-media">
                  <image class="my-pin-media-img" src="{{item.url}}" mode="aspectFill" />
                  <view class="my-pin-media-remove" data-index="{{index}}" data-type="image" bindtap="onRemovePinMediaTap">×</view>
                </view>
              </block>
              <view wx:if="{{myPinForm.video || pinVideoUploading}}" class="my-pin-media my-pin-media-video">
                <block wx:if="{{myPinForm.video}}">
                <video
                  id="pin-form-video"
                  class="my-pin-media-video-player"
                  src="{{myPinForm.video.url}}"
                  poster="{{myPinForm.video.poster}}"
                  object-fit="cover"
                  autoplay="{{true}}"
                  muted="{{true}}"
                  loop="{{true}}"
                  show-center-play-btn="{{false}}"
                  show-play-btn="{{false}}"
                  controls="{{false}}"
                  enable-progress-gesture="{{false}}"
                  bindwaiting="onPinVideoWaiting"
                  bindplay="onPinVideoReady"
                  bindloadeddata="onPinVideoReady"
                />
                <view
                  class="video-fullscreen-hit"
                  catchtap="onInlineVideoTap"
                  data-url="{{myPinForm.video.url}}"
                  data-poster="{{myPinForm.video.poster}}"
                  data-video-id="pin-form-video"
                ></view>
                <view wx:if="{{pinVideoLoading}}" class="video-loading-mask">
                  <text class="video-loading-text">加载中...</text>
                </view>
                <view class="my-pin-media-video-tag">视频</view>
                <view class="my-pin-media-remove" data-type="video" bindtap="onRemovePinMediaTap">×</view>
                </block>
                <block wx:else>
                  <view class="my-pin-media-uploading">
                    <text class="my-pin-media-uploading-title">视频上传中</text>
                    <text class="my-pin-media-uploading-progress">{{pinVideoUploadProgress}}%</text>
                    <view class="my-pin-media-progress-track">
                      <view class="my-pin-media-progress-bar" style="width: {{pinVideoUploadProgress}}%;"></view>
                    </view>
                  </view>
                </block>
              </view>
              <view wx:if="{{(myPinForm.images.length + ((myPinForm.video || pinVideoUploading) ? 1 : 0)) < 3}}" class="my-pin-media-add" bindtap="onAddPinMediaTap">
                <view class="my-pin-media-plus">+</view>
                <text class="my-pin-media-add-text">上传</text>
              </view>
            </view>
          </view>
          <view class="field-row">
            <view class="field-label required">
              <text class="required-star">*</text>
              <text>名称</text>
            </view>
            <input class="field-input form-input" placeholder="请输入名称" value="{{myPinForm.name}}" bindinput="onPinNameInput" />
            <view class="field-tip">最多输入20个汉字或字符</view>
          </view>
          <view class="field-row">
            <view class="field-label">
              <text>简介</text>
            </view>
            <textarea class="field-textarea form-textarea" placeholder="请输入简介" value="{{myPinForm.description}}" bindinput="onPinDescInput" maxlength="300" auto-height />
          </view>
          <view class="field-row">
            <view class="field-label">
              <text>工作组</text>
            </view>
            <view class="workgroup-selector">
              <!-- <view class="stat-phone-pill {{item.hasWorkGroup ? 'is-workgroup' : 'is-private'}}" wx:if="{{activeCenterTab === 'MY_MARKERS' && item.scope !== 'PUBLIC'}}" bindtap="onOpenWorkGroupPickerForCreate" data-id="{{item.id}}">
                <block wx:if="{{item.hasWorkGroup}}">
                  <image class="pill-icon" src="{{item.workGroupCoverImage || assetPaths.workGroup}}" mode="aspectFill" lazy-load="true" />
                  <text class="pill-name">
                    {{item.workGroupDisplayName}}
                  </text>
                  <text class="pill-count">({{item.workGroupMemberCount || 0}})</text>
                  <image class="pill-arrow" src="{{assetPaths.arrowRight}}" mode="aspectFit" />
                </block>
                <block wx:else>
                  <image class="pill-icon" src="{{assetPaths.workGroup}}" mode="aspectFit" />
                </block>
              </view> -->
              <view wx:if="{{!myPinForm.publishToPlatform}}" class="stat-phone-pill is-workgroup" bindtap="onOpenWorkGroupPickerForCreate"> 
                <block wx:if="{{myPinSelectedGroups && myPinSelectedGroups.length}}">
                  <view class="pill-icon">
                    <image  src="{{myPinSelectedGroups[0].coverImage || assetPaths.workGroup}}" mode="aspectFit" />
                  </view>
                  <text class="pill-name">{{myPinSelectedGroups[0].name || '工作组'}}</text>
                  <text class="pill-count">({{myPinSelectedGroups[0].memberCount || 0}})</text>
                  <image class="pill-arrow" src="{{assetPaths.arrowRight}}" mode="aspectFit" />
                </block>
                <block wx:else>
                  <image class="pill-icon" src="{{assetPaths.workGroup}}" mode="aspectFit" />
                </block>
              </view>
              <text wx:else class="workgroup-disabled-text">发布状态不可设置</text>
            </view>
            </view>
            <view class="field-row pin-publish-row">
              <view class="field-label">
                <text>发布到平台（需审核）</text>
              </view>
              <view class="publish-toggle">
                <switch checked="{{myPinForm.publishToPlatform}}" bindchange="onPinPublishToggle" color="#111111" style="transform: scale(0.82); transform-origin: center;" />
              </view>
            </view>
          </view>
      </scroll-view>
      <view class="drawer-footer">
        <button class="footer-btn primary" loading="{{pinSubmitting}}" disabled="{{pinSubmitting}}" bindtap="onSubmitPinForm">
          确认
        </button>
      </view>
    </view>
  </view>

  <block wx:if="{{publishPlatformDialogVisible}}">
    <view class="modal-overlay" catchtouchmove="noop">
      <view class="modal-mask" bindtap="onPublishPlatformCancel"></view>
      <view class="modal-card.share publish-platform-card">
        <view class="modal-header">
          <view class="modal-close.share" bindtap="onPublishPlatformCancel">×</view>
        </view>
        <image class="publish-platform-banner" src="/pages/markers/assets/release-to-map.png" mode="widthFix" />
        <text class="modal-title-share">共享到平台</text>
        <scroll-view class="modal-body publish-platform-body share" scroll-y="true" enhanced="true" show-scrollbar="false">
          <text wx:if="{{publishPlatformDialogLoading}}" class="publish-platform-state">加载中...</text>
          <text wx:elif="{{publishPlatformDialogError}}" class="publish-platform-state is-error">{{publishPlatformDialogError}}</text>
          <block wx:elif="{{publishPlatformDialogSegments.length}}">
            <block wx:for="{{publishPlatformDialogSegments}}" wx:key="index">
              <rich-text
                wx:if="{{item.type === 'rich'}}"
                class="publish-platform-richtext"
                nodes="{{item.nodes}}"
                selectable="true"
                space="nbsp"
                bindtap="onPublishPlatformRichTextTap"
              />
              <image
                wx:elif="{{item.type === 'image'}}"
                class="publish-platform-rich-image"
                src="{{item.src}}"
                mode="widthFix"
                show-menu-by-longpress="true"
                data-index="{{item.index}}"
                bindtap="onPublishPlatformImageTap"
              />
            </block>
          </block>
          <rich-text
            wx:else
            class="publish-platform-richtext"
            nodes="{{publishPlatformDialogNodes}}"
            selectable="true"
            space="nbsp"
            bindtap="onPublishPlatformRichTextTap"
          />
        </scroll-view>
        <view class="publish-platform-actions">
          <button class="publish-platform-btn primary" bindtap="onPublishPlatformConfirm">确定</button>
          <button class="publish-platform-btn secondary" bindtap="onPublishPlatformCancel">取消</button>
        </view>
      </view>
    </view>
  </block>

  <block wx:if="{{showKmlTips}}">
    <view class="kml-tips-dialog-overlay" catchtouchmove="noop" catchtap="noop">
      <view class="kml-tips-dialog-container">
        <view class="kml-tips-dialog-card">
          <text class="kml-tips-dialog-text" decode="true">受限于小程序性能，KML/KMZ功能暂仅支持导入导出<text class="kml-tips-dialog-text-highlight" decode="true">（&lt;1M）</text>。</text>
          <view class="kml-tips-dialog-btn" catchtap="onCloseKmlTips">我知道了</view>
        </view>
      </view>
    </view>
  </block>

  <block wx:if="{{rejectReasonDialogVisible}}">
    <view class="reject-reason-dialog-overlay" catchtouchmove="noop" catchtap="onCloseRejectReasonDialog">
      <view class="reject-reason-dialog-container" catchtap="noop">
        <view class="reject-reason-dialog-card">
          <text class="reject-reason-dialog-title">{{rejectReasonDialogTitle || '驳回理由'}}</text>
          <text class="reject-reason-dialog-text">{{rejectReasonDialogMessage}}</text>
          <text class="reject-reason-dialog-note">{{rejectReasonDialogNote}}</text>
          <view class="reject-reason-dialog-btn" catchtap="onCloseRejectReasonDialog">我知道了</view>
        </view>
      </view>
    </view>
  </block>

  <block wx:if="{{showPinCreateSheet}}">
    <view class="pin-create-sheet-overlay" catchtouchmove="noop">
      <view class="pin-create-sheet-mask" bindtap="onClosePinCreateSheet"></view>
      <view class="pin-create-sheet">
        <view class="pin-create-sheet-handle"></view>
        <view class="pin-create-sheet-item" bindtap="onPinCreateDirect">
          <text class="pin-create-sheet-title">直接创建</text>
        </view>
        <view class="pin-create-sheet-divider"></view>
        <view class="pin-create-sheet-item" bindtap="onPinCreateKml">
          <view class="pin-create-sheet-row">
            <text class="pin-create-sheet-title">通过KML/KMZ文件创建（仅微信）</text>
            <view class="pin-create-sheet-tip" catchtap="onKmlTipsTap">
              <image class="pin-create-sheet-tip-icon" src="{{assetPaths.tips}}" mode="aspectFit" />
            </view>
          </view>
        </view>
      </view>
    </view>
  </block>

  <block wx:if="{{deleteDialogVisible}}">
    <view class="delete-dialog-overlay" catchtouchmove="noop">
      <view class="delete-dialog-mask" bindtap="onDeleteDialogCancel"></view>
      <view class="delete-dialog-card" catchtouchmove="noop">
        <text class="delete-dialog-title">删除标记</text>
        <text class="delete-dialog-desc">
          为防误删，请输入标记全称：
          <text class="delete-dialog-name">{{deleteDialogMarkerName}}</text>
        </text>
        <input class="delete-dialog-input" placeholder="{{deleteDialogMarkerName}}" value="{{deleteDialogInput}}" bindinput="onDeleteDialogInput" />
        <text wx:if="{{deleteDialogError}}" class="delete-dialog-error">{{deleteDialogError}}</text>
        <view class="delete-dialog-actions">
          <button class="delete-dialog-btn delete-dialog-btn--secondary" bindtap="onDeleteDialogCancel">
            取消
          </button>
          <button class="delete-dialog-btn delete-dialog-btn--primary" bindtap="onDeleteDialogConfirm">
            删除
          </button>
        </view>
      </view>
    </view>
  </block>

  <block wx:if="{{actionSheetVisible && activeCenterTab === 'MY_MARKERS'}}">
    <view class="action-sheet-overlay" catchtouchmove="noop">
      <view class="action-sheet-mask" bindtap="onActionSheetCancel" catchtouchmove="noop"></view>
      <view class="action-sheet-container" catchtap="noop" catchtouchmove="noop">
        <view class="action-sheet-card action-sheet-card-my">
          <block wx:if="{{actionSheetPrimaryOption}}">
            <view class="action-sheet-item action-sheet-item-my {{!actionSheetPrimaryOption.enabled ? 'action-sheet-item-disabled' : ''}}" data-action="{{actionSheetPrimaryOption.action}}" bindtap="onActionSheetAction">
              <view class="action-sheet-icon-box">
                <image class="action-sheet-icon" src="{{actionSheetPrimaryOption.icon}}" mode="aspectFit" />
              </view>
              <text class="action-sheet-label">{{actionSheetPrimaryOption.label}}</text>
              <text wx:if="{{actionSheetPrimaryOption.note}}" class="action-sheet-note">{{actionSheetPrimaryOption.note}}</text>
            </view>
          </block>
          <block wx:for="{{actionSheetSecondaryOptions}}" wx:key="action">
            <view class="action-sheet-item action-sheet-item-my {{!item.enabled ? 'action-sheet-item-disabled' : ''}}" data-action="{{item.action}}" bindtap="onActionSheetAction">
              <text class="action-sheet-label action-sheet-label--single">{{item.label}}</text>
              <text wx:if="{{item.note}}" class="action-sheet-note">{{item.note}}</text>
            </view>
          </block>
        </view>
        <view class="action-sheet-card action-sheet-card-cancel">
          <view class="action-sheet-item action-sheet-item-cancel" data-action="cancel" bindtap="onActionSheetAction">
            取消
          </view>
        </view>
      </view>
    </view>
  </block>

  <block wx:elif="{{actionSheetVisible}}">
    <view class="action-sheet-overlay" catchtouchmove="noop">
      <view class="action-sheet-mask" bindtap="onActionSheetCancel" catchtouchmove="noop"></view>
      <view class="action-sheet-container" catchtap="noop" catchtouchmove="noop">
        <view class="action-sheet-card">
          <view class="action-sheet-item" data-action="home" bindtap="onActionSheetAction">主页预览</view>
          <view class="action-sheet-item" data-action="detail" bindtap="onActionSheetAction">详情</view>
          <view class="action-sheet-item {{actionSheetDisableModify ? 'action-sheet-item-disabled' : ''}}" data-action="edit" bindtap="onActionSheetAction">
            编辑
          </view>
          <view class="action-sheet-item action-sheet-item-danger {{actionSheetDisableModify ? 'action-sheet-item-disabled' : ''}}" data-action="delete" bindtap="onActionSheetAction">
            删除
          </view>
        </view>
        <view class="action-sheet-card action-sheet-card-cancel">
          <view class="action-sheet-item action-sheet-item-cancel" data-action="cancel" bindtap="onActionSheetAction">
            取消
          </view>
        </view>
      </view>
    </view>
  </block>

  <block wx:if="{{pinConfirmVisible}}">
    <view class="confirm-overlay" catchtouchmove="noop">
      <view class="confirm-mask" bindtap="onPinConfirmCancel"></view>
      <view class="confirm-card">
        <text class="confirm-title">提示</text>
        <text class="confirm-message">{{pinConfirmMessage}}</text>
        <view class="confirm-actions">
          <button class="confirm-btn confirm-btn--secondary" bindtap="onPinConfirmCancel" disabled="{{pinConfirmBusy}}">
            取消
          </button>
          <button class="confirm-btn confirm-btn--primary" bindtap="onPinConfirmProceed" disabled="{{pinConfirmBusy}}">
            确认
          </button>
        </view>
      </view>
    </view>
  </block>

  <view wx:if="{{joinInvitePrompt}}" class="invite-overlay" catchtouchmove="noop">
    <view class="invite-mask"></view>
    <view class="invite-card">
      <view class="invite-title">加入工作组</view>
      <view class="invite-body">
        <text class="invite-text">是否加入工作组：{{joinInvitePrompt.groupName || joinInvitePrompt.groupId || '--'}}</text>
        <text class="invite-tip">确认后将加入该工作组并同步标记协同</text>
      </view>
      <view class="invite-footer">
        <button class="invite-btn secondary" bindtap="cancelJoinWorkGroup" disabled="{{joinInviting}}">
          取消
        </button>
        <button
          class="invite-btn primary"
          disabled="{{joinInviting}}"
          loading="{{joinInviting}}"
          data-invitation-code="{{joinInvitePrompt.invitationCode}}"
          data-group-id="{{joinInvitePrompt.groupId}}"
          data-group-name="{{joinInvitePrompt.groupName}}"
          bindtap="confirmJoinWorkGroup"
        >
          确认加入
        </button>
      </view>
    </view>
  </view>
</view>




