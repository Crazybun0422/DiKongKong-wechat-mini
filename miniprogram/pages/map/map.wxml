<view class="page">
  <view class="map-wrap">
    <map
      id="main-map"
      class="map-canvas"
      longitude="{{center.longitude}}"
      latitude="{{center.latitude}}"
      scale="{{scale}}"
      min-scale="{{minScale}}"
      max-scale="{{maxScale}}"
      subkey="{{mapSubKey}}"
      layer-style="1"
      enable-satellite="{{enableSatellite}}"
      show-location="true"
      markers="{{markers}}"
      polygons="{{polygons}}"
      circles="{{circles}}"
      bindregionchange="onRegionChange"
      bindupdated="onMapUpdated"
      bindmarkertap="onMarkerTap"
      bindcallouttap="onMarkerCalloutTap"
    />
    <!-- <cover-view class="uom-dialog" wx:if="{{uomTileWarningVisible}}">
      <cover-view class="uom-dialog-box">
        <cover-view class="uom-dialog-text">受地图组件能力限制，本页部分地图功能暂不可用。
👉 完整功能已在微信小程序 「低空星球」 上线，欢迎前往使用。</cover-view>
        <cover-view class="uom-dialog-action">
          <cover-view
            class="uom-dialog-btn"
            hover-class="uom-dialog-btn--hover"
            bindtap="onUomTileWarningNever"
          >
            不再提示
          </cover-view>
        </cover-view>
      </cover-view>
    </cover-view> -->
    <image
      class="center-pin {{mapLayerType === 'satellite' ? 'center-pin--satellite' : ''}}"
      src="/assets/position.png"
      mode="widthFix"
    />
    <view class="map-scale" wx:if="{{scaleBarVisible}}">
      <text class="map-scale-label">{{scaleBarLabel}}</text>
      <view class="map-scale-track" style="width: {{scaleBarWidthRpx}}rpx;">
        <view class="map-scale-line"></view>
        <view class="map-scale-tick map-scale-tick-start"></view>
        <view class="map-scale-tick map-scale-tick-end"></view>
      </view>
    </view>

    <view class="preflight-overlay" wx:if="{{showDashboardPanel}}">
      <view class="preflight-card">
        <view class="preflight-title">飞前安全准备</view>
        <view class="drone-picker-block">
          <!-- <view class="drone-description">
            <text class="drone-description-title">此次执飞的无人机型号</text>
            <text class="drone-description-subtitle">不同机型在飞行高度/区域、报备有差异。</text>
          </view> -->
          <view class="drone-picker-display" bindtap="openDronePicker">
            <text class="preflight-label">执飞机型：</text>
            <text class="drone-picker-value picker-underline">{{selectedDroneName}}</text>
          </view>
        </view>
        <view class="preflight-row temporary-no-fly-row">
          <text class="preflight-label">临时禁飞区：</text>
          <block wx:if="{{temporaryNoFlyZoneInfo}}">
            <view class="temporary-no-fly-content">
              <image class="temporary-no-fly-icon" src="/assets/alarm.png" mode="widthFix" />
              <view
                wx:if="{{temporaryNoFlyZoneInfo.hasLink}}"
                class="temporary-no-fly-link"
                hover-class="temporary-no-fly-link-hover"
                bindtap="onTemporaryZoneLinkTap"
                data-link="{{temporaryNoFlyZoneInfo.link}}"
                data-path="{{temporaryNoFlyZoneInfo.linkPath}}"
              >
                {{temporaryNoFlyZoneInfo.displayName}}
              </view>
              <text wx:else class="temporary-no-fly-name">{{temporaryNoFlyZoneInfo.displayName}}</text>
            </view>
          </block>
          <text class="preflight-value {{'tone-' + temporaryNoFlyTone}}" wx:else>{{temporaryNoFlyText}}</text>
        </view>
        <view class="preflight-row">
          <text class="preflight-label">位于UOM划分：</text>
          <text class="preflight-value {{'tone-' + uomTone}}">{{uomStatus}}</text>
        </view>
        <view class="preflight-row">
          <text class="preflight-label">位于大疆划分：</text>
          <text class="preflight-value {{'tone-' + djiTone}}" style="color: {{djiColor || ''}};">{{djiStatus}}</text>
        </view>
        <text class="preflight-extra" wx:if="{{djiStatusExtra}}">{{djiStatusExtra}}</text>
        <text
          class="center-pin-indicator"
          wx:if="{{centerPinTitle}}"
          bindtap="onCenterPinIndicatorTap"
        >
          {{centerPinTitle}}
        </text>

        <view class="control-row">
          <view class="search-stack">
            <view class="search-pill">
              <input
                class="search-field"
                type="text"
                placeholder="搜索"
                placeholder-style="color:#f1f1f1"
                value="{{keyword}}"
                bindinput="onKeywordInput"
                confirm-type="search"
                bindconfirm="onSearchConfirm"
              />
              <button
                class="search-btn"
                hover-class="search-btn-hover"
                hover-start-time="10"
                hover-stay-time="80"
                bindtap="onSearchTap"
              >
                <image class="search-btn-icon" src="/assets/search.png" mode="aspectFit" />
              </button>
            </view>
            <view class="search-suggest-panel" wx:if="{{searchSuggestions.length || searchSuggestLoading || searchSuggestError}}">
              <view class="search-suggest-state" wx:if="{{searchSuggestLoading}}">搜索中...</view>
              <view class="search-suggest-state" wx:elif="{{searchSuggestError}}">{{searchSuggestError}}</view>
              <scroll-view scroll-y="true" class="search-suggest-scroll" wx:else>
                <block wx:for="{{searchSuggestions}}" wx:key="id">
                  <view
                    class="search-suggest-item"
                    data-index="{{index}}"
                    bindtap="onSuggestionTap"
                  >
                    <text class="suggest-title {{item.source === 'marker' ? 'suggest-title-marker' : ''}}">
                      {{item.source === 'marker' ? (item.title || '') + '（低空星球）' : item.title}}
                    </text>
                    <text class="suggest-address" wx:if="{{item.address}}">{{item.address}}</text>
                  </view>
                </block>
              </scroll-view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="floating-controls" wx:if="{{activeTab === 'home'}}">
      <button
        class="layer-button"
        hover-class="dashboard-toggle-hover"
        bindtap="onLayerButtonTap"
      >
        <image class="layer-button-icon" src="/assets/layer.png" mode="aspectFit" />
      </button>
      <!-- <button
        class="dashboard-toggle topic-button"
        hover-class="dashboard-toggle-hover"
        bindtap="onTopicButtonTap"
      >
        <image class="dashboard-toggle-icon" src="/assets/topic.png" mode="aspectFit" />
      </button> -->
      <button
        class="dashboard-toggle"
        hover-class="dashboard-toggle-hover"
        bindtap="onMarkerButtonTap"
      >
        <image class="dashboard-toggle-icon" src="/assets/idea.png" mode="aspectFit" />
      </button>
      <button
        class="marker-button"
        hover-class="marker-button-hover"
        bindtap="onLocateTap"
      >
        <image class="marker-button-icon" src="/assets/location.png" mode="aspectFit" />
      </button>
    </view>

    <view class="bottom-controls">
      <view class="bottom-menu">
        <button class="menu-btn {{activeTab === 'home' ? 'is-active' : ''}}" bindtap="onMenuHomeTap">
          <image class="menu-icon" src="/assets/home.png" mode="aspectFit" />
        </button>
        <button class="menu-btn {{activeTab === 'profile' ? 'is-active' : ''}}" bindtap="onMenuProfileTap">
          <image class="menu-icon" src="/assets/profile.png" mode="aspectFit" />
        </button>
      </view>

      <button
        class="chat-fab"
        hover-class="chat-fab-hover"
        bindtap="onChatButtonTap"
      >
        <image class="chat-fab-icon" src="/assets/ai-chat.png" mode="aspectFit" />
      </button>
    </view>
    <block wx:if="{{dronePickerVisible}}">
      <view class="drone-picker-mask" bindtap="closeDronePicker"></view>
      <view class="drone-picker-sheet">
        <view class="drone-picker-sheet-header">
          <view class="drone-description">
            <text class="drone-description-title">此次执飞的无人机型号</text>
            <text class="drone-description-subtitle">不同机型在飞行高度/区域、报备有差异。</text>
          </view>
          <text class="drone-picker-confirm" bindtap="confirmDronePicker">确定</text>
        </view>
        <scroll-view class="drone-picker-sheet-list" scroll-y="true">
          <block wx:for="{{droneNames}}" wx:key="index">
            <view
              class="drone-picker-option {{pendingDroneIndex === index ? 'is-active' : ''}}"
              data-index="{{index}}"
              bindtap="onSelectDroneOption"
            >
              {{item}}
            </view>
          </block>
        </scroll-view>
      </view>
    </block>

    <block wx:if="{{markerDetailVisible}}">
      <view class="marker-detail-mask {{markerDetailClosing ? 'marker-detail-mask--closing' : ''}}" bindtap="onMarkerDetailMaskTap"></view>
      <view
        class="marker-detail-sheet {{markerDetailClosing ? 'is-closing' : ''}} {{markerDetailExpanding ? 'is-expanding' : ''}}"
        bindtouchstart="onMarkerDetailTouchStart"
        bindtouchmove="onMarkerDetailTouchMove"
        bindtouchend="onMarkerDetailTouchEnd"
        bindtouchcancel="onMarkerDetailTouchCancel"
      >
        <view
          class="like-badge {{markerLikeAnimating ? 'is-anim' : ''}}"
          bindtouchstart="onMarkerLikeTouchStart"
          bindtouchend="onMarkerLikeTouchEnd"
          bindtouchcancel="onMarkerLikeTouchEnd"
          data-page="{{false}}"
        >
          <view class="like-badge-label like-badge-label--hint" wx:if="{{markerLikeHintLabel}}">{{markerLikeHintLabel}}</view>
          <view class="like-badge-label like-badge-label--result" wx:if="{{markerLikeResultLabel}}">{{markerLikeResultLabel}}</view>
          <image
            class="like-badge-icon"
            src="{{markerLiked ? '/assets/like.png' : '/assets/unlike.png'}}"
            mode="widthFix"
          />
          <text
            class="like-badge-count"
            data-count="{{markerLikeCount}}"
            bindtap="onLikeCountTap"
          >
            {{markerLikeCountDisplay}}
          </text>
        </view>
        <view class="marker-detail-handle"></view>
        <view class="marker-detail-header">
          <view class="marker-detail-info">
            <text class="marker-detail-name">{{detailCard.name || '未命名商户'}}</text>
            <text
              class="marker-detail-location"
              wx:if="{{detailCard.locationText}}"
            >
              {{detailCard.locationText}}
            </text>
          </view>
        </view>
        <view class="marker-detail-body">
          <block wx:if="{{detailCard.images && detailCard.images.length}}">
            <swiper
              class="marker-detail-swiper"
              autoplay="{{false}}"
              circular="{{true}}"
              bindchange="onMarkerDetailSwiperChange"
              current="{{markerDetailCurrentImage}}"
            >
              <block wx:for="{{detailCard.images}}" wx:key="id">
                <swiper-item>
                  <image class="marker-detail-swiper-image" src="{{item.url}}" mode="aspectFill" />
                </swiper-item>
              </block>
            </swiper>
            <view class="marker-detail-swiper-dots" wx:if="{{detailCard.images.length > 1}}">
              <block wx:for="{{detailCard.images}}" wx:key="id">
                <view class="marker-detail-swiper-dot {{index === markerDetailCurrentImage ? 'is-active' : ''}}"></view>
              </block>
            </view>
          </block>
          <view class="marker-detail-cover marker-detail-cover--placeholder" wx:else>
            <text class="marker-detail-cover-text">暂无图片</text>
          </view>
        </view>
        <view class="marker-detail-gesture-hint" wx:if="{{markerDetailAllowExpand}}">
          <text class="marker-detail-gesture-text">上滑查看详情</text>
        </view>
      </view>
    </block>

    <block wx:if="{{markerPageVisible}}">
      <view class="marker-page {{markerPageClosing ? 'marker-page--closing' : 'marker-page--open'}}">
        <view class="marker-page-mask" bindtap="onMarkerPageMaskTap"></view>
        <view
          class="like-badge like-badge--page {{markerPageLikeAnimating ? 'is-anim' : ''}}"
          bindtouchstart="onMarkerLikeTouchStart"
          bindtouchend="onMarkerLikeTouchEnd"
          bindtouchcancel="onMarkerLikeTouchEnd"
          data-page="{{true}}"
        >
          <view class="like-badge-label like-badge-label--hint" wx:if="{{markerPageLikeHintLabel}}">{{markerPageLikeHintLabel}}</view>
          <view class="like-badge-label like-badge-label--result" wx:if="{{markerPageLikeResultLabel}}">{{markerPageLikeResultLabel}}</view>
          <image
            class="like-badge-icon"
            src="{{markerPageLiked ? '/assets/like.png' : '/assets/unlike.png'}}"
            mode="widthFix"
          />
          <text
            class="like-badge-count"
            data-count="{{markerPageLikeCount}}"
            bindtap="onLikeCountTap"
          >
            {{markerPageLikeCountDisplay}}
          </text>
        </view>
        <scroll-view
          scroll-y
          class="marker-page-scroll"
          bindscroll="onMarkerPageScroll"
          bindtouchstart="onMarkerPageTouchStart"
          bindtouchmove="onMarkerPageTouchMove"
          bindtouchend="onMarkerPageTouchEnd"
          bindtouchcancel="onMarkerPageTouchCancel"
        >
          <view class="marker-page-hero">
            <block wx:if="{{markerPageDetail.images && markerPageDetail.images.length}}">
              <swiper
                class="marker-page-swiper"
                autoplay="{{false}}"
                circular="{{true}}"
                bindchange="onMarkerPageSwiperChange"
                current="{{markerPageCurrentImage}}"
              >
                <block wx:for="{{markerPageDetail.images}}" wx:key="id">
                  <swiper-item>
                    <image class="marker-page-swiper-image" src="{{item.url}}" mode="aspectFill" />
                  </swiper-item>
                </block>
              </swiper>
              <view class="marker-page-swiper-dots" wx:if="{{markerPageDetail.images.length}}">
                <block wx:for="{{markerPageDetail.images}}" wx:key="id">
                  <view class="marker-page-swiper-dot {{index === markerPageCurrentImage ? 'is-active' : ''}}"></view>
                </block>
              </view>
            </block>
            <view class="marker-page-hero-placeholder" wx:else>
              <text class="marker-page-hero-placeholder-text">暂无商户图片</text>
            </view>
          </view>

          <view class="marker-page-body">
            <view class="marker-page-header">
              <text class="marker-page-title">{{markerPageDetail.name || '未命名商户'}}</text>
            </view>

            <view
              class="marker-page-honors"
              wx:if="{{markerPageDetail.honors && markerPageDetail.honors.length}}"
            >
              <block wx:for="{{markerPageDetail.honors}}" wx:key="*this">
                <view class="marker-page-honor-chip">{{item}}</view>
              </block>
            </view>

            <view
              class="marker-page-address"
              wx:if="{{markerPageDetail.locationText || markerPageDetail.phone}}"
            >
              <view class="marker-page-address-info" wx:if="{{markerPageDetail.locationText}}">
                <text class="marker-page-address-text">{{markerPageDetail.locationText}}</text>
                <text
                  class="marker-page-address-distance"
                  wx:if="{{markerPageDistanceText}}"
                >
                  {{markerPageDistanceText}}
                </text>
              </view>
              <view class="marker-page-address-actions">
                <view
                  class="marker-page-action"
                  wx:if="{{markerPageDetail.latitude && markerPageDetail.longitude}}"
                  data-latitude="{{markerPageDetail.latitude}}"
                  data-longitude="{{markerPageDetail.longitude}}"
                  data-name="{{markerPageDetail.name || '商户位置'}}"
                  data-address="{{markerPageDetail.locationText || ''}}"
                  bindtap="onMarkerPageNavigateTap"
                >
                  <view class="marker-page-action-icon">
                    <image class="marker-page-action-image" src="/assets/m-target.png" mode="aspectFit" />
                  </view>
                  <text class="marker-page-action-label">位置</text>
                </view>
                <view
                  class="marker-page-action"
                  wx:if="{{markerPageDetail.phone}}"
                  data-phone="{{markerPageDetail.phone}}"
                  data-marker-id="{{markerPageDetail.markerId || markerPageDetail.id || ''}}"
                  data-name="{{markerPageDetail.name || ''}}"
                  bindtap="onMarkerPageCallTap"
                >
                  <view class="marker-page-action-icon">
                    <image class="marker-page-action-image" src="/assets/m-telephone.png" mode="aspectFit" />
                  </view>
                  <text class="marker-page-action-label">电话</text>
                </view>
              </view>
            </view>

            <view class="marker-page-section">
              <text class="marker-page-section-title">简介</text>
              <text class="marker-page-section-text" wx:if="{{markerPageDetail.description}}">{{markerPageDetail.description}}</text>
              <text class="marker-page-section-text marker-page-section-text--placeholder" wx:else>暂无简介</text>
            </view>

            <view
              class="marker-page-section"
              wx:if="{{markerPageDetail.attachments && markerPageDetail.attachments.length}}"
            >
              <text class="marker-page-section-title">附件</text>
              <view class="marker-page-link-list">
                <view
                  class="marker-page-link-item"
                  data-url="{{markerPageDetail.attachments[0].url}}"
                  bindtap="onMarkerPageAttachmentTap"
                >
                  <view class="marker-page-link-info">
                    <text class="marker-page-link-text">企业产品和业务介绍</text>
                  </view>
                  <image class="marker-page-link-icon" src="/assets/f-download.png" mode="aspectFit" />
                </view>
              </view>
            </view>

            <block wx:if="{{markerPageDetail.videoAccounts && markerPageDetail.videoAccounts.length}}">
              <block wx:for="{{markerPageDetail.videoAccounts}}" wx:key="id">
                <view
                  class="marker-page-link-item marker-page-link-item--video"
                  data-url="{{item.url || ''}}"
                  data-finder="{{item.finderUserName || ''}}"
                  data-activity="{{item.activityId || ''}}"
                  bindtap="onMarkerPageVideoTap"
                >
                  <view class="marker-page-link-info">
                    <text class="marker-page-link-text">{{markerPageDetail.videoAccounts.length > 1 ? ('视频号内容 ' + (index + 1)) : '丰富的视频案例介绍'}}</text>
                    <text class="marker-page-link-arrow">></text>
                  </view>
                  <image class="marker-page-link-icon" src="/assets/v-account.png" mode="aspectFit" />
                </view>
              </block>
            </block>

            <view
              class="marker-page-qrcode-wrapper"
              wx:if="{{markerPageDetail.qrCodes && markerPageDetail.qrCodes.length}}"
            >
              <block wx:for="{{markerPageDetail.qrCodes}}" wx:key="index">
                <image
                  class="marker-page-qrcode"
                  src="{{item.url}}"
                  mode="aspectFit"
                  show-menu-by-longpress="true"
                />
              </block>
            </view>
          </view>
        </scroll-view>

        <block wx:if="{{markerPageShareEnabled}}">
          <button open-type="share" class="marker-page-share">
            <image class="marker-page-share-icon" src="/assets/tansmit.png" mode="aspectFit" />
            <text class="marker-page-share-text">转发</text>
          </button>
        </block>
        <block wx:else>
          <button class="marker-page-share marker-page-share--disabled" bindtap="onMarkerPageShareDisabledTap">
            <image class="marker-page-share-icon" src="/assets/tansmit.png" mode="aspectFit" />
            <text class="marker-page-share-text">转发</text>
          </button>
        </block>
        <view class="marker-page-close-hint">下滑关闭详情</view>
      </view>
    </block>

    <block wx:if="{{layerPanelVisible}}">
      <view class="layer-panel-mask" bindtap="onLayerPanelMaskTap"></view>
      <view class="layer-panel {{layerPanelClosing ? 'is-closing' : 'is-open'}}">
        <view class="layer-panel-header">
          <text class="layer-panel-title">图层</text>
          <view class="layer-panel-close" bindtap="onLayerPanelClose">
            <image class="layer-panel-close-icon" src="/assets/marker-detail-close.png" mode="aspectFit" />
          </view>
        </view>

        <view class="layer-type-grid">
          <view
            class="layer-card {{mapLayerType === 'standard' ? 'is-active' : ''}}"
            data-type="standard"
            bindtap="onMapLayerSelect"
          >
            <view class="layer-card-thumb-wrap">
              <image class="layer-card-thumb" src="/assets/map-standard.png" mode="aspectFill" />
            </view>
            <text class="layer-card-label">标准图层</text>
          </view>
          <view
            class="layer-card {{mapLayerType === 'satellite' ? 'is-active' : ''}}"
            data-type="satellite"
            bindtap="onMapLayerSelect"
          >
            <view class="layer-card-thumb-wrap">
              <image class="layer-card-thumb" src="/assets/map-satellite.png" mode="aspectFill" />
            </view>
            <text class="layer-card-label">卫星图</text>
          </view>
        </view>

        <view class="layer-panel-section layer-panel-section--switch">
          <view class="airboard-row">
            <view class="airboard-icon"></view>
            <text class="airboard-label">空域看板</text>
            <switch
              class="airboard-switch"
              checked="{{airBoardEnabled}}"
              color="#000000"
              bindchange="onAirBoardSwitchChange"
            />
          </view>
        </view>

        <view class="layer-panel-section">
          <text class="layer-panel-section-title">地图元素</text>
          <view class="layer-element-grid">
            <block wx:for="{{mapElementOptions}}" wx:key="id">
              <view class="layer-element-item" data-id="{{item.id}}" bindtap="onMapElementToggle">
                <image
                  wx:if="{{item.enabled}}"
                  class="layer-element-icon"
                  src="/assets/check.png"
                  mode="aspectFit"
                />
                <view wx:else class="layer-element-icon layer-element-icon--off"></view>
                <text class="layer-element-label">{{item.label}}</text>
              </view>
            </block>
          </view>
          <text class="layer-panel-hint">更多图层配置将陆续上线</text>
        </view>
      </view>
    </block>

    <block wx:if="{{callSheetVisible}}">
      <view class="call-sheet-mask" bindtap="onCallSheetMaskTap"></view>
      <view class="call-sheet">
        <view class="call-sheet-message">来电时，请说明通过“低空星球”看到我的</view>
        <button class="call-sheet-button call-sheet-button--primary" bindtap="onCallSheetConfirm">
          {{callSheetPhone}}
        </button>
        <button class="call-sheet-button call-sheet-button--secondary" bindtap="onCallSheetCancel">取消</button>
      </view>
    </block>

  </view>

  <view wx:if="{{joinInvitePrompt}}" class="invite-overlay" catchtouchmove="noop">
    <view class="invite-mask"></view>
    <view class="invite-card">
      <view class="invite-title">加入工作组</view>
      <view class="invite-body">
        <text wx:if="{{joinInviteLoginPending}}">登录中...</text>
        <block wx:else>
          <text class="invite-text">是否加入工作组：{{joinInvitePrompt.groupName || joinInvitePrompt.groupId || '--'}}</text>
          <text class="invite-tip">确认后将加入该工作组并同步标记协同</text>
        </block>
      </view>
      <view class="invite-footer">
        <button
          class="invite-btn primary"
          loading="{{joinInviting || joinInviteLoginPending}}"
          data-invitation-code="{{joinInvitePrompt.invitationCode}}"
          data-group-id="{{joinInvitePrompt.groupId}}"
          data-group-name="{{joinInvitePrompt.groupName}}"
          bindtap="confirmJoinWorkGroup"
        >
          确认加入
        </button>
      </view>
    </view>
  </view>
</view>
