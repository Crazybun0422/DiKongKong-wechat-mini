<view class="page {{isWideLayout ? 'page--wide' : ''}}">
  <view class="map-wrap">
    <map
      id="main-map"
      class="map-canvas"
      style="height: calc(100vh + {{statusBarHeight}}px); margin-top: -{{statusBarHeight}}px;"
      longitude="{{center.longitude}}"
      latitude="{{center.latitude}}"
      scale="{{scale}}"
      rotate="{{mapRotate}}"
      skew="{{mapSkew}}"
      min-scale="{{minScale}}"
      max-scale="{{maxScale}}"
      subkey="{{mapSubKey}}"
      layer-style="1"
      enable-satellite="{{enableSatellite}}"
      enable-scroll="{{!mapBlockerVisible && !centerPinFollowActive && !layerPanelVisible}}"
      enable-zoom="{{!mapBlockerVisible && !layerPanelVisible}}"
      enable-rotate="{{!mapBlockerVisible && !layerPanelVisible}}"
      enable-overlooking="{{!mapBlockerVisible && !layerPanelVisible}}"
      show-location="{{myLocationModeResolved ? !usePlanetCenterPoint : false}}"
      markers="{{markers}}"
      polyline="{{polylines}}"
      polygons="{{polygons}}"
      circles="{{circles}}"
      bindregionchange="onRegionChange"
      bindupdated="onMapUpdated"
      bindtap="onMapTap"
      bindmarkertap="onMarkerTap"
      bindcallouttap="onMarkerCalloutTap"
    />
    <map-search-link
      center="{{searchLinkCenter}}"
      target="{{searchLinkTarget}}"
      visible="{{mapCenterReady && searchLinkVisible && centerTargetLinkEnabled}}"
      satellite="{{mapLayerType === 'satellite'}}"
      bind:graphicschange="onSearchLinkGraphicsChange"
    />
    <map-center-pin
      wx:if="{{mapCenterReady}}"
      top-offset-px="{{centerPinOffsetPx}}"
      ui-scale="{{mapUiScale}}"
      satellite="{{mapLayerType === 'satellite'}}"
      sneaking-active="{{stealthModeActive}}"
      sneaking-tip-text="专注中，长按解除"
      link-active="{{centerPinLinkActive}}"
      link-tip-text="{{centerPinLinkTipText}}"
      long-press-guide-nodes="{{coordinateLongPressGuideNodes}}"
      follow-active="{{centerPinFollowActive}}"
      follow-tip-text="{{centerPinFollowTipText}}"
      welcome-bubble-dismiss-token="{{centerPinWelcomeBubbleDismissToken}}"
      suppress-welcome-bubble="{{(keyword && keyword.length > 0) || searchSuggestLoading || (searchSuggestions && searchSuggestions.length > 0) || (searchSuggestError && searchSuggestError.length > 0) || searchLinkVisible}}"
      bind:tap="onCenterPinTap"
      bind:longpress="onCenterPinLongPress"
      bind:close="onCenterPinSheetClose"
      bind:action="onCenterPinAction"
    />
    <dji-no-fly-layer
      id="dji-no-fly-layer"
      bind:graphicschange="onDjiGraphicsChange"
      bind:statuschange="onDjiStatusChange"
    />
    <temporary-no-fly-layer
      id="temporary-no-fly-layer"
      bind:graphicschange="onTemporaryNoFlyGraphicsChange"
      bind:statuschange="onTemporaryNoFlyStatusChange"
    />
    <newbie-task-popup
      id="newbie-task-popup"
      bind:statechange="onNewbieTaskStateChange"
      bind:checkinguide="onCheckinGuideStart"
      bind:inviteguide="onInviteGuideStart"
    />
    <add-mini-app-popup
      id="add-mini-app-popup"
      bind:close="onAddMiniAppPopupClose"
      bind:statechange="onAddMiniAppStateChange"
    />
    <uom-plugin id="uom-plugin" wx:if="{{isWeChatRuntime === true}}" bind:statuschange="onUomStatusChange" />
    <uom2-plugin
      id="uom2-plugin"
      wx:elif="{{isWeChatRuntime === false}}"
      bind:statuschange="onUomStatusChange"
      bind:tileschanged="onUomTilesChanged"
    />
    <map-debug-panel wx:if="{{debugEnabled}}" info="{{debugInfo}}" />
    <view
      id="subscription-banner"
      class="subscription-banner map-ui-scale-left"
      wx:if="{{activeTab === 'home' && showSubscriptionBanner && !stealthModeActive}}"
      style="top: {{subscriptionBannerTopPx}}px; left: {{subscriptionBannerLeftPx}}px; {{subscriptionBannerScaleStyle}}"
    >
      <view class="subscription-banner-text">
        确保有新功能、空投福利时，您永远是第一批知道的~
      </view>
      <button
        class="subscription-banner-cta"
        hover-class="subscription-banner-cta--hover"
        bindtap="onSubscriptionBannerTap"
        loading="{{subscriptionBannerLoading}}"
      >
        立即开启
      </button>
    </view>
    <view
      class="map-checkin-entry-wrap map-ui-scale-right"
      wx:if="{{activeTab === 'home' && !stealthModeActive}}"
      style="{{checkinEntryStyle}}"
    >
      <button
        id="map-checkin-entry-btn"
        class="map-checkin-entry {{checkinTodaySigned ? '' : 'is-breathing'}}"
        bindtap="onMapCheckinEntryTap"
      >
        <image
          class="map-checkin-entry-image"
          src="{{checkinTodaySigned ? '/assets/map-checkin-signed.png' : '/assets/map-checkin-unsigned.png'}}"
          mode="aspectFit"
        />
      </button>
    </view>
    <view
      class="map-compass-anchor map-ui-scale-left {{mapLayerType === 'satellite' ? 'map-compass-anchor--satellite' : ''}}"
      wx:if="{{compassVisible}}"
      style="left: {{scaleControlsLeftPx}}px; bottom: calc(env(safe-area-inset-bottom) + {{compassBottomPx}}px); {{mapUiScaleStyle}} transform-origin: left bottom;"
    >
      <map-compass
        rotate="{{compassRotate}}"
        skew="{{compassSkew}}"
        satellite="{{mapLayerType === 'satellite'}}"
        bind:compasstap="onCompassTap"
      />
    </view>
    <view
      class="map-scale-container map-ui-scale-left {{mapLayerType === 'satellite' ? 'map-scale-container--satellite' : ''}}"
      wx:if="{{scaleBarVisible}}"
      style="left: {{scaleControlsLeftPx}}px; bottom: calc(env(safe-area-inset-bottom) + {{scaleControlsBottomPx}}px); {{mapUiScaleStyle}} transform-origin: left bottom;"
    >
      <view class="map-scale">
        <text class="map-scale-label">{{scaleBarLabel}}</text>
        <view class="map-scale-track" style="width: {{scaleBarWidthRpx}}rpx;">
          <view class="map-scale-line"></view>
          <view class="map-scale-tick map-scale-tick-start"></view>
          <view class="map-scale-tick map-scale-tick-end"></view>
        </view>
      </view>
      <view
        class="map-center-coords"
        wx:if="{{centerCoordinateLatText && centerCoordinateLngText}}"
        bindtap="onCenterCoordinateTap"
      >
        <text class="map-center-coords-text">{{centerCoordinateLngText}}</text>
        <text class="map-center-coords-text">{{centerCoordinateLatText}}</text>
        <view class="map-center-coords-pill" catchtap="onCoordinateSystemToggle">
          <view class="map-center-coords-pill-inner">
            <text class="map-center-coords-pill-text">{{coordinateSystemLabel}}</text>
            <view class="map-center-coords-pill-arrow"></view>
          </view>
        </view>
      </view>
    </view>

    <coordinate-system-sheet
      visible="{{coordinateSystemSheetVisible}}"
      wide-layout="{{isWideLayout}}"
      coordinate-system="{{coordinateSystem}}"
      coordinate-system-options="{{coordinateSystemOptions}}"
      coordinate-system-description-nodes="{{coordinateSystemDescriptionNodes}}"
      bind:masktap="onCoordinateSystemSheetMaskTap"
      bind:optiontap="onCoordinateSystemOptionTap"
    />

    <preflight-dashboard
      wx:if="{{showDashboardPanel}}"
      id="preflight-dashboard"
      stealth-mode-active="{{stealthModeActive}}"
      top-px="{{preflightTopPx}}"
      left-px="{{preflightLeftPx}}"
      ui-scale-style="{{mapUiScaleStyle}}"
      drone-picker-label="{{dronePickerLabel}}"
      temporary-no-fly-zone-info="{{temporaryNoFlyZoneInfo}}"
      temporary-no-fly-tone="{{temporaryNoFlyTone}}"
      temporary-no-fly-text="{{temporaryNoFlyText}}"
      uom-loading="{{uomLoading}}"
      uom-tone="{{uomTone}}"
      uom-status="{{uomStatus}}"
      dji-tone="{{djiTone}}"
      dji-color="{{djiColor}}"
      dji-status="{{djiStatus}}"
      dji-status-extra="{{djiStatusExtra}}"
      center-pin-title="{{centerPinTitle}}"
      keyword="{{keyword}}"
      search-suggestions="{{searchSuggestions}}"
      search-suggest-loading="{{searchSuggestLoading}}"
      search-suggest-error="{{searchSuggestError}}"
      city-report-center="{{cityReportCenter}}"
      city-report-active="{{showDashboardPanel && !stealthModeActive}}"
      city-report-dialog-visible="{{cityReportDialogVisible}}"
      city-report-dialog-text="{{cityReportDialogText}}"
      bind:opendronepicker="openDronePicker"
      bind:temporarynoticeentrytap="onTemporaryNoticeEntryTap"
      bind:temporaryzonelinktap="onTemporaryZoneLinkTap"
      bind:centerpinindicatortap="onCenterPinIndicatorTap"
      bind:keywordinput="onKeywordInput"
      bind:searchconfirm="onSearchConfirm"
      bind:searchtap="onSearchTap"
      bind:searchcoordinatetipstap="onSearchCoordinateTipsTap"
      bind:suggestiontap="onSuggestionTap"
      bind:cityreportstatechange="onCityReportStateChange"
      bind:cityreportdialogchange="onCityReportDialogChange"
      bind:cityreportdialogclose="onCityReportDialogClose"
    />

    <block wx:if="{{cityReportDialogVisible}}">
      <view class="city-report-dialog-overlay" catchtouchmove="noop" catchtap="noop">
        <view class="city-report-dialog-container">
          <view class="city-report-dialog-card">
            <text class="city-report-dialog-text">{{cityReportDialogText}}</text>
            <view class="city-report-dialog-btn" catchtap="onCityReportDialogClose">我知道了</view>
          </view>
        </view>
      </view>
    </block>

    <policy-update-modal
      visible="{{policyUpdateVisible}}"
      update-type="{{policyUpdateType}}"
      title="{{policyUpdateTitle}}"
      loading="{{policyUpdateSubmitting}}"
      closing="{{policyUpdateClosing}}"
      bind:agree="onPolicyUpdateAgree"
      bind:disagree="onPolicyUpdateDisagree"
      bind:agreement="onPolicyAgreementTap"
      bind:privacy="onPolicyPrivacyTap"
    />

    <map-floating-controls
      visible="{{activeTab === 'home' && !stealthModeActive}}"
      container-style="right: {{floatingControlsRightPx}}px; bottom: calc(env(safe-area-inset-bottom) + {{floatingControlsBottomPx}}px);"
      ui-scale-style="{{mapUiScaleStyle}}"
      show-newbie-gift-entry="{{showNewbieGiftEntry}}"
      bind:newbiegifttap="onNewbieGiftTap"
      bind:layerbuttontap="onLayerButtonTap"
      bind:markerbuttontap="onMarkerButtonTap"
      bind:locatetap="onLocateTap"
    />
    <map-weather-strip
      visible="{{weatherFeatureEnabled && activeTab === 'home' && !stealthModeActive}}"
      container-style="left: {{weatherWidgetLeftPx}}px; width: {{weatherWidgetWidthPx}}px; bottom: calc(env(safe-area-inset-bottom) + {{weatherWidgetBottomPx}}px); {{mapUiScaleStyle}} transform-origin: left bottom;"
      satellite="{{mapLayerType === 'satellite'}}"
      loading="{{weatherLoading}}"
      error="{{weatherError}}"
      updated-at-text="{{weatherUpdatedAtText}}"
      items="{{weatherSummaryItems}}"
      bind:weathertap="onWeatherWidgetTap"
    />

    <map-bottom-nav
      id="map-bottom-nav"
      visible="{{!stealthModeActive}}"
      container-style="bottom: calc(env(safe-area-inset-bottom) + {{bottomNavBottomPx}}px);"
      wide-layout="{{isWideLayout}}"
      ui-scale="{{mapUiScale}}"
      active-tab="{{activeTab}}"
      show-profile-red-dot="{{showProfileRedDot}}"
      bind:menuhometap="onMenuHomeTap"
      bind:menuprofiletap="onMenuProfileTap"
      bind:chatbuttontap="onChatButtonTap"
    />
    <drone-picker-sheet
      visible="{{dronePickerVisible}}"
      wide-layout="{{isWideLayout}}"
      drone-categories="{{droneCategories}}"
      active-drone-category-index="{{activeDroneCategoryIndex}}"
      drone-category-items="{{droneCategoryItems}}"
      pending-drone-index="{{pendingDroneIndex}}"
      bind:close="closeDronePicker"
      bind:confirm="confirmDronePicker"
      bind:selectcategory="onSelectDroneCategory"
      bind:selectoption="onSelectDroneOption"
    />

    <marker-detail-sheet
      wx:if="{{markerDetailVisible}}"
      detail-card="{{detailCard}}"
      marker-detail-closing="{{markerDetailClosing}}"
      marker-detail-expanding="{{markerDetailExpanding}}"
      marker-detail-allow-expand="{{markerDetailAllowExpand}}"
      marker-detail-current-image="{{markerDetailCurrentImage}}"
      marker-detail-video-loading="{{markerDetailVideoLoading}}"
      marker-like-animating="{{markerLikeAnimating}}"
      marker-like-hint-label="{{markerLikeHintLabel}}"
      marker-like-result-label="{{markerLikeResultLabel}}"
      marker-liked="{{markerLiked}}"
      marker-like-count="{{markerLikeCount}}"
      marker-like-count-display="{{markerLikeCountDisplay}}"
      marker-svip-icon-path="{{markerSvipIconPath}}"
      bind:masktap="onMarkerDetailMaskTap"
      bind:masktouchmove="onMarkerDetailMaskTouchMove"
      bind:touchstart="onMarkerDetailTouchStart"
      bind:touchmove="onMarkerDetailTouchMove"
      bind:touchend="onMarkerDetailTouchEnd"
      bind:touchcancel="onMarkerDetailTouchCancel"
      bind:liketouchstart="onMarkerLikeTouchStart"
      bind:liketouchend="onMarkerLikeTouchEnd"
      bind:likecounttap="onLikeCountTap"
      bind:swiperchange="onMarkerDetailSwiperChange"
      bind:videowaiting="onMarkerDetailVideoWaiting"
      bind:videoready="onMarkerDetailVideoReady"
      bind:inlinevideotap="onMapInlineVideoTap"
      bind:creatortap="onCreatorNameTap"
    />

    <marker-page-sheet
      wx:if="{{markerPageVisible}}"
      marker-page-closing="{{markerPageClosing}}"
      marker-page-detail="{{markerPageDetail}}"
      marker-page-current-image="{{markerPageCurrentImage}}"
      marker-page-video-loading="{{markerPageVideoLoading}}"
      marker-page-like-animating="{{markerPageLikeAnimating}}"
      marker-page-like-hint-label="{{markerPageLikeHintLabel}}"
      marker-page-like-result-label="{{markerPageLikeResultLabel}}"
      marker-page-liked="{{markerPageLiked}}"
      marker-page-like-count="{{markerPageLikeCount}}"
      marker-page-like-count-display="{{markerPageLikeCountDisplay}}"
      marker-page-share-enabled="{{markerPageShareEnabled}}"
      marker-page-is-pin="{{markerPageIsPin}}"
      marker-page-distance-text="{{markerPageDistanceText}}"
      marker-svip-icon-path="{{markerSvipIconPath}}"
      bind:masktap="onMarkerPageMaskTap"
      bind:scroll="onMarkerPageScroll"
      bind:touchstart="onMarkerPageTouchStart"
      bind:touchmove="onMarkerPageTouchMove"
      bind:touchend="onMarkerPageTouchEnd"
      bind:touchcancel="onMarkerPageTouchCancel"
      bind:swiperchange="onMarkerPageSwiperChange"
      bind:videowaiting="onMarkerPageVideoWaiting"
      bind:videoready="onMarkerPageVideoReady"
      bind:inlinevideotap="onMapInlineVideoTap"
      bind:certificationtap="onMarkerCertificationBadgeTap"
      bind:liketouchstart="onMarkerLikeTouchStart"
      bind:liketouchend="onMarkerLikeTouchEnd"
      bind:likecounttap="onLikeCountTap"
      bind:postertap="onMarkerPosterTap"
      bind:sharedisabledtap="onMarkerPageShareDisabledTap"
      bind:navigatetap="onMarkerPageNavigateTap"
      bind:calltap="onMarkerPageCallTap"
      bind:attachmenttap="onMarkerPageAttachmentTap"
      bind:videotap="onMarkerPageVideoTap"
      bind:creatortap="onCreatorNameTap"
    />

    <block wx:if="{{markerCertificationSheetVisible}}">
      <view
        class="marker-certification-mask {{markerCertificationSheetClosing ? 'is-closing' : ''}}"
        bindtap="onMarkerCertificationSheetMaskTap"
        catchtouchmove="noop"
      ></view>
      <view
        class="marker-certification-sheet {{markerCertificationSheetClosing ? 'is-closing' : ''}}"
        catchtap="noop"
        catchtouchmove="noop"
      >
        <view class="marker-certification-sheet-head">
          <text class="marker-certification-sheet-brand">低空星球</text>
          <image class="marker-certification-sheet-head-icon" src="{{markerSvipIconPath}}" mode="aspectFit" />
        </view>
        <block wx:for="{{markerCertificationInfoItems}}" wx:key="id">
          <view class="marker-certification-item">
            <image class="marker-certification-item-icon" src="{{item.icon}}" mode="aspectFit" />
            <view class="marker-certification-item-content">
              <text class="marker-certification-item-title">{{item.title}}</text>
              <text class="marker-certification-item-description">{{item.description}}</text>
            </view>
          </view>
        </block>
      </view>
    </block>

    <map-layer-panel
      wx:if="{{layerPanelVisible}}"
      id="map-layer-panel"
      layer-panel-closing="{{layerPanelClosing}}"
      layer-panel-max-height-px="{{layerPanelMaxHeightPx}}"
      layer-panel-body-height-px="{{layerPanelBodyHeightPx}}"
      layer-panel-body-max-height-px="{{layerPanelBodyMaxHeightPx}}"
      map-layer-type="{{mapLayerType}}"
      air-board-enabled="{{airBoardEnabled}}"
      use-planet-center-point="{{usePlanetCenterPoint}}"
      center-target-link-enabled="{{centerTargetLinkEnabled}}"
      province-city-highlight-enabled="{{provinceCityHighlightEnabled}}"
      province-city-tree="{{provinceCityTree}}"
      province-city-highlight-loading="{{provinceCityHighlightLoading}}"
      province-city-highlight-error="{{provinceCityHighlightError}}"
      map-element-options="{{mapElementOptions}}"
      bind:masktap="onLayerPanelMaskTap"
      bind:close="onLayerPanelClose"
      bind:maplayerselect="onMapLayerSelect"
      bind:airboardswitchchange="onAirBoardSwitchChange"
      bind:useplanetcenterpointswitchchange="onUsePlanetCenterPointSwitchChange"
      bind:centertargetlinkswitchchange="onCenterTargetLinkSwitchChange"
      bind:provincecityhighlightswitchchange="onProvinceCityHighlightSwitchChange"
      bind:provincecitytreeexpandtap="onProvinceCityTreeExpandTap"
      bind:provincecitytreeselecttap="onProvinceCityTreeSelectTap"
      bind:mapelementtoggle="onMapElementToggle"
    />

    <block wx:if="{{callSheetVisible}}">
      <view class="call-sheet-mask" bindtap="onCallSheetMaskTap"></view>
      <view class="call-sheet">
        <view class="call-sheet-message">来电时，请说明通过“低空星球”看到我的</view>
        <button class="call-sheet-button call-sheet-button--primary" bindtap="onCallSheetConfirm">
          {{callSheetPhone}}
        </button>
        <button class="call-sheet-button call-sheet-button--secondary" bindtap="onCallSheetCancel">取消</button>
      </view>
    </block>

  </view>

  <block wx:if="{{searchCoordinateTipsVisible}}">
    <view class="city-report-dialog-overlay" catchtouchmove="noop" catchtap="noop">
      <view class="city-report-dialog-container">
        <view class="city-report-dialog-card">
          <text class="city-report-dialog-text">{{searchCoordinateTipsText}}</text>
          <view class="city-report-dialog-btn" catchtap="onCloseSearchCoordinateTipsDialog">我知道了</view>
        </view>
      </view>
    </view>
  </block>

  <view wx:if="{{joinInvitePrompt}}" class="invite-overlay" catchtouchmove="noop">
    <view class="invite-mask"></view>
    <view class="invite-card">
      <view class="invite-title">加入工作组</view>
      <view class="invite-body">
        <text wx:if="{{joinInviteLoginPending}}">登录中...</text>
        <block wx:else>
          <text class="invite-text">是否加入工作组：{{joinInvitePrompt.groupName || joinInvitePrompt.groupId || '--'}}</text>
          <text class="invite-tip">确认后将加入该工作组并同步标记协同</text>
        </block>
      </view>
      <view class="invite-footer">
        <button class="invite-btn secondary" bindtap="cancelJoinWorkGroup" disabled="{{joinInviting}}">
          取消
        </button>
        <button
          class="invite-btn primary"
          disabled="{{joinInviting || joinInviteLoginPending}}"
          loading="{{joinInviting || joinInviteLoginPending}}"
          data-invitation-code="{{joinInvitePrompt.invitationCode}}"
          data-group-id="{{joinInvitePrompt.groupId}}"
          data-group-name="{{joinInvitePrompt.groupName}}"
          bindtap="confirmJoinWorkGroup"
        >
          确认加入
        </button>
      </view>
    </view>
  </view>

  <block wx:if="{{showCheckinGuideMap}}">
    <view class="checkin-guide-overlay" style="{{checkinGuideOverlayStyle}}"></view>
    <view
      class="checkin-guide-mask checkin-guide-mask-top"
      style="height: {{checkinGuideMask.top}}px;"
      catchtouchmove="noop"
      catchtap="onGuideMaskTap"
    ></view>
    <view
      class="checkin-guide-mask checkin-guide-mask-left"
      style="top: {{checkinGuideMask.top}}px; height: {{checkinGuideMask.size}}px; width: {{checkinGuideMask.left}}px;"
      catchtouchmove="noop"
      catchtap="onGuideMaskTap"
    ></view>
    <view
      class="checkin-guide-mask checkin-guide-mask-right"
      style="top: {{checkinGuideMask.top}}px; height: {{checkinGuideMask.size}}px; left: {{checkinGuideMask.rightLeft}}px;"
      catchtouchmove="noop"
      catchtap="onGuideMaskTap"
    ></view>
    <view
      class="checkin-guide-mask checkin-guide-mask-bottom"
      style="top: {{checkinGuideMask.bottomTop}}px;"
      catchtouchmove="noop"
      catchtap="onGuideMaskTap"
    ></view>
    <view
      class="checkin-guide-ring"
      style="left: {{checkinGuideMask.left}}px; top: {{checkinGuideMask.top}}px; width: {{checkinGuideMask.size}}px; height: {{checkinGuideMask.size}}px;"
    ></view>
  </block>
  <block wx:if="{{showInviteGuideMap}}">
    <view class="checkin-guide-overlay" style="{{inviteGuideOverlayStyle}}"></view>
    <view
      class="checkin-guide-mask checkin-guide-mask-top"
      style="height: {{inviteGuideMask.top}}px;"
      catchtouchmove="noop"
      catchtap="onGuideMaskTap"
    ></view>
    <view
      class="checkin-guide-mask checkin-guide-mask-left"
      style="top: {{inviteGuideMask.top}}px; height: {{inviteGuideMask.size}}px; width: {{inviteGuideMask.left}}px;"
      catchtouchmove="noop"
      catchtap="onGuideMaskTap"
    ></view>
    <view
      class="checkin-guide-mask checkin-guide-mask-right"
      style="top: {{inviteGuideMask.top}}px; height: {{inviteGuideMask.size}}px; left: {{inviteGuideMask.rightLeft}}px;"
      catchtouchmove="noop"
      catchtap="onGuideMaskTap"
    ></view>
    <view
      class="checkin-guide-mask checkin-guide-mask-bottom"
      style="top: {{inviteGuideMask.bottomTop}}px;"
      catchtouchmove="noop"
      catchtap="onGuideMaskTap"
    ></view>
  </block>
</view>


