<view
  class="bottom-controls"
  wx:if="{{visible}}"
  style="{{containerStyle}} {{wideLayout && uiScale < 0.9999 ? 'transform: translateX(-50%) scale(' + uiScale + '); transform-origin: center bottom;' : 'transform: translateX(-50%); transform-origin: center bottom;'}}"
>
  <view class="bottom-menu">
    <button class="menu-btn {{activeTab === 'home' ? 'is-active' : ''}}" bindtap="onMenuHomeTap">
      <image class="menu-icon" src="{{activeTab === 'home' ? '/assets/home-active.png' : '/assets/home.png'}}" mode="aspectFit" />
    </button>
    <button class="menu-btn {{activeTab === 'profile' ? 'is-active' : ''}}" bindtap="onMenuProfileTap" id="menu-profile-btn">
      <image class="menu-icon" src="{{activeTab === 'profile' ? '/assets/profile-active.png' : '/assets/profile.png'}}" mode="aspectFit" />
      <view wx:if="{{showProfileRedDot}}" class="menu-badge">
        <image class="menu-badge-dot" src="/assets/red-point.png" mode="aspectFit" />
      </view>
    </button>
  </view>

  <button
    class="chat-fab"
    hover-class="chat-fab-hover"
    bindtap="onChatButtonTap"
  >
    <image class="chat-fab-icon" src="/assets/ai-chat.png" mode="aspectFit" />
  </button>
</view>
