.debug-root {
  position: absolute;
  top: calc(env(safe-area-inset-top) + 20rpx);
  left: 20rpx;
  z-index: 90;
  pointer-events: none;
}

.debug-toggle {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(17, 24, 39, 0.8);
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  pointer-events: auto;
}

.debug-panel {
  width: 520rpx;
  max-height: 60vh;
  background: rgba(15, 23, 42, 0.92);
  border-radius: 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  padding: 18rpx 18rpx 12rpx;
  color: #f8fafc;
  box-sizing: border-box;
  pointer-events: auto;
  overflow: hidden;
}

.debug-panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.debug-panel-title {
  font-size: 24rpx;
  font-weight: 700;
}

.debug-panel-close {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  line-height: 1;
}

.debug-panel-body {
  max-height: 52vh;
  overflow-y: auto;
}

.debug-line {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
  font-size: 20rpx;
  line-height: 1.4;
  padding: 4rpx 0;
  border-bottom: 1rpx dashed rgba(255, 255, 255, 0.08);
}

.debug-line:last-child {
  border-bottom: none;
}

.debug-key {
  color: rgba(248, 250, 252, 0.7);
  flex: 0 0 170rpx;
}

.debug-value {
  color: #f8fafc;
  flex: 1;
  text-align: right;
  word-break: break-all;
}
