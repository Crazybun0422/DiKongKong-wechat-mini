.search-stack {
  flex: 1;
  width: 100%;
  position: relative;
  display: flex;
  align-items: center;
  gap: 0rpx;
  pointer-events: auto;
}

.search-pill {
  flex: 1 1 auto;
  display: flex;
  align-items: center;
  border: 2rpx solid rgba(255, 255, 255, 0.95);
  border-radius: 999rpx;
  height: 72rpx;
  min-height: 72rpx;
  min-width: 0;
  padding-left: 28rpx;
  background: rgba(0, 0, 0, 0.22);
  pointer-events: auto;
  box-shadow: 0 12rpx 24rpx rgba(0, 0, 0, 0.22) inset;
  box-sizing: border-box;
  overflow: hidden;
}

.search-input-wrap {
  position: relative;
  flex: 1;
  min-width: 0;
  height: 100%;
}

.search-display {
  position: absolute;
  top: 50%;
  left: 0;
  right: 8rpx;
  transform: translateY(-50%);
  font-size: 28rpx;
  line-height: 1.3;
  color: #fff;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  pointer-events: none;
}

.search-display--placeholder {
  color: rgba(255, 255, 255, 0.85);
}

.search-field {
  position: relative;
  z-index: 1;
  flex: 1;
  min-width: 0;
  height: 72rpx;
  line-height: 72rpx;
  border: none;
  background: transparent;
  color: transparent;
  font-size: 28rpx;
  padding: 0 8rpx 0 0;
  box-sizing: border-box;
  display: block;
}

.search-field::placeholder {
  color: transparent;
}

button.search-tips-btn {
  flex-shrink: 0;
  width: 54rpx;
  height: 54rpx;
  border: none;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  pointer-events: auto;
}

button.search-tips-btn::after {
  border: 0;
  content: none;
}

.search-tips-btn-icon {
  width: 40rpx;
  height: 40rpx;
  opacity: 0.92;
}

.search-tips-btn-hover {
  transform: scale(0.92);
  opacity: 0.88;
}

.search-tips-btn--outside {
  width: 40rpx;
  height: 40rpx;
  margin-left: -2rpx;
}

button.search-btn {
  flex-shrink: 0;
  width: 70rpx;
  height: 70rpx;
  margin-left: 16rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.95);
  background: rgba(255, 255, 255, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  transition: transform 0.12s ease, background-color 0.12s ease;
  pointer-events: auto;
}

button.search-btn::after {
  border: 0;
  content: none;
}

.search-btn-icon {
  width: 40rpx;
  height: 40rpx;
}

.search-btn-hover {
  transform: scale(0.9);
  background: rgba(255, 255, 255, 0.18);
}

.search-suggest-panel {
  position: absolute;
  left: 0;
  right: 0;
  top: calc(100% + 12rpx);
  border-radius: 24rpx;
  background: rgba(12, 21, 33, 0.92);
  box-shadow: 0 18rpx 32rpx rgba(0, 0, 0, 0.35);
  padding: 8rpx;
  z-index: 12;
}

.search-suggest-scroll {
  max-height: 320rpx;
  overflow: auto;
}

.search-suggest-item {
  padding: 14rpx 20rpx;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  color: #fff;
}

.search-suggest-item + .search-suggest-item {
  margin-top: 6rpx;
}

.search-suggest-item:active {
  background: rgba(255, 255, 255, 0.08);
}

.search-suggest-state {
  padding: 20rpx;
  text-align: center;
  color: rgba(255, 255, 255, 0.85);
  font-size: 24rpx;
}

.suggest-title {
  font-size: 26rpx;
  font-weight: 600;
}

.suggest-title-marker {
  color: #22c55e;
}

.suggest-title-pin {
  color: #22c55e;
}

.suggest-address {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}
