.page {
  display: flex;
  flex-direction: column;
   height:100vh; 
  background: #e7eaef;
}

.map-wrap {
  position: relative;
  flex: 1;
  width: 100%;
}


.map-canvas {
  width: 100%;
  height: 100vh;
}

.uom-dialog {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 80;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.uom-dialog-box {
  position: relative;
  max-width: 720rpx;
  padding: 32rpx 40rpx;
  background: rgba(15, 23, 42, 0.55);
  border: 1rpx solid rgba(255, 255, 255, 0.32);
  border-radius: 24rpx;
  box-shadow: 0 18rpx 36rpx rgba(15, 23, 42, 0.18);
}

.uom-dialog-text {
  display: block;
  color: #f8fafc;
  font-size: 26rpx;
  line-height: 1.7;
  text-align: center;
}

.uom-dialog-action {
  margin-top: 24rpx;
  padding-bottom: 5px;
  display: flex;
  justify-content: center;
}

.uom-dialog-btn {
  min-width: 100rpx;
  padding: 11rpx 0rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.32);
  background: rgba(255, 255, 255, 0.16);
  color: #f8fafc;
  font-size: 26rpx;
  line-height: 1.2;
  text-align: center;
  box-sizing: border-box;
}

.uom-dialog-btn::after {
  display: none;
}

.uom-dialog-btn--hover {
  background: rgba(255, 255, 255, 0.26);
}

.subscription-banner {
  position: absolute;
  left: 16rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 10rpx 18rpx;
  background: rgba(64, 64, 64, 0.75);
  border-radius: 16rpx;
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.25);
  z-index: 36;
  pointer-events: auto;
  max-width: 480rpx;
  min-width:480rpx;
}

.subscription-banner-text {
  color: #f8fafc;
  font-size: 18rpx;
  line-height: 1.5;
  max-width: 320rpx;
}

.subscription-banner-cta {
  background: #cf2e2e;
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 12rpx;
  padding: 12rpx 20rpx;
  border: none;
  line-height: 1;
  min-width: 130rpx;
  box-shadow: 0 8rpx 20rpx rgba(207, 46, 46, 0.32);
}

.subscription-banner-cta::after {
  display: none;
}

.subscription-banner-cta--hover {
  opacity: 0.9;
}

.preflight-overlay {
  position: absolute;
  top: calc(env(safe-area-inset-top) + 120rpx);
  left: 16rpx;
  width: 460rpx;
  min-width: 460rpx;
  max-width: 460rpx;
  z-index: 30;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  pointer-events: none;
}

.preflight-overlay--stealth {
  width: 410rpx;
  min-width: 410rpx;
  max-width: 410rpx;
}
.preflight-card {
  position: relative;
  padding: 32rpx 36rpx 28rpx;
  color: #fff;
  background: transparent;
  width: 100%;
  box-sizing: border-box;
}

.preflight-card::before {
  content: "";
  position: absolute;
  inset: 0;
  right: -100rpx;              /* 涓夎寤朵几鐨勫搴?*/
  border-radius: 24rpx 0 0 24rpx;
  background: rgba(0, 0, 0, 0.5);
  /* box-shadow: 0 12rpx 30rpx rgba(0,0,0,0); */
  clip-path: polygon(
    0% 0%,
    78% 0%,
    100% 50%,
    78% 100%,
    0% 100%
  );
  z-index: -1;
}

.preflight-title {
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.drone-picker-block {
  margin-bottom: 12rpx;
  pointer-events: auto;
}

.drone-description {
  margin-bottom: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.drone-description-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}

.drone-description-subtitle {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}

.drone-picker-display {
  display: flex;
  align-items: center;
  column-gap: 12rpx;
  pointer-events: auto;
}

.drone-picker-display:active {
  background: rgba(255, 255, 255, 0.16);
}

.drone-picker-value {
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
}

.preflight-row {
  display: flex;
  align-items: center;
  column-gap: 10rpx;
  margin-bottom: 10rpx;
  flex-wrap: nowrap;
  overflow: visible;
  width: 100%;
}

.temporary-no-fly-row {
  align-items: center;
}

.temporary-no-fly-content {
  display: flex;
  align-items: center;
  column-gap: 8rpx;
  pointer-events: auto;
  flex-wrap: nowrap;
  width: 100%;
  min-width: 0;
  overflow: hidden;
}

.temporary-no-fly-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.temporary-no-fly-link,
.temporary-no-fly-name {
  font-size: 24rpx;
  font-weight: 600;
  flex: 1;
  min-width: 0;
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.temporary-no-fly-link {
  color: #ff5e57;
  text-decoration: underline;
}

.temporary-no-fly-name {
  color: #fff;
}

.temporary-no-fly-link-hover {
  opacity: 0.8;
}

.preflight-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  white-space: nowrap;
  flex-shrink: 0;
}

.preflight-row--uom {
  position: relative;
}

.preflight-inline-loading {
  position: absolute;
  left: -26rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 18rpx;
  height: 18rpx;
  flex-shrink: 0;
  pointer-events: none;
}

.preflight-inline-loading-trace,
.preflight-inline-loading-ring,
.preflight-inline-loading-core {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  border-radius: 999rpx;
}

.preflight-inline-loading-trace {
  width: 18rpx;
  height: 18rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.26);
}

.preflight-inline-loading-ring {
  width: 18rpx;
  height: 18rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.18);
  border-top-color: rgb(28, 224, 228);
  border-right-color: rgba(255, 255, 255, 0.18);
  animation: preflight-inline-spin 960ms cubic-bezier(0.55, 0.08, 0.32, 0.95) infinite;
}

.preflight-inline-loading-core {
  width: 6rpx;
  height: 6rpx;
  background: rgb(28, 224, 228);
  animation: preflight-inline-pulse 1400ms ease-in-out infinite;
}

.preflight-value {
  font-size: 24rpx;
  font-weight: 600;
  white-space: nowrap;
}

.preflight-value.tone-safe {
  color: #dcf8e2;
  text-shadow: 0 2rpx 6rpx rgba(20, 83, 45, 0.2);
}

.preflight-value.tone-warn {
  color: #fffbf4;
  text-shadow: 0 2rpx 6rpx rgba(133, 77, 14, 0.08);
}

.preflight-value.tone-alert {
  color: #ffe1e0;
  text-shadow: 0 2rpx 6rpx rgba(136, 19, 55, 0.2);
}

.preflight-value.tone-neutral {
  color: #fff;
}

@keyframes preflight-inline-spin {
  0% {
    transform: translate(-50%, -50%) rotate(0deg);
  }

  100% {
    transform: translate(-50%, -50%) rotate(360deg);
  }
}

@keyframes preflight-inline-pulse {
  0%,
  100% {
    opacity: 0.78;
    transform: translate(-50%, -50%) scale(0.92);
  }

  50% {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1.08);
  }
}

.preflight-extra {
  display: block;
  margin: -6rpx 0 24rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.72);
  line-height: 1.4;
}

.center-pin-indicator {
  font-size: 24rpx;
  font-weight: 700;

  display: block;
  margin: -30rpx 0 24rpx;
  font-size: 22rpx;
  color: rgba(244, 228, 198, 1);
  text-shadow: 0 2rpx 6rpx rgba(133, 77, 14, 0.1);
  line-height: 1.4;
  pointer-events: auto;
  text-decoration: underline;
  text-decoration-thickness: 2rpx;
}

.like-badge {
  position: absolute;
  top: 65rpx;
  right: 65rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  border: 2rpx solid transparent;
  background: linear-gradient(135deg, rgba(0,0,0,0.18), rgba(0,0,0,0.18)) padding-box,
    linear-gradient(135deg, #fef9e7, #f8edc2, #fef9e7) border-box;
  z-index: 120;
  pointer-events: auto;
  position: absolute;
  overflow: visible;
}

.like-badge--page {
  z-index: 130;
  background: linear-gradient(135deg, rgba(0,0,0,0.18), rgba(0,0,0,0.18)) padding-box,
    linear-gradient(135deg, #f5f0d8, #e6d8aa, #f5f0d8) border-box;
}

.like-badge--inline {
  position: relative;
  top: auto;
  right: auto;
  margin-left: auto;
}

button.marker-page-share-header {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: transparent;
  border: none;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

button.marker-page-share-header::after {
  border: none;
}

.marker-page-share-header-icon {
  width: 88rpx;
  height: 88rpx;
}

button.marker-page-share-header--disabled {
  opacity: 0.5;
}

.like-badge.is-anim {
  animation: like-bounce 500ms ease-out both;
}

.like-badge-icon {
  width: 32rpx;
  height: 32rpx;
}

.like-badge-count {
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  transform: translateY(-15rpx);
}

.like-badge-label {
  position: absolute;
  top: -52rpx;
  left: 50%;
  transform: translateX(-50%);
  padding: 4rpx 10rpx;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  border-radius: 999rpx;
  font-size: 16rpx;
  pointer-events: none;
  opacity: 0.95;
  white-space: nowrap;
}

.like-badge-label--hint {
  animation: like-label-float 800ms ease-out both;
}

.like-badge-label--result {
  background: rgba(255, 255, 255, 0.9);
  color: #111;
  animation: like-label-float 900ms ease-out both;
}

.like-badge--inline .like-badge-label {
  top: -56rpx;
  left: 50%;
  right: auto;
  transform: translateX(-50%);
}

@keyframes like-bounce {
  0% {
    transform: scale(1);
  }
  25% {
    transform: scale(1.25);
    box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.45), 0 0 0 16rpx rgba(255, 255, 255, 0.25);
  }
  60% {
    transform: scale(1.08);
    box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.3), 0 0 0 28rpx rgba(255, 255, 255, 0.15);
  }
  100% {
    transform: scale(1);
    box-shadow: 0 0 0 0 rgba(255, 255, 255, 0);
  }
}

@keyframes like-label-float {
  0% {
    transform: translate(-50%, 0);
    opacity: 0;
  }
  20% {
    opacity: 1;
  }
  100% {
    transform: translate(-50%, -28rpx);
    opacity: 0;
  }
}

.picker-underline {
  text-decoration: underline;
  text-underline-offset: 4rpx;
}

.drone-picker-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.25);
  z-index: 35;
}

.drone-picker-sheet {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 40;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx 34rpx 60rpx;
  min-height: 820rpx;
  box-shadow: 0 -8rpx 36rpx rgba(0, 0, 0, 0.18);
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  pointer-events: auto;
}

.drone-picker-sheet-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24rpx;
}

.drone-picker-sheet-header .drone-description {
  margin-bottom: 0;
}

.drone-picker-sheet-header .drone-description-title {
  color: #111;
}

.drone-picker-sheet-header .drone-description-subtitle {
  color: rgba(17, 17, 17, 0.7);
}

.drone-picker-confirm {
  font-size: 30rpx;
  color: #000000;
  font-weight: 600;
}

.drone-picker-sheet-body {
  display: flex;
  gap: 20rpx;
  flex: 1;
  min-height: 640rpx;
}

.drone-category-list {
  width: 220rpx;
  max-height: 640rpx;
  background: rgba(0, 0, 0, 0.04);
  border-radius: 18rpx;
  padding: 12rpx;
  box-sizing: border-box;
}

.drone-category-item {
  padding: 18rpx 16rpx;
  border-radius: 14rpx;
  font-size: 26rpx;
  color: rgba(0, 0, 0, 0.65);
  margin-bottom: 12rpx;
  background: rgba(0, 0, 0, 0.06);
  transition: background 0.2s ease, color 0.2s ease, box-shadow 0.2s ease;
}

.drone-category-item:last-child {
  margin-bottom: 0;
}

.drone-category-item.is-active {
  background: #000000;
  color: #ffffff;
  font-weight: 600;
  box-shadow: 0 12rpx 22rpx rgba(0, 0, 0, 0.24);
}

.drone-model-list {
  flex: 1;
  max-height: 640rpx;
}

.drone-picker-option {
  padding: 22rpx 20rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.65);
  margin-bottom: 14rpx;
  background: rgba(0, 0, 0, 0.08);
  transition: background 0.2s ease, color 0.2s ease, box-shadow 0.2s ease;
}

.drone-picker-option:last-child {
  margin-bottom: 0;
}

.drone-picker-option.is-active {
  background: #000000;
  color: #fff;
  font-weight: 600;
  box-shadow: 0 12rpx 22rpx rgba(0, 0, 0, 0.24);
}

.status-hint {
  display: block;
  margin-top: 16rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.65);
}

.control-row {
  display: flex;
  align-items: center;
  justify-content: flex-start; /* 闈犲乏 */
  gap: 0;
}

.search-stack {
  flex: 1;
  width: 100%;
  position: relative;
  display: flex;
  align-items: center;
  gap: 0rpx;
  pointer-events: auto;
}

.search-pill {
  flex: 1 1 auto;
  display: flex;
  align-items: center;
  border: 2rpx solid rgba(255, 255, 255, 0.95);
  border-radius: 999rpx;
  height: 72rpx;
  min-width: 0;
  padding-left: 28rpx;
  background: rgba(0, 0, 0, 0.22);
  pointer-events: auto;
  box-shadow: 0 12rpx 24rpx rgba(0, 0, 0, 0.22) inset;
}

.search-field {
  flex: 1;
  min-width: 0;
  border: none;
  background: transparent;
  color: #fff;
  font-size: 28rpx;
  line-height: 1;
  padding: 0;
}

.search-field::placeholder {
  color: rgba(255, 255, 255, 0.85);
}

button.search-tips-btn {
  flex-shrink: 0;
  width: 54rpx;
  height: 54rpx;
  border: none;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  pointer-events: auto;
}

button.search-tips-btn::after {
  border: 0;
  content: none;
}

.search-tips-btn-icon {
  width: 40rpx;
  height: 40rpx;
  opacity: 0.92;
}

.search-tips-btn-hover {
  transform: scale(0.92);
  opacity: 0.88;
}

.search-tips-btn--outside {
  width: 40rpx;
  height: 40rpx;
  margin-left: -2rpx;
}

button.search-btn {
  flex-shrink: 0;
  width: 70rpx;
  height: 70rpx;
  margin-left: 16rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.95);
  background: rgba(255, 255, 255, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  transition: transform 0.12s ease, background-color 0.12s ease;
  pointer-events: auto;
}

button.search-btn::after {
  border: 0;
  content: none;
}

.search-btn-icon {
  width: 40rpx;
  height: 40rpx;
}

.search-btn-hover {
  transform: scale(0.9);
  background: rgba(255, 255, 255, 0.18);
}

.search-suggest-panel {
  position: absolute;
  left: 0;
  right: 0;
  top: calc(100% + 12rpx);
  border-radius: 24rpx;
  background: rgba(12, 21, 33, 0.92);
  box-shadow: 0 18rpx 32rpx rgba(0, 0, 0, 0.35);
  padding: 8rpx;
  z-index: 12;
}

.search-suggest-scroll {
  max-height: 320rpx;
  overflow: auto;
}

.search-suggest-item {
  padding: 14rpx 20rpx;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  color: #fff;
}

.search-suggest-item + .search-suggest-item {
  margin-top: 6rpx;
}

.search-suggest-item:active {
  background: rgba(255, 255, 255, 0.08);
}

.search-suggest-state {
  padding: 20rpx;
  text-align: center;
  color: rgba(255, 255, 255, 0.85);
  font-size: 24rpx;
}

.suggest-title {
  font-size: 26rpx;
  font-weight: 600;
}

.suggest-title-marker {
  color: #22c55e;
}

.suggest-title-pin {
  color: #22c55e;
}

.suggest-address {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.map-scale-container {
  position: absolute;
  left: 32rpx;
  bottom: calc(env(safe-area-inset-bottom) + 240rpx);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  z-index: 36;
  pointer-events: none;
}

.map-compass-anchor {
  position: absolute;
  left: 32rpx;
  bottom: calc(env(safe-area-inset-bottom) + 240rpx + 250rpx);
  z-index: 36;
  pointer-events: auto;
}

.map-compass-anchor--satellite {
  filter: drop-shadow(0 2rpx 8rpx rgba(0, 0, 0, 0.8));
}

.map-scale {
  position: relative;
  padding: 12rpx 0;
  color: #000;
  pointer-events: none;
}

.map-scale-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #000;
}

.map-scale-track {
  margin-top: 10rpx;
  height: 18rpx;
  position: relative;
}

.map-scale-line {
  position: absolute;
  top: 50%;
  left: 0;
  width: 100%;
  height: 4rpx;
  background: #000;
  transform: translateY(-50%);
}

.map-scale-tick {
  position: absolute;
  top: calc(50% - 8rpx);
  width: 2rpx;
  height: 16rpx;
  background: #000;
}

.map-scale-tick-start {
  left: 0;
}

.map-scale-tick-end {
  right: 0;
}

.map-center-coords {
  display: flex;
  align-items: flex-start;
  flex-direction: column;
  max-width: 380rpx;
  padding: 10rpx 0;
  pointer-events: auto;
  gap: 6rpx;
}

.map-center-coords-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #000;
  text-decoration: underline;
  text-underline-offset: 4rpx;
  line-height: 1.2;
  word-break: break-all;
}

.map-center-coords-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  align-self: stretch;
  width: 100%;
  box-sizing: border-box;
  margin-left: -1rpx;
  margin-top: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: #000;
  color: #fff;
}

.map-center-coords-pill-inner {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  white-space: nowrap;
}

.map-center-coords-pill-text {
  font-size: 20rpx;
  font-weight: 600;
  color: currentColor;
  letter-spacing: 0.3rpx;
  white-space: nowrap;
}

.map-center-coords-pill-arrow {
  width: 0;
  height: 0;
  border-left: 7rpx solid transparent;
  border-right: 7rpx solid transparent;
  border-top: 9rpx solid currentColor;
  transform: translateY(2rpx);
}

.map-scale-container--satellite .map-scale {
  color: #fff;
}

.map-scale-container--satellite .map-scale-label {
  color: #fff;
  text-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.85);
}

.map-scale-container--satellite .map-scale-line,
.map-scale-container--satellite .map-scale-tick {
  background: #fff;
  box-shadow: 0 0 6rpx rgba(0, 0, 0, 0.7);
}

.map-scale-container--satellite .map-center-coords {
  padding: 10rpx 0;
}

.map-scale-container--satellite .map-center-coords-text {
  color: #fff;
