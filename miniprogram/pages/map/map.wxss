.invite-btn.primary {
  background: #0f172a;
  color: #fff;
}

.invite-btn.secondary {
  background: #f3f4f6;
  color: #111827;
}

.invite-btn.primary:disabled {
  opacity: 0.6;
}

.checkin-guide-mask {
  position: fixed;
  left: 0;
  right: 0;
  background: transparent;
  z-index: 240;
}

.checkin-guide-mask-top {
  top: 0;
}

.checkin-guide-mask-left {
  left: 0;
  right: auto;
}

.checkin-guide-mask-right {
  right: 0;
}

.checkin-guide-mask-bottom {
  bottom: 0;
}

.checkin-guide-ring {
  position: fixed;
  display: none;
}

.checkin-guide-overlay {
  position: fixed;
  inset: 0;
  z-index: 239;
  pointer-events: none;
}

.city-report-dialog-overlay {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}

.city-report-dialog-container {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.city-report-dialog-card {
  width: 380rpx;
  max-width: 86vw;
  padding: 76rpx 48rpx 60rpx;
  border-radius: 36rpx;
  background: linear-gradient(180deg, #86b5ff 0%, #b5d1ff 30%, #eef4ff 60%, #f5f5f7 100%);
  box-shadow: 0 24rpx 60rpx rgba(0, 0, 0, 0.18);
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  text-align: center;
}

.city-report-dialog-text {
  font-size: 28rpx;
  color: #333333;
  opacity: 0.95;
  line-height: 1.6;
}

.city-report-dialog-btn {
  margin: 24rpx auto 0;
  width: 100%;
  height: 72rpx;
  border-radius: 999rpx;
  background: #1c1c1c;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "ZhSubset", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial,
    "PingFang SC", "Heiti SC", "Microsoft YaHei", sans-serif;
  padding: 0;
  border: none;
  box-sizing: border-box;
  align-self: center;
}

.city-report-dialog-btn::after {
  border: none;
}

.page--wide .drone-picker-sheet,
.page--wide .coordinate-system-sheet,
.page--wide .layer-panel,
.page--wide .call-sheet,
.page--wide .marker-detail-sheet,
.page--wide .marker-certification-sheet {
  width: calc(100vw - 64rpx);
  max-width: 920rpx;
  left: 0;
  right: 0;
  margin-left: auto;
  margin-right: auto;
}

.page--wide .marker-page-scroll {
  width: 100%;
  max-width: 980rpx;
  margin: 0 auto;
}

.map-ui-scale-left {
  transform-origin: left top;
}

.map-ui-scale-right {
  transform-origin: right center;
}

.map-ui-scale-bottom {
  transform-origin: center bottom;
}
