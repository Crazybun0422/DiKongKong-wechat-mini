<view class="subscription-feed-page">
  <scroll-view
    scroll-y="true"
    class="subscription-feed-scroll"
    refresher-enabled="true"
    refresher-triggered="{{refresherTriggered}}"
    bindrefresherrefresh="onRefresherRefresh"
  >
    <block wx:if="{{loading}}">
      <view class="subscription-feed-loading">加载中...</view>
    </block>
    <block wx:elif="{{error}}">
      <view class="subscription-feed-error">
        <text>{{error}}</text>
        <button class="subscription-feed-retry" bindtap="onRetryTap">重试</button>
      </view>
    </block>
    <block wx:else>
      <block wx:if="{{contentSegments.length}}">
        <block wx:for="{{contentSegments}}" wx:key="index">
          <rich-text
            wx:if="{{item.type === 'rich'}}"
            class="subscription-feed-content"
            nodes="{{item.nodes}}"
            space="nbsp"
            selectable="true"
          />
          <image
            wx:elif="{{item.type === 'image'}}"
            class="subscription-feed-image"
            src="{{item.src}}"
            mode="widthFix"
            show-menu-by-longpress="true"
            data-index="{{item.index}}"
            bindtap="onImageTap"
          />
        </block>
      </block>
      <rich-text
        wx:else
        class="subscription-feed-content"
        nodes="{{contentNodes}}"
        space="nbsp"
        selectable="true"
        bindtap="onRichTextTap"
      />
    </block>
  </scroll-view>

  <view
    class="subscription-banner subscription-banner--fixed"
    wx:if="{{showSubscriptionBanner}}"
  >
    <view class="subscription-banner-text">
      确保有新功能、空投福利时，您永远是第一批知道的~
    </view>
    <button
      class="subscription-banner-cta"
      hover-class="subscription-banner-cta--hover"
      bindtap="onSubscriptionBannerTap"
      loading="{{subscriptionBannerLoading}}"
    >
      立即开启
    </button>
  </view>
</view>
