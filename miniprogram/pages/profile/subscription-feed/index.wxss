.subscription-feed-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f7f8fa;
}

.subscription-feed-scroll {
  flex: 1;
  padding: 32rpx 32rpx 40rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.subscription-feed-loading,
.subscription-feed-error {
  margin-top: 120rpx;
  text-align: center;
  color: #666;
  font-size: 28rpx;
}

.subscription-feed-retry {
  margin-top: 24rpx;
  min-width: 220rpx;
  height: 72rpx;
  padding: 0 48rpx;
  line-height: 1;
  background: linear-gradient(135deg, #000000 0%, #333333 100%);
  color: #fff;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 24rpx rgba(15, 23, 42, 0.12);
}

.subscription-feed-retry::after {
  border: none;
}

.subscription-feed-content {
  font-size: 30rpx;
  color: #1f1f1f;
  line-height: 1.8;
}
.subscription-feed-image {
  display: block;
  width: 100%;
  margin: 24rpx auto;
  border-radius: 24rpx;
  background: #f5f6f7;
}

.subscription-feed-content p {
  margin: 20rpx 0;
}

.subscription-feed-content h1,
.subscription-feed-content h2,
.subscription-feed-content h3,
.subscription-feed-content h4,
.subscription-feed-content h5,
.subscription-feed-content h6 {
  margin: 32rpx 0 20rpx;
  font-weight: 600;
}

.subscription-feed-content h1 { font-size: 44rpx; }
.subscription-feed-content h2 { font-size: 38rpx; }
.subscription-feed-content h3 { font-size: 34rpx; }
.subscription-feed-content h4 { font-size: 32rpx; }
.subscription-feed-content h5 { font-size: 30rpx; }
.subscription-feed-content h6 { font-size: 28rpx; }

.subscription-feed-content .op-checkbox {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  margin-right: 8rpx;
  margin-left: 4rpx;
  border-radius: 8rpx;
  border: 2rpx solid #d9d9d9;
  font-size: 28rpx;
  color: #999;
}

.subscription-feed-content .op-checkbox.is-checked {
  color: #1677ff;
  border-color: #1677ff;
}

.subscription-feed-content ul,
.subscription-feed-content ol {
  padding-left: 48rpx;
  margin: 12rpx 0;
}

.subscription-feed-content li {
  margin-bottom: 8rpx;
}

.subscription-feed-content .op-table {
  width: 100%;
  overflow: hidden;
  border-radius: 16rpx;
  border: 2rpx solid #e5e6eb;
  margin: 24rpx 0;
}

.subscription-feed-content .op-table-head,
.subscription-feed-content .op-table-row {
  display: flex;
}

.subscription-feed-content .op-table-header-cell,
.subscription-feed-content .op-table-cell {
  flex: 1;
  padding: 20rpx 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
  border-right: 2rpx solid #f0f0f0;
  box-sizing: border-box;
}

.subscription-feed-content .op-table-row .op-table-cell:last-child,
.subscription-feed-content .op-table-head .op-table-header-cell:last-child {
  border-right: 0;
}

.subscription-feed-content .op-table-row:last-child .op-table-cell {
  border-bottom: 0;
}

.subscription-feed-content .op-table-head {
  background: #f5f7ff;
  font-weight: 600;
}

.subscription-feed-content .op-table-caption {
  padding: 12rpx 0;
  font-size: 26rpx;
  text-align: center;
  color: #888;
}

.subscription-feed-content .op-figure {
  margin: 24rpx 0;
  text-align: center;
}

.subscription-feed-content .op-figure image,
.subscription-feed-content .op-figure img {
  display: block;
  width: auto;
  max-width: calc(100% - 100rpx);
  height: auto;
  margin: 50rpx auto;
  border-radius: 16rpx;
}

.subscription-feed-content .op-figcaption {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #666;
}

.subscription-feed-content .op-link {
  color: #1677ff;
  text-decoration: underline;
}

.subscription-feed-content .op-image-container {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

.subscription-feed-content .op-image-container image,
.subscription-feed-content .op-image-container img {
  display: block;
  width: auto;
  max-width: calc(100% - 100rpx);
  height: auto;
  margin: 50rpx auto;
  border-radius: 12rpx;
}

.subscription-feed-content image,
.subscription-feed-content img {
  display: block;
  width: auto;
  max-width: calc(100% - 100rpx);
  height: auto;
  margin: 50rpx auto;
  border-radius: 12rpx;
}

.subscription-feed-content code {
  padding: 4rpx 8rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-family: Menlo, Monaco, Consolas, "Courier New", monospace;
  font-size: 26rpx;
}

.subscription-feed-content pre {
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  overflow: auto;
}

.subscription-feed-content blockquote {
  margin: 20rpx 0;
  padding: 20rpx 24rpx;
  background: #f0f5ff;
  border-left: 8rpx solid #1677ff;
  color: #3b4a69;
}

.subscription-banner {
  position: fixed;
  left: 50%;
  bottom: calc(env(safe-area-inset-bottom) + 32rpx);
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 10rpx 18rpx;
  background: rgba(64, 64, 64, 0.75);
  border-radius: 16rpx;
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.25);
  z-index: 36;
  pointer-events: auto;
  min-width:480rpx;
  max-width: 480rpx;
}

.subscription-banner-text {
  color: #f8fafc;
  font-size: 18rpx;
  line-height: 1.5;
  max-width: 360rpx;
}

.subscription-banner-cta {
  background: #cf2e2e;
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 12rpx;
  padding: 12rpx 20rpx;
  border: none;
  line-height: 1;
  min-width: 130rpx;
  box-shadow: 0 8rpx 20rpx rgba(207, 46, 46, 0.32);
}

.subscription-banner-cta::after {
  display: none;
}

.subscription-banner-cta--hover {
  opacity: 0.9;
}

.subscription-banner--fixed {
  position: fixed;
  left: 50%;
  bottom: calc(env(safe-area-inset-bottom) + 32rpx);
  transform: translateX(-50%);
}
