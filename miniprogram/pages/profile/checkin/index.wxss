.checkin-page {
  position: fixed;
  inset: 0;
  overflow: hidden;
  background: linear-gradient(180deg, #86b5ff 0%, #b5d1ff 30%, #eef4ff 60%, #f5f5f7 100%);
  color: #1a2b4a;
  font-family: "ZhSubset", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, "PingFang SC", "Heiti SC", "Microsoft YaHei", sans-serif;
  padding-bottom: 0;
  box-sizing: border-box;
}

.checkin-page--locked {
  height: 100vh;
  overflow: hidden;
}

.checkin-header {
  padding: 74rpx 32rpx 32rpx;
  transform: none;
}

.checkin-topbar {
  display: flex;
  align-items: center;
  position: relative;
  height: 72rpx;
}

button.checkin-back {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.6);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  position: relative;
  z-index: 1;
  position: absolute;
  left: 0;
}

button.checkin-back::after {
  border: none;
}

.checkin-back-icon {
  font-size: 34rpx;
  color: #1a2b4a;
}

.checkin-title {
  font-size: 34rpx;
  font-weight: 600;
  position: absolute;
  left: 0;
  right: 0;
  text-align: center;
  max-width: none;
  text-align: center;
  z-index: 0;
}

.checkin-topbar-spacer {
  width: 72rpx;
  height: 72rpx;
  position: relative;
  z-index: 1;
  margin-left: auto;
}

.checkin-hero {
  margin-top: 24rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 24rpx;
}

.checkin-hero-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.checkin-flp-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.checkin-flp-value {
  font-size: 60rpx;
  font-weight: 700;
}

.checkin-flp-unit {
  font-size: 28rpx;
  font-weight: 600;
  opacity: 0.85;
}

.checkin-flp-tip {
  font-size: 26rpx;
  color: rgba(26, 43, 74, 0.7);
}

.checkin-hero-image {
  width: 250rpx;
  flex-shrink: 0;
}

.checkin-card {
  position: relative;
  margin: calc(-24rpx - 80px + 200rpx) 32rpx 0;
  padding: 28rpx;
  background: transparent;
  box-shadow: none;
}

.checkin-card-content {
  position: relative;
  z-index: 1;
  transform: translateY(-220rpx);
}

.checkin-card-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
  transform: translateY(-70rpx);
  transform-origin: top center;
}

.checkin-card--no-banner .checkin-card-bg {
  transform: translateY(-70rpx) scaleY(0.92);
}

.checkin-card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  position: relative;
  margin-bottom: 8rpx;
  min-height: 120rpx;
}

.checkin-card-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 0;
  margin-top: 170rpx;
  position: relative;
  z-index: 1;
}

.checkin-card-title-text {
  position: relative;
  z-index: 2;
}

.checkin-card-ribbon {
  position: relative;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: visible;
  z-index: 1;
}

.checkin-card-ribbon-bg {
  position: absolute;
  left: 40%;
  bottom: -4rpx;
  width: 140rpx;
  height: 42rpx;
  transform: translateX(-50%);
  z-index: 0;
}

.checkin-card-days {
  color: #ff5aa5;
  font-size: 48rpx;
  font-weight: 700;
  position: relative;
  z-index: 2;
}

.checkin-card-hero {
  width: 340rpx;
  position: absolute;
  top: 10px;
  right: -50rpx;
}

.checkin-card > view,
.checkin-card > button {
  position: relative;
  z-index: 1;
}

.checkin-week-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 6rpx;
}

.checkin-card-body {
  transform: translateY(50rpx);
}

.checkin-card-body--no-banner {
  transform: translateY(50rpx);
}

.checkin-day-card {
  position: relative;
  width: calc(25% - 18rpx);
  background: #f5f6f9;
  border-radius: 22rpx;
  padding: 8rpx 4rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  left: 20rpx;
  box-sizing: border-box;
}

.checkin-day-card.is-sunday {
  width: calc(50% - 25rpx);
  min-height: 180rpx;
  padding: 16rpx 12rpx 20rpx;
}

.checkin-turntable {
  position: absolute;
  top: 0rpx;
  right: 0rpx;
  width: 72rpx;
  height: 72rpx;
  padding: 0;
  margin: 0;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.checkin-turntable--active {
  transform: none;
}

.checkin-turntable-image {
  width: 72rpx;
  height: 72rpx;
  transform-origin: center;
  transform: scale(1.24);
}

.checkin-turntable.is-breathing .checkin-turntable-image {
  animation: checkinTurntableBreath 1.6s ease-in-out infinite;
}

.checkin-turntable--active .checkin-turntable-image {
  animation-play-state: paused;
  transform: scale(0.94);
  filter: none;
}

@keyframes checkinTurntableBreath {
  0% {
    transform: scale(1.1);
    filter: none;
  }
  50% {
    transform: scale(1.24);
    filter: none;
  }
  100% {
    transform: scale(1.1);
    filter: none;
  }
}
.checkin-day-card.is-actionable {
  box-shadow: 0 12rpx 20rpx rgba(24, 42, 82, 0.12);
  border: 2rpx solid rgba(38, 111, 255, 0.35);
}

.checkin-reward {
  font-size: 18rpx;
  font-weight: 600;
}

.checkin-icon-wrap {
  width: 84rpx;
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.checkin-day-image {
  width: 84rpx;
  height: 84rpx;
}

.checkin-today-icon {
  position: relative;
  width: 84rpx;
  height: 84rpx;
}

.checkin-day-check {
  position: absolute;
  width: 30rpx;
  height: 30rpx;
  right: -2rpx;
  bottom: -4rpx;
}

.checkin-weekday {
  font-size: 18rpx;
  color: rgba(26, 43, 74, 0.6);
}

.checkin-bonus {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  padding: 4rpx 10rpx;
  background: #38bdf8;
  color: #111;
  font-size: 18rpx;
  border-radius: 999rpx;
  transform: rotate(10deg);
}


.checkin-action-btn {
  margin-top: 18rpx;
  height: 88rpx;
  border-radius: 44rpx;
  width: 560rpx !important;
  max-width: none;
  background: #1b1f26;
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-sizing: border-box;
}

.checkin-action-btn::after {
  border: none;
}

.checkin-action-btn.is-disabled,
.checkin-action-btn[disabled] {
  background: rgba(0, 0, 0, 0.35) !important;
  color: rgba(255, 255, 255, 0.85) !important;
}

.checkin-action-wrap {
  position: relative;
  overflow: visible;
}

.checkin-action-btn-wrap {
  display: flex;
  justify-content: center;
}

.checkin-subscription-banner {
  position: absolute;
  left: 130rpx;
  right: 130rpx;
  top: calc(100% + 16rpx);
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 10rpx 25rpx;
  background: rgba(255, 255, 255, 0.7);
  border-radius: 16rpx;
  box-shadow: none;
  box-sizing: border-box;
}

.checkin-subscription-text {
  color: #1a2b4a;
  font-size: 18rpx;
  line-height: 1.5;
  flex: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.checkin-subscription-cta {
  background: #cf2e2e;
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 12rpx;
  width: 200rpx !important;
  min-width: 88rpx;
  padding: 12rpx 12rpx;
  border: none;
  line-height: 1;
  box-shadow: 0 8rpx 20rpx rgba(207, 46, 46, 0.32);
  flex-shrink: 0;
}

.checkin-subscription-cta::after {
  display: none;
}

.checkin-subscription-cta--hover {
  opacity: 0.9;
}

.checkin-task-card {
  margin: -50rpx 32rpx 0;
  padding: 32rpx;
  background: #fff;
  border-radius: 32rpx;
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.08);
}

.checkin-task-card--no-banner {
  margin-top: -100rpx;
}

.checkin-task-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a2b4a;
  margin-bottom: 24rpx;
}

.checkin-task-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 18rpx 0;
}

.checkin-task-item + .checkin-task-item {
  border-top: 2rpx solid rgba(26, 43, 74, 0.08);
}

.checkin-task-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
  min-width: 0;
}

.checkin-task-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a2b4a;
}

.checkin-task-desc {
  font-size: 24rpx;
  color: rgba(26, 43, 74, 0.65);
}

.checkin-task-action {
  width: 200rpx !important;
  height: 56rpx !important;
  padding: 0 !important;
  border-radius: 999rpx;
  background: #111;
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 56rpx !important;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-left: auto;
  box-sizing: border-box;
  flex-shrink: 0;
}

.checkin-task-action::after {
  display: none;
}

.checkin-loading-mask {
  position: fixed;
  inset: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, rgba(134, 181, 255, 0.9) 0%, rgba(181, 209, 255, 0.9) 40%, rgba(238, 244, 255, 0.95) 100%);
}

.checkin-loading-card {
  padding: 0;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
}

.checkin-loading-image {
  width: 240rpx;
  height: 240rpx;
}

.checkin-loading,
.checkin-error {
  margin: 32rpx 32rpx 0;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  font-size: 26rpx;
  color: rgba(26, 43, 74, 0.7);
  text-align: center;
}

.checkin-lottery-mask {
  position: fixed;
  inset: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(12, 20, 44, 0.8);
}

.checkin-lottery-card {
  position: relative;
  width: 650rpx;
  height: 694rpx;
  background: transparent;
}

.checkin-lottery-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.checkin-lottery-spray {
  position: absolute;
  bottom: 0rpx;
  left: -10rpx;
  width: 280rpx;
  z-index: 3;
  animation: checkinFlyInBottom 1s ease-out both;
}

.checkin-lottery-title {
  position: absolute;
  top: -50rpx;
  left: 80%;
  width: 280rpx;
  transform: translateX(-50%);
  z-index: 2;
  animation: checkinFlyInTop 1s ease-out both;
}

.checkin-lottery-grid {
  position: absolute;
  left: 136.4rpx;
  top: 134.9rpx;
  width: 391.6rpx;
  height: 421.7rpx;
  display: grid;
  grid-template-columns: repeat(3, 120.9rpx);
  grid-template-rows: repeat(3, 129.1rpx);
  gap: 17.2rpx 14.4rpx;
  align-items: center;
  justify-items: center;
}

.checkin-lottery-result {
  position: absolute;
  left: 136.4rpx;
  top: 134.9rpx;
  width: 391.6rpx;
  height: 421.7rpx;
  z-index: 4;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkin-lottery-frost {
  position: absolute;
  inset: 0;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.22);
  border: 1rpx solid rgba(255, 255, 255, 0.4);
  backdrop-filter: blur(18.8rpx);
  -webkit-backdrop-filter: blur(18.8rpx);
}

.checkin-lottery-result-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
}

.checkin-lottery-result-image {
  width: 195rpx;
  height: 195rpx;
}

.checkin-lottery-result-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #1b1f26;
  text-shadow: 0 4.5rpx 11.5rpx rgba(255, 255, 255, 0.8);
  animation: checkinLotteryPulse 1.8s ease-in-out infinite;
}

.checkin-lottery-claim {
  width: 216.7rpx !important;
  height: 60.6rpx;
  border-radius: 999rpx;
  background: #0f1216;
  color: #fff;
  font-size: 28rpx !important;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-top: 6.5rpx;
  padding: 0;
  min-width: 0;
  line-height: 60.6rpx;
  align-self: center;
  box-sizing: border-box;
}

.checkin-lottery-claim::after {
  border: none;
}

.checkin-lottery-cell {
  width: 120.9rpx;
  height: 129.1rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkin-lottery-prize-card {
  width: 120.9rpx;
  height: 129.1rpx;
  border-radius: 23.4rpx;
  background: transparent;
  box-shadow: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4.3rpx;
  transition: background 120ms ease, box-shadow 120ms ease, transform 120ms ease;
}

.checkin-lottery-prize-card.is-active {
  background: rgba(255, 221, 138, 0.55);
  box-shadow: 0 10.8rpx 23.8rpx rgba(255, 198, 92, 0.4);
  transform: translateY(5.4rpx);
}

.checkin-lottery-prize-card.is-active .checkin-lottery-text {
  color: #b97900;
}

.checkin-lottery-button {
  width: 161.6rpx;
  height: 142rpx;
  border-radius: 24rpx;
  font-size: 32.5rpx;
  font-weight: 800;
  letter-spacing: 2.4rpx;
  color: #7a4a00;
  background: transparent;
  border: none;
  line-height: 142rpx;
  padding: 0;
  text-shadow: 0 2.2rpx 6.9rpx rgba(255, 255, 255, 0.5);
  margin-left: 0 !important;
  transform: translateY(-0.5rpx);
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkin-lottery-button::after {
  border: none;
}

.checkin-lottery-button-text {
  display: inline-block;
  transition: transform 120ms ease, letter-spacing 120ms ease, text-shadow 120ms ease;
}

.checkin-lottery-button-text--android {
  margin-left: 2rpx;
}

.checkin-lottery-button-text--ios {
  margin-left: -10rpx;
}

.checkin-lottery-button-text.is-active {
  transform: scale(0.92);
  letter-spacing: 1.1rpx;
  text-shadow: 0 1rpx 3rpx rgba(255, 255, 255, 0.35);
}

.checkin-lottery-coin {
  width: 58.5rpx;
  height: 58.5rpx;
}

.checkin-lottery-coin--non-flp {
  border-radius: 999rpx;
  overflow: hidden;
  transform: scale(1.12);
}

.checkin-lottery-coin--non-flp-low {
  transform: scale(1.22);
}

.checkin-lottery-coin--non-flp-lowest {
  transform: scale(1.34);
  animation: checkinLotteryImageBlinkScale 1.6s ease-in-out infinite;
}

.checkin-lottery-text--non-flp {
  font-size: 16rpx;
}

.checkin-lottery-text--non-flp.checkin-lottery-text--low,
.checkin-lottery-text--non-flp.checkin-lottery-text--lowest {
  font-size: 16rpx;
  animation: none;
  transform: none;
}

.checkin-lottery-text {
  font-size: 19.5rpx;
  font-weight: 700;
  color: #8fa5cc;
  margin-top: 6.5rpx;
  letter-spacing: 1.1rpx;
}

.checkin-lottery-text--low {
  font-size: 28.2rpx;
  font-weight: 800;
  color: #1b1f26;
}

.checkin-lottery-text--lowest {
  font-size: 34.7rpx;
  font-weight: 900;
  color: transparent;
  background-image: linear-gradient(120deg, #a87312 0%, #d2a84a 35%, #8b5c0f 70%, #f0d28a 100%);
  background-clip: text;
  -webkit-background-clip: text;
  text-shadow: 0 2rpx 6rpx rgba(255, 255, 255, 0.5);
  animation: checkinLotteryBreath 1.6s ease-in-out infinite;
}

@keyframes checkinLotteryImageBlinkScale {
  0%,
  100% {
    opacity: 1;
    transform: scale(1.34);
  }
  50% {
    opacity: 0.4;
    transform: scale(1.48);
  }
}

@keyframes checkinLotteryBreath {
  0% {
    transform: scale(1);
    text-shadow: 0 2rpx 6rpx rgba(255, 255, 255, 0.45);
  }
  50% {
    transform: scale(1.06);
    text-shadow: 0 6rpx 14rpx rgba(255, 255, 255, 0.65);
  }
  100% {
    transform: scale(1);
    text-shadow: 0 2rpx 6rpx rgba(255, 255, 255, 0.45);
  }
}

@keyframes checkinFlyInTop {
  0% {
    opacity: 0;
    transform: translate(-50%, -60rpx);
  }
  100% {
    opacity: 1;
    transform: translate(-50%, 0);
  }
}

@keyframes checkinFlyInBottom {
  0% {
    opacity: 0;
    transform: translateY(60rpx);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes checkinLotteryPulse {
  0% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-6rpx);
  }
  100% {
    transform: translateY(0);
  }
}

