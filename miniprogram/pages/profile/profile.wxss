.profile-page {
  position: relative;
  min-height: 100vh;
  padding-top: calc(env(safe-area-inset-top) + 140rpx);
  padding-bottom: env(safe-area-inset-bottom);
  box-sizing: border-box;
  background: #f5f5f7;
  margin-top: -30rpx;
}

.subscribe-wait-overlay {
  position: absolute;
  inset: 0;
  display: block;
  z-index: 37;
  pointer-events: none;
}

.subscribe-wait-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.35);
}

.subscribe-wait-image-wrap {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  justify-content: center;
  pointer-events: none;
}

.subscribe-wait-image {
  width: 100wh;
  max-width: 92%;
  opacity: 0.95;
  pointer-events: none;
}

.status-breath-button {
  position: absolute;
  top: calc(env(safe-area-inset-top) + 5.1vh);
  right: 30vw;
  width: 150rpx;
  height: 50rpx;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: center;
  transform-origin: center;
  pointer-events: auto;
}

.status-breath-button.is-breathing {
  animation: status-breath 2.2s ease-in-out infinite;
}

.status-breath-image {
  width: 150rpx;
  height: 50rpx;
}

@keyframes status-breath {
  0% {
    transform: scale(1);
    opacity: 0.9;
    filter: drop-shadow(0 0 0 rgba(0, 0, 0, 0));
  }
  50% {
    transform: scale(1.1);
    opacity: 1;
    filter: drop-shadow(0 6rpx 10rpx rgba(0, 0, 0, 0.18));
  }
  100% {
    transform: scale(1);
    opacity: 0.9;
    filter: drop-shadow(0 0 0 rgba(0, 0, 0, 0));
  }
}

.profile-scroll {
  padding: 48rpx 40rpx 220rpx;
  box-sizing: border-box;
  min-height: 100vh;
}

.profile-loading,
.profile-error {
  margin-top: 220rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  color: rgba(15, 23, 42, 0.6);
  font-size: 28rpx;
}

.profile-retry-btn {
  padding: 0 48rpx;
  height: 72rpx;
  line-height: 1;
  background: linear-gradient(135deg, #000000 0%, #333333 100%);
  color: #fff;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 24rpx rgba(15, 23, 42, 0.12);
}

.profile-retry-btn::after {
  border: none;
}

.profile-content {
  display: flex;
  flex-direction: column;
  gap: 36rpx;
}

.profile-header-card {
  display: flex;
  min-height: 200rpx;
  background: #f5f5f7;
  border-radius: 32rpx;
  /* padding: 32rpx; */
  align-items: center;
  /* box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.08); */
}

.profile-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  background: #eceff3;
}

.profile-header-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

button.profile-avatar-button {
  border: none;
  padding: 0;
  margin: 0;
  margin-right: 32rpx;
  margin-left: 40rpx;
  background: transparent;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  /* position: relative; */
  /* flex:1; */
  /* display: flex; */
  align-items: center;
  justify-content: center;
}

button.profile-avatar-button::after {
  border: none;
}

.avatar-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 38rpx;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 20rpx;
}

.profile-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.profile-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #0f172a;
}

.profile-name-edit {
  font-size: 20rpx;
  color: rgba(15, 23, 42, 0.45);
  margin-left: 8rpx;
}

.profile-like-row {
  margin-top: 8rpx;
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.profile-like-label {
  font-size: 22rpx;
  color: rgba(15, 23, 42, 0.55);
}

.profile-like-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
  transform:translateY(5rpx);
}

.profile-name-input {
  flex: 1;
  min-width: 40%;
  max-width: 60%;
  height: 70rpx;
  border-radius: 20rpx;
  /* border: 1rpx solid rgba(15, 23, 42, 0.1); */
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #0f172a;
  background: rgba(15, 23, 42, 0.00);
}

.profile-code-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 26rpx;
  color: rgba(15, 23, 42, 0.6);
}

.profile-code-label {
  color: rgba(15, 23, 42, 0.45);
}

.profile-code-value {
  color: #0f172a;
  font-weight: 500;
}

.profile-code-copy {
  font-size: 24rpx;
  color: #000000;
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.08);
}

.checkin-guide-mask {
  position: fixed;
  left: 0;
  right: 0;
  background: transparent;
  z-index: 240;
}

.checkin-guide-mask-top {
  top: 0;
}

.checkin-guide-mask-left {
  left: 0;
  right: auto;
}

.checkin-guide-mask-right {
  right: 0;
}

.checkin-guide-mask-bottom {
  bottom: 0;
}

.checkin-guide-ring {
  position: fixed;
  display: none;
}

.checkin-guide-overlay {
  position: fixed;
  inset: 0;
  z-index: 239;
  pointer-events: none;
}

.invite-guide-mask {
  position: fixed;
  left: 0;
  right: 0;
  background: transparent;
  z-index: 240;
}

.invite-guide-mask-top {
  top: 0;
}

.invite-guide-mask-left {
  left: 0;
  right: auto;
}

.invite-guide-mask-right {
  right: 0;
}

.invite-guide-mask-bottom {
  bottom: 0;
}

.invite-guide-rect {
  position: fixed;
  border: 2rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 40rpx;
  box-sizing: border-box;
  background: transparent;
  box-shadow: 0 0 0 2000px rgba(0, 0, 0, 0.6);
  pointer-events: none;
  z-index: 241;
}

.checkin-guide-introduce {
  position: fixed;
  width: 180rpx;
  transform: translateY(-50rpx);
  z-index: 241;
  pointer-events: none;
}

.profile-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 10rpx 26rpx rgba(15, 23, 42, 0.06);
}

.profile-card-left {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.profile-card-title {
  font-size: 28rpx;
  color: rgba(15, 23, 42, 0.55);
}

.profile-card-value {
  font-size: 48rpx;
  font-weight: 600;
  color: #0f172a;
}

.profile-card-arrow {
  width: 50rpx;
  height: 50rpx;
  flex-shrink: 0;
  filter: brightness(0) saturate(100%);
  opacity: 0.6;
  display: block;
}

.profile-section {
  background: #fff;
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.profile-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
  margin-bottom: 24rpx;
}

.profile-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.profile-list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0rpx 16rpx;
  border-radius: 24rpx;
  min-height: 80rpx;
  background: rgba(15, 23, 42, 0.02);
}

button.profile-list-item {
  width: 100%;
  border: none;
  background: rgba(15, 23, 42, 0.02);
  padding: 0rpx 16rpx;
  font-weight: 400;
  color: inherit;
}

button.profile-list-item::after {
  border: none;
}

.profile-list-item-hover {
  background: rgba(0, 0, 0, 0.08);
}

.profile-list-item-contact {
  position: relative;
}

.profile-list-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.profile-list-icon {
  width: 44rpx;
  height: 44rpx;
  flex-shrink: 0;
  filter: brightness(0) saturate(100%);
  opacity: 0.85;
}

.profile-list-text {
  font-size: 28rpx;
  color: #0f172a;
}

.profile-list-tag {
  font-size: 22rpx;
  color: #000000;
  background: rgba(0, 0, 0, 0.12);
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}

.profile-list-arrow {
  width: 50rpx;
  height: 50rpx;
  flex-shrink: 0;
  filter: brightness(0) saturate(100%);
  opacity: 0.6;
  /* opacity: 0.55;
  display: block; */
}

.profile-list-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.subscription-badge {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #f85a54;
  box-shadow: 0 0 0 2rpx rgba(248, 90, 84, 0.2);
  animation: badge-breath 1.6s infinite ease-in-out;
}

@keyframes badge-breath {
  0% {
    transform: scale(1);
    opacity: 1;
  }
  50% {
    transform: scale(1.2);
    opacity: 0.72;
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

.profile-footnote {
  font-size: 24rpx;
  color: rgba(15, 23, 42, 0.45);
  text-align: center;
}

.bottom-controls {
  position: fixed;
  left: 55%;
  bottom: calc(env(safe-area-inset-bottom) + 42rpx);
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: 0;
  z-index: 40;
}

.bottom-menu {
  flex: 0 0 420rpx;
  width: 220rpx;
  height: 120rpx;
  border-radius: 999rpx;
  margin-right: 40rpx;
  background: rgba(255, 255, 255, 0.95);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  box-shadow: 0 18rpx 36rpx rgba(0, 0, 0, 0.2);
}

.bottom-menu button.menu-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: none;
  background: transparent;
  padding: 0;
  color: #000000;
  font-size: 22rpx;
  row-gap: 8rpx;
}

.bottom-menu button.menu-btn:active {
  transform: scale(0.95);
}

.menu-icon {
  width: 64rpx;
  height: 64rpx;
  filter: brightness(0) saturate(100%);
  opacity: 1;
  transition: opacity 0.2s ease;
}

.menu-label {
  font-size: 22rpx;
  color: #000000;
  opacity: 1;
  transition: opacity 0.2s ease;
}

.menu-btn.is-active .menu-label {
  color: #1c66e1;
  font-weight: 600;
  opacity: 1;
}

.menu-btn.is-active .menu-icon {
  filter: none;
  opacity: 1;
}

.chat-fab {
  position: relative;
  flex: 0 0 120rpx;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 20px;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 18rpx 34rpx rgba(0, 0, 0, 0.22);
  border: none;
  display: flex;
  align-items: center;
  padding: 0;
  justify-content: center;
}

.chat-fab::after {
  border: none;
}

.chat-fab-icon {
  width: 64rpx;
  height: 64rpx;
  filter: brightness(0) saturate(100%);
}

.chat-fab-hover {
  transform: scale(0.95);
}

.chat-fab-icon {
  width: 52rpx;
  height: 52rpx;
}
