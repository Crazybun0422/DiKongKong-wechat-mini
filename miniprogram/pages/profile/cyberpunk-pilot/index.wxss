.cyber-page {
  min-height: 100vh;
  padding: calc(env(safe-area-inset-top) + 118rpx) 24rpx 40rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top left, rgba(0, 238, 255, 0.18), transparent 34%),
    radial-gradient(circle at top right, rgba(242, 75, 188, 0.16), transparent 32%),
    linear-gradient(180deg, #040814 0%, #090f1f 42%, #050914 100%);
  color: #ffffff;
  position: relative;
  overflow: visible;
}

.cyber-noise {
  position: absolute;
  inset: 0;
  opacity: 0.08;
  background-image:
    linear-gradient(rgba(255, 255, 255, 0.08) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(255, 255, 255, 0.06) 1rpx, transparent 1rpx);
  background-size: 24rpx 24rpx;
  pointer-events: none;
}

.cyber-topbar,
.cyber-content,
.cyber-state {
  position: relative;
  z-index: 1;
}

.cyber-topbar {
  height: 104rpx;
  display: flex;
  align-items: center;
}

.cyber-back {
  width: 140rpx;
  height: 72rpx;
  padding: 0;
  margin: 0;
  border: 0;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  overflow: visible;
  transform: translateX(-150rpx);
}

.cyber-back::after {
  border: none;
}

.cyber-back-image {
  width: 74rpx;
  height: 41rpx;
  display: block;
  filter: drop-shadow(0 0 14rpx rgba(92, 240, 255, 0.38));
}

.cyber-state {
  min-height: 880rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 28rpx;
}

.cyber-state-ring {
  width: 132rpx;
  height: 132rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(99, 235, 255, 0.82);
  border-right-color: rgba(255, 110, 214, 0.85);
  animation: cyber-spin 1.2s linear infinite;
}

.cyber-state-text {
  font-size: 26rpx;
  color: rgba(236, 243, 255, 0.82);
}

.cyber-retry {
  min-width: 220rpx;
  height: 76rpx;
  padding: 0 30rpx;
  border: 0;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(68, 241, 255, 0.18), rgba(255, 76, 194, 0.22));
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  box-shadow: inset 0 0 0 2rpx rgba(126, 237, 255, 0.28);
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  line-height: 1;
}

.cyber-retry::after {
  border: none;
}

.cyber-content {
  padding-top: 12rpx;
}

.cyber-strip-shell {
  padding: 24rpx 20rpx 36rpx;
  border-radius: 34rpx;
  background: rgba(6, 14, 30, 0.72);
  border: 2rpx solid rgba(126, 240, 255, 0.2);
  box-shadow:
    inset 0 0 0 2rpx rgba(255, 255, 255, 0.02),
    0 24rpx 48rpx rgba(0, 0, 0, 0.26);
  backdrop-filter: blur(14rpx);
}

.cyber-strip {
  width: 100%;
  white-space: nowrap;
}

.cyber-strip-track {
  display: flex;
  gap: 20rpx;
  padding-top: 24rpx;
  padding-bottom: 28rpx;
  padding-right: 28rpx;
  box-sizing: border-box;
}

.cyber-avatar-card {
  position: relative;
  flex: 0 0 156rpx;
  width: 156rpx;
  height: 156rpx;
  padding: 14rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.05);
  border: 2rpx solid rgba(255, 255, 255, 0.06);
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: visible;
}

.cyber-avatar-status {
  position: absolute;
  left: 50%;
  bottom: 30rpx;
  transform: translateX(-50%);
  padding: 0 12rpx;
  height: 26rpx;
  border-radius: 999rpx;
  background: rgba(245, 158, 11, 0.18);
  box-shadow: inset 0 0 0 1rpx rgba(245, 158, 11, 0.42);
  color: #f6bf4a;
  font-size: 16rpx;
  line-height: 26rpx;
  font-weight: 700;
  white-space: nowrap;
  z-index: 3;
}

.cyber-avatar-card.is-selected {
  transform: none;
  border-color: rgba(127, 237, 255, 0.72);
  box-shadow:
    0 0 0 2rpx rgba(255, 100, 205, 0.18),
    0 22rpx 40rpx rgba(0, 0, 0, 0.24),
    0 0 34rpx rgba(87, 235, 255, 0.16);
}

.cyber-avatar-frame {
  width: 104rpx;
  height: 104rpx;
  padding: 4rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(88, 246, 255, 0.96), rgba(255, 93, 193, 0.84));
  box-shadow:
    0 0 0 2rpx rgba(255, 255, 255, 0.05),
    0 14rpx 26rpx rgba(0, 0, 0, 0.22);
  box-sizing: border-box;
}

.cyber-avatar-image {
  width: 100%;
  height: 100%;
  display: block;
  border-radius: 50%;
}

.cyber-confirm-wrap {
  padding-top: 22rpx;
  display: flex;
  justify-content: flex-end;
}

.cyber-confirm-btn {
  min-width: 246rpx;
  height: 84rpx;
  padding: 0 34rpx 0 28rpx;
  border: 0;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #50f5ff 0%, #83b4ff 42%, #ff5ab9 100%);
  color: #07111f;
  font-size: 28rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-shadow:
    0 18rpx 32rpx rgba(48, 196, 255, 0.25),
    0 0 32rpx rgba(255, 88, 192, 0.18);
}

.cyber-confirm-btn::after {
  border: none;
}

.cyber-confirm-vip {
  width: 104rpx;
  height: 68rpx;
}

.cyber-preview {
  position: relative;
  margin-top: 22rpx;
  height: 940rpx;
  overflow: hidden;
  box-shadow: none;
}

.cyber-preview-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  display: block;
  filter: blur(30rpx);
  transform: scale(1.14);
  z-index: 0;
}

.cyber-preview-stage {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  box-sizing: border-box;
  z-index: 1;
}

.cyber-preview-image {
  width: calc(100% - 72rpx);
  height: calc(100% - 72rpx);
  display: block;
  position: relative;
  z-index: 1;
  filter: drop-shadow(0 26rpx 34rpx rgba(0, 0, 0, 0.34));
}

@keyframes cyber-spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}
