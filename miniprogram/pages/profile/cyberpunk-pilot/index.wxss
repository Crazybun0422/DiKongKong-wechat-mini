.cyber-page {
  min-height: 100vh;
  padding: calc(env(safe-area-inset-top) + 24rpx) 32rpx 48rpx;
  box-sizing: border-box;
  background: #0b1020;
  color: #ffffff;
}

.cyber-topbar {
  height: 72rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.cyber-back {
  width: 64rpx;
  height: 64rpx;
  padding: 0;
  margin: 0;
  border: 0;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
  color: #ffffff;
  font-size: 52rpx;
  line-height: 58rpx;
}

.cyber-back::after {
  border: none;
}

.cyber-title {
  font-size: 32rpx;
  font-weight: 700;
}

.cyber-hero {
  min-height: 620rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}

.pilot-avatar {
  position: relative;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background:
    linear-gradient(145deg, rgba(31, 41, 55, 0.96), rgba(3, 7, 18, 0.98)),
    #111827;
  border: 4rpx solid rgba(103, 232, 249, 0.72);
  box-shadow: 0 0 50rpx rgba(34, 211, 238, 0.28), inset 0 -24rpx 50rpx rgba(236, 72, 153, 0.18);
  overflow: hidden;
}

.pilot-visor {
  position: absolute;
  left: 44rpx;
  right: 44rpx;
  top: 94rpx;
  height: 58rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #22d3ee 0%, #a78bfa 45%, #ec4899 100%);
  box-shadow: 0 0 34rpx rgba(34, 211, 238, 0.58);
}

.pilot-glow {
  position: absolute;
  bottom: 52rpx;
  width: 74rpx;
  height: 90rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.08);
}

.pilot-glow--left {
  left: 58rpx;
}

.pilot-glow--right {
  right: 58rpx;
}

.pilot-name {
  font-size: 42rpx;
  font-weight: 800;
}

.pilot-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.62);
}

.cyber-panel {
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  overflow: hidden;
}

.cyber-row {
  min-height: 96rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.cyber-row + .cyber-row {
  border-top: 2rpx solid rgba(255, 255, 255, 0.08);
}

.cyber-row-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.62);
}

.cyber-row-value {
  font-size: 26rpx;
  color: #ffffff;
}
