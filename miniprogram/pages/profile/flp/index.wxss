.flp-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f3f4f6 0%, #ffffff 60%);
  color: #121212;
}

.flp-scroll {
  height: 100vh;
  box-sizing: border-box;
  padding: 56rpx 48rpx 120rpx;
}

.flp-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 48rpx;
}

.flp-header {
  display: flex;
  margin-top: 100rpx;
  justify-content: center;
  gap: 40rpx;
}

.flp-balance-value {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.flp-balance-number {
  font-size: 96rpx;
  font-weight: 600;
  color: #111111;
  line-height: 1;
}

.flp-balance-unit {
  font-size: 36rpx;
  color: #4b5563;
  font-weight: 500;
}

.flp-detail-entry {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  margin-top: 20rpx;
  margin-left: 50rpx;
}

.flp-detail-entry-hover {
  opacity: 0.6;
}

.flp-detail-icon {
  width: 52rpx;
}

.flp-detail-text {
  font-size: 28rpx;
  color: #4b5563;
  letter-spacing: 4rpx;
}

.flp-benefits-card {
  width: 100%;
  max-width: 660rpx;
  background: #ffffff;
  border-radius: 34rpx;
  padding: 0;
  box-shadow: 0 14rpx 40rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.flp-rights-section {
  padding: 34rpx 30rpx 46rpx;
}

.flp-rights-title {
  display: block;
  font-size: 26rpx;
  line-height: 1.2;
  font-weight: 600;
  color: #111827;
  margin-bottom: 28rpx;
}

.flp-rights-list {
  display: flex;
  align-items: flex-start;
  justify-content: flex-start;
  gap: 0;
}

.flp-right-item {
  flex: 0 0 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.flp-right-item--placeholder {
  visibility: hidden;
}

.flp-right-icon {
  width: 62rpx;
  height: 62rpx;
  margin-bottom: 14rpx;
}

.flp-right-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #111827;
  line-height: 1.2;
}

.flp-right-desc {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #6b7280;
  line-height: 1.25;
}

.flp-benefit-item {
  display: flex;
  align-items: center;
  padding: 34rpx 34rpx;
  gap: 24rpx;
}

.flp-benefit-item + .flp-benefit-item {
  border-top: 1px solid rgba(17, 24, 39, 0.06);
}

.flp-benefit-info {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  flex: 1;
  min-width: 0;
}

.flp-benefit-action {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex: 0 0 auto;
}

.flp-benefit-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
}

.flp-benefit-desc {
  font-size: 26rpx;
  color: #7b8088;
}

.flp-action-btn {
  margin-left: 16rpx;
  padding: 10rpx 14rpx;
  font-size: 24rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #000000 0%, #3a3939 100%);
  border-radius: 999rpx;
  border: none;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 164rpx !important;
  min-width: 164rpx !important;
  max-width: 164rpx;
  white-space: nowrap;
  box-sizing: border-box;
}

.flp-action-btn::after {
  display: none;
}

.flp-help-container {
  width: 100%;
  max-width: 660rpx;
  text-align: center;
}

.flp-help-link {
  display: inline-block;
  padding: 0rpx 0;
  font-size: 32rpx;
  margin-top: -40rpx;
  color: #050505;
  text-decoration: underline;
}

.flp-help-link-active {
  opacity: 0.7;
}

.invite-guide-mask {
  position: fixed;
  left: 0;
  right: 0;
  background: transparent;
  z-index: 240;
}

.invite-guide-mask-top {
  top: 0;
}

.invite-guide-mask-left {
  left: 0;
  right: auto;
}

.invite-guide-mask-right {
  right: 0;
}

.invite-guide-mask-bottom {
  bottom: 0;
}

.invite-guide-overlay {
  position: fixed;
  inset: 0;
  z-index: 239;
  pointer-events: none;
}

@media (max-width: 750rpx) {
  .flp-scroll {
    padding: 48rpx 32rpx 96rpx;
  }

  .flp-header {
    flex-direction: column;
    align-items: center;
    gap: 24rpx;
  }

  .flp-balance-value {
    justify-content: center;
  }

  .flp-benefit-item {
    padding: 32rpx 28rpx;
    gap: 18rpx;
  }

  .flp-action-btn {
    margin-left: 12rpx;
    padding: 8rpx 12rpx;
    font-size: 24rpx;
    width: 156rpx !important;
    min-width: 156rpx !important;
    max-width: 156rpx;
  }
}
