<view class="flp-reward-page">
  <scroll-view scroll-y="true" class="flp-reward-scroll">
    <block wx:if="{{loading}}">
      <view class="flp-reward-loading">加载中...</view>
    </block>
    <block wx:elif="{{error}}">
      <view class="flp-reward-error">
        <text>{{error}}</text>
        <button class="flp-reward-retry" bindtap="onRetryTap">重试</button>
      </view>
    </block>
    <block wx:else>
      <block wx:if="{{contentSegments.length}}">
        <block wx:for="{{contentSegments}}" wx:key="index">
          <rich-text
            wx:if="{{item.type === 'rich'}}"
            class="flp-reward-content"
            nodes="{{item.nodes}}"
            space="nbsp"
            selectable="true"
            bindtap="onRichTextTap"
          />
          <image
            wx:elif="{{item.type === 'image'}}"
            class="flp-reward-image"
            src="{{item.src}}"
            mode="widthFix"
            show-menu-by-longpress="true"
            data-index="{{item.index}}"
            bindtap="onImageTap"
          />
        </block>
      </block>
      <rich-text
        wx:else
        class="flp-reward-content"
        nodes="{{contentNodes}}"
        space="nbsp"
        selectable="true"
        bindtap="onRichTextTap"
      />
    </block>
  </scroll-view>
</view>
