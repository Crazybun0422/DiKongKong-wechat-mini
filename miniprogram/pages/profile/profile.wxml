<view class="profile-page" >
  <view
    class="subscribe-wait-overlay"
    wx:if="{{showSubscribeWaitOverlay}}"
  >
    <view class="subscribe-wait-mask"></view>
    <view class="subscribe-wait-image-wrap" style="top: calc(env(safe-area-inset-top) + 15vh);">
      <image class="subscribe-wait-image" src="/pages/profile/assets/introduction_bg.png" mode="widthFix" />
    </view>
  </view>
  <view scroll-y="false" class="profile-scroll" bindtap="onBlankTap">
    <block wx:if="{{loading}}">
      <view class="profile-loading">加载中...</view>
    </block>
    <block wx:elif="{{error}}">
      <view class="profile-error">
        <text>{{error}}</text>
        <button class="profile-retry-btn" bindtap="onRetryTap">重试</button>
      </view>
    </block>
    <block wx:else>
        <view class="profile-content">
        <view class="profile-header-card">
          <button
            class="profile-avatar-button {{profile.vip ? 'is-vip' : ''}}"
            bindtap="openAvatarActionSheet"
          >
            <view class="profile-avatar-clip">
              <image
                class="profile-avatar"
                src="{{profile.avatarUrl || defaultAvatar}}"
                mode="aspectFill"
              />
              <view class="avatar-overlay">
                <text>更换</text>
              </view>
            </view>
          </button>
          <view class="profile-header-body" catchtap="onEditing">
          <view class="profile-name-row">
            <block wx:if="{{nicknameEditing}}">
              <input
                class="profile-name-input"
                type="nickname"
                  value="{{nicknameInput}}"
                  bindinput="onNicknameInputChange"
                  bindconfirm="onNicknameInputConfirm"
                  confirm-type="done"
                  focus="{{nicknameEditing}}"
                  catchtap="onEditProfileTap"
                  placeholder="编辑昵称"
                  bindnicknamereview="onNickReview"
                />
              </block>
              <block wx:else>
                <text class="profile-name {{profile.vip ? 'is-vip' : ''}}" bindtap="startNicknameEdit">{{profile.nickname}}</text>
                <text class="profile-name-edit" bindtap="startNicknameEdit">点击修改</text>
              </block>
            </view>

            <view class="profile-code-row">
              <text class="profile-code-label">低空号</text>
              <text class="profile-code-value">{{profile.featureCode}}</text>
            </view>
            <view class="profile-like-row">
              <text class="profile-like-label">获赞数</text>
              <text class="profile-like-value">{{likeSummary.total}}</text>
            </view>
          </view>
          <button
            class="profile-member-button"
            bindtap="onMemberCenterTap"
            hover-class="profile-member-button-hover"
            hover-stay-time="90"
          >
            <image
              class="profile-member-image"
              src="{{profile.vip ? '/assets/vip/vip-user.png' : '/assets/vip/regular-user.png'}}"
              mode="aspectFit"
            />
          </button>
        </view>

        <view class="profile-card" id="profile-flp-card" bindtap="onFlpCardTap">
          <view class="profile-card-left">
            <text class="profile-card-title">FLP</text>
            <text class="profile-card-value">{{profile.flpDisplay}}</text>
          </view>
          <image class="profile-card-arrow" src="/assets/arrow-right.png" mode="aspectFit" />
        </view>

        <view class="profile-section">
          <view class="profile-section-title">权益+</view>
          <view class="profile-list">
            <view
              class="profile-list-item"
              hover-class="profile-list-item-hover"
              data-action="markers"
              bindtap="onListItemTap"
            >
              <view class="profile-list-left">
                <image class="profile-list-icon" src="/assets/idea.png" mode="aspectFit" />
                <text class="profile-list-text">创作中心</text>
                <!-- <text class="profile-list-tag">内测中</text> -->
              </view>
              <image class="profile-list-arrow" src="/assets/arrow-right.png" mode="aspectFit" />
            </view>
            <button
              class="profile-list-item profile-list-item-contact"
              hover-class="profile-list-item-hover"
              open-type="contact"
              bindcontact="onCustomerServiceContact"
              session-from="{{customerServiceSessionFrom}}"
            >
              <view class="profile-list-left">
                <text class="profile-list-text">客服</text>
              </view>
              <image class="profile-list-arrow" src="/assets/arrow-right.png" mode="aspectFit" />
            </button>
            <view
              class="profile-list-item"
              hover-class="profile-list-item-hover"
              data-action="open-platform"
              bindtap="onListItemTap"
            >
              <view class="profile-list-left">
                <text class="profile-list-text">开放平台</text>
                <text class="profile-list-tag">插件 / API</text>
              </view>
              <image class="profile-list-arrow" src="/assets/arrow-right.png" mode="aspectFit" />
            </view>
            <view
              class="profile-list-item"
              hover-class="profile-list-item-hover"
              data-action="subscription-feed"
              bindtap="onListItemTap"
            >
              <view class="profile-list-left">
                <text class="profile-list-text">运营动态</text>
              </view>
              <view class="profile-list-right">
                <view class="subscription-badge" wx:if="{{showSubscriptionRedDot}}"></view>
                <image class="profile-list-arrow" src="/assets/arrow-right.png" mode="aspectFit" />
              </view>
            </view>
            <view
              class="profile-list-item"
              hover-class="profile-list-item-hover"
              data-action="community-interaction"
              bindtap="onListItemTap"
            >
              <view class="profile-list-left">
                <text class="profile-list-text">社区互动</text>
              </view>
              <image class="profile-list-arrow" src="/assets/arrow-right.png" mode="aspectFit" />
            </view>
          </view>
        </view>
      </view>
    </block>
  </view>

  <block wx:if="{{avatarActionSheetVisible}}">
    <view class="avatar-action-mask" bindtap="closeAvatarActionSheet" catchtouchmove="noop"></view>
    <view class="avatar-action-sheet" catchtap="noop" catchtouchmove="noop">
      <view class="avatar-action-handle"></view>
      <text class="avatar-action-title">更换头像</text>
      <button
        class="avatar-action-item"
        open-type="chooseAvatar"
        bindchooseavatar="onChooseAvatar"
      >
        <view class="avatar-action-icon avatar-action-icon--wechat"></view>
        <view class="avatar-action-copy">
          <text class="avatar-action-name">微信或照片</text>
          <text class="avatar-action-desc">选择微信头像或本地照片</text>
        </view>
      </button>
      <view class="avatar-action-item avatar-action-item--vip" bindtap="onCyberpunkPilotTap">
        <view class="avatar-action-icon avatar-action-icon--cyber"></view>
        <view class="avatar-action-copy">
          <text class="avatar-action-name">赛博朋克飞手</text>
          <text class="avatar-action-desc">会员专属飞手形象</text>
        </view>
        <image class="avatar-action-vip" src="/assets/vip/vip-user.png" mode="aspectFit" />
      </view>
      <view class="avatar-action-cancel" bindtap="closeAvatarActionSheet">取消</view>
    </view>
  </block>

  <view class="bottom-controls">
    <view class="bottom-menu">
      <button
        class="menu-btn {{activeTab === 'home' ? 'is-active' : ''}}"
        bindtap="onMenuHomeTap"
      >
        <image class="menu-icon" src="{{activeTab === 'home' ? '/assets/home-active.png' : '/assets/home.png'}}" mode="aspectFit" />
      </button>
      <button
        class="menu-btn {{activeTab === 'profile' ? 'is-active' : ''}}"
        bindtap="onMenuProfileTap"
      >
        <image class="menu-icon" src="{{activeTab === 'profile' ? '/assets/profile-active.png' : '/assets/profile.png'}}" mode="aspectFit" />
      </button>
    </view>

    <button class="chat-fab" hover-class="chat-fab-hover" bindtap="onChatButtonTap">
      <image class="chat-fab-icon" src="/assets/ai-chat.png" mode="aspectFit" />
    </button>
  </view>

  <block wx:if="{{showInviteGuideProfile}}">
    <view class="invite-guide-mask invite-guide-mask-top" style="height: {{inviteGuideMask.top}}px;" catchtouchmove="noop"></view>
    <view
      class="invite-guide-mask invite-guide-mask-left"
      style="top: {{inviteGuideMask.top}}px; height: {{inviteGuideMask.height}}px; width: {{inviteGuideMask.left}}px;"
      catchtouchmove="noop"
    ></view>
    <view
      class="invite-guide-mask invite-guide-mask-right"
      style="top: {{inviteGuideMask.top}}px; height: {{inviteGuideMask.height}}px; left: {{inviteGuideMask.rightLeft}}px;"
      catchtouchmove="noop"
    ></view>
    <view
      class="invite-guide-mask invite-guide-mask-bottom"
      style="top: {{inviteGuideMask.bottomTop}}px;"
      catchtouchmove="noop"
    ></view>
    <view
      class="invite-guide-rect"
      style="left: {{inviteGuideMask.left}}px; top: {{inviteGuideMask.top}}px; width: {{inviteGuideMask.width}}px; height: {{inviteGuideMask.height}}px;"
    ></view>
  </block>
</view>


