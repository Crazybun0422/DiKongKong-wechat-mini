.entry-page {
  min-height: 100vh;
  background: #f7f8fa;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.entry-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.entry-loading-image {
  width: 200rpx;
  height: 200rpx;
}

.entry-error {
  text-align: center;
  color: #444;
  font-size: 28rpx;
}

.entry-error-text {
  display: block;
  margin-bottom: 24rpx;
}

.entry-retry {
  min-width: 220rpx;
  height: 72rpx;
  padding: 0 48rpx;
  line-height: 1;
  background: linear-gradient(135deg, #000000 0%, #333333 100%);
  color: #fff;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 24rpx rgba(15, 23, 42, 0.12);
}

.entry-retry::after {
  border: none;
}
