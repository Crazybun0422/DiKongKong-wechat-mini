.temporary-no-fly-announcement-page {
  min-height: 100vh;
  padding: 48rpx 32rpx;
  box-sizing: border-box;
  background: #f5f5f5;
}

.temporary-no-fly-announcement-card {
  padding: 48rpx 36rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.08);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.temporary-no-fly-announcement-title {
  font-size: 34rpx;
  line-height: 1.4;
  color: #111827;
  font-weight: 700;
}

.temporary-no-fly-announcement-desc {
  font-size: 28rpx;
  line-height: 1.6;
  color: #6b7280;
}
