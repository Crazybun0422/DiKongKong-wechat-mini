.temporary-no-fly-announcement-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  padding: 24rpx 24rpx 0;
  background: #ffffff;
  overflow: hidden;
}

.temporary-no-fly-announcement-fixed-top {
  flex: 0 0 auto;
  background: #ffffff;
}

.temporary-no-fly-announcement-search-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.temporary-no-fly-announcement-search {
  flex: 1;
  width: auto;
  min-width: 0;
  max-width: 480rpx;
  height: 76rpx;
  padding: 0 24rpx;
  border-radius: 38rpx;
  background: #ffffff;
  border: 1rpx solid #d8d8d8;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

button.marker-page-share-header.temporary-no-fly-announcement-share-btn {
  width: 88rpx;
  height: 88rpx;
  min-width: 88rpx;
  margin: 0;
}

button.marker-page-share-header.temporary-no-fly-announcement-share-btn::after {
  border: none;
}

button.marker-page-share-header {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: transparent;
  border: none;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

button.marker-page-share-header::after {
  border: none;
}

.marker-page-share-header-icon {
  width: 88rpx;
  height: 88rpx;
}

.temporary-no-fly-announcement-search-icon {
  width: 42rpx;
  height: 42rpx;
  flex: 0 0 42rpx;
  opacity: 0.72;
}

.temporary-no-fly-announcement-search-input {
  flex: 1;
  min-width: 0;
  height: 100%;
  font-size: 28rpx;
  color: #111111;
}

.temporary-no-fly-announcement-search-placeholder {
  color: #b0b0b0;
}

.temporary-no-fly-announcement-notice {
  margin-top: 18rpx;
  padding: 20rpx 22rpx;
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  border-radius: 18rpx;
  background: #FFF7E8;
  font-size: 24rpx;
  line-height: 1.6;
  color: #D7A33A;
}

.temporary-no-fly-announcement-notice-icon {
  width: 54rpx;
  height: 54rpx;
  flex: 0 0 54rpx;
  margin-top: 0;
  opacity: 0.92;
}

.temporary-no-fly-announcement-notice-content {
  flex: 1;
  min-width: 0;
  color: #D7A33A;
}

.temporary-no-fly-announcement-scroll {
  flex: 1 1 auto;
  min-height: 0;
  margin-top: 20rpx;
  padding-bottom: 20rpx;
  box-sizing: border-box;
}

.temporary-no-fly-announcement-state,
.temporary-no-fly-announcement-footer {
  padding: 40rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #8b8b8b;
  background: #ffffff;
}

.temporary-no-fly-announcement-list {
  padding-bottom: 12rpx;
}

.temporary-no-fly-announcement-item {
  margin-bottom: 18rpx;
  padding: 18rpx 18rpx;
  border-radius: 20rpx;
  background: #f2f2f2;
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}

.temporary-no-fly-announcement-item-main {
  flex: 1;
  min-width: 0;
}

.temporary-no-fly-announcement-item-title {
  font-size: 32rpx;
  line-height: 1.28;
  color: #000000;
  font-weight: 700;
  word-break: break-all;
}

.temporary-no-fly-announcement-period-row {
  margin-top: 0;
  display: flex;
  align-items: center;
  font-size: 22rpx;
  line-height: 0.9;
  gap: 4rpx;
}

.temporary-no-fly-announcement-period-label {
  color: #555555;
  flex: 0 0 auto;
  white-space: nowrap;
}

.temporary-no-fly-announcement-period-label--active {
  color: #D7A33A;
}

.temporary-no-fly-announcement-period-value {
  color: #8a8a8a;
  flex: 1;
  min-width: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.temporary-no-fly-announcement-period-value--active {
  color: #D7A33A;
}

.temporary-no-fly-announcement-map-entry {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  width: 96rpx;
  flex: 0 0 96rpx;
}

.temporary-no-fly-announcement-map-entry-list {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  flex: 0 0 96rpx;
  padding-top: 2rpx;
}

.temporary-no-fly-announcement-map-icon {
  width: 64rpx;
  height: 64rpx;
}

.temporary-no-fly-announcement-map-text {
  margin-top: 4rpx;
  font-size: 22rpx;
  line-height: 1.1;
  color: #2b2b2b;
  white-space: nowrap;
}

.temporary-no-fly-announcement-fixed-bottom {
  flex: 0 0 auto;
  background: #ffffff;
  padding: 8rpx 0 12rpx;
}

.temporary-no-fly-announcement-disclaimer {
  font-size: 20rpx;
  line-height: 1.6;
  color: #8b8b8b;
}
